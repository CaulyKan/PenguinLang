class Foo {
    x: i32;
    y: i32;    
    fun new(mut this, x: i32, y: i32) {
        this.x = x;
        this.y = y;
    }
    fun to_str(this) -> string {
        return "foo=" + cast<string>(this.x) + "," + cast<string>(this.y);
    }
}

initial {
    let f = new Foo(1,2);
    println(f.to_str());
}