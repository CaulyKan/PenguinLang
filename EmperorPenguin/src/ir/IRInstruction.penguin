// 23. GLOBAL_STORE - store value to a global variable
class IRGlobalStore {
    global_name: !mut string = "";
    value: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, global_name: string, value: IRValue, loc: IRSourceLocation) {
        this.global_name = global_name;
        this.value = value;
        this.location = loc;
    }

    fun display(this) -> string {
        return "GLOBAL_STORE @" + this.global_name + ", " + this.value.display();
    }
}

// IRInstruction enum
enum IRInstruction {
    const_inst: IRConst;
    arg: IRArg;
    assign: IRAssign;
    cast_inst: IRCast;
    binop: IRBinOp;
    unaryop: IRUnaryOp;
    rdmbr: IRRdmbr;
    wrmbr: IRWrmbr;
    br: IRBr;
    br_cond: IRBrCond;
    ret: IRRet;
    ret_void: IRRetVoid;
    call: IRCall;
    call_void: IRCallVoid;
    call_virt: IRCallVirt;
    new_inst: IRNew;
    new_enum: IRNewEnum;
    isenum: IRIsEnum;
    rdenum: IRRdenum;
    isinstance: IRIsInstance;
    box: IRBox;
    unbox: IRUnbox;
    label_inst: IRLabelInst;
    global_load: IRGlobalLoad;
    global_store: IRGlobalStore;

    fun display(this) -> string {
        if (this is IRInstruction.const_inst) { return this.const_inst.display(); }
        if (this is IRInstruction.arg) { return this.arg.display(); }
        if (this is IRInstruction.assign) { return this.assign.display(); }
        if (this is IRInstruction.cast_inst) { return this.cast_inst.display(); }
        if (this is IRInstruction.binop) { return this.binop.display(); }
        if (this is IRInstruction.unaryop) { return this.unaryop.display(); }
        if (this is IRInstruction.rdmbr) { return this.rdmbr.display(); }
        if (this is IRInstruction.wrmbr) { return this.wrmbr.display(); }
        if (this is IRInstruction.br) { return this.br.display(); }
        if (this is IRInstruction.br_cond) { return this.br_cond.display(); }
        if (this is IRInstruction.ret) { return this.ret.display(); }
        if (this is IRInstruction.ret_void) { return this.ret_void.display(); }
        if (this is IRInstruction.call) { return this.call.display(); }
        if (this is IRInstruction.call_void) { return this.call_void.display(); }
        if (this is IRInstruction.call_virt) { return this.call_virt.display(); }
        if (this is IRInstruction.new_inst) { return this.new_inst.display(); }
        if (this is IRInstruction.new_enum) { return this.new_enum.display(); }
        if (this is IRInstruction.isenum) { return this.isenum.display(); }
        if (this is IRInstruction.rdenum) { return this.rdenum.display(); }
        if (this is IRInstruction.isinstance) { return this.isinstance.display(); }
        if (this is IRInstruction.box) { return this.box.display(); }
        if (this is IRInstruction.unbox) { return this.unbox.display(); }
        if (this is IRInstruction.label_inst) { return this.label_inst.display(); }
        if (this is IRInstruction.global_load) { return this.global_load.display(); }
        if (this is IRInstruction.global_store) { return this.global_store.display(); }
        return "unknown_instruction";
    }

    fun is_terminator(this) -> bool {
        if (this is IRInstruction.ret) { return true; }
        if (this is IRInstruction.ret_void) { return true; }
        return false;
    }

    fun is_control_flow(this) -> bool {
        if (this is IRInstruction.br) { return true; }
        if (this is IRInstruction.br_cond) { return true; }
        if (this is IRInstruction.ret) { return true; }
        if (this is IRInstruction.ret_void) { return true; }
        return false;
    }
}

}
