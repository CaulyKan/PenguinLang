namespace ir {

// 1. CONST - constant assignment
class IRConst {
    result: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    value: !mut string = "";
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, result: IRValue, value: string, loc: IRSourceLocation) {
        this.result = result;
        this.value = value;
        this.location = loc;
    }

    fun display(this) -> string {
        return this.result.display() + ":" + this.result.get_ir_type() + " = CONST " + this.value;
    }
}

// 2. ARG - argument/parameter access
class IRArg {
    result: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    param_name: !mut string = "";
    param_index: !mut i64 = 0;
    ir_type: !mut string = "";
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, result: IRValue, param_name: string, param_index: i64, ir_type: string, loc: IRSourceLocation) {
        this.result = result;
        this.param_name = param_name;
        this.param_index = param_index;
        this.ir_type = ir_type;
        this.location = loc;
    }

    fun display(this) -> string {
        return this.result.display() + ":" + this.ir_type + " = ARG " + this.param_name + " " + cast<string>(this.param_index);
    }
}

// 3. ASSIGN - variable assignment
class IRAssign {
    dest: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    src: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, dest: IRValue, src: IRValue, loc: IRSourceLocation) {
        this.dest = dest;
        this.src = src;
        this.location = loc;
    }

    fun display(this) -> string {
        return this.dest.display() + ":" + this.dest.get_ir_type() + " = ASSIGN " + this.src.display();
    }
}

// 3. CAST - type conversion
class IRCast {
    result: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    operand: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    from_type: !mut string = "";
    to_type: !mut string = "";
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, result: IRValue, operand: IRValue, from_type: string, to_type: string, loc: IRSourceLocation) {
        this.result = result;
        this.operand = operand;
        this.from_type = from_type;
        this.to_type = to_type;
        this.location = loc;
    }

    fun display(this) -> string {
        return this.result.display() + ":" + this.to_type + " = CAST " + this.operand.display() + " " + this.from_type + "->" + this.to_type;
    }
}

// 4. BINOP - binary operations (arithmetic and logical)
class IRBinOp {
    op: !mut string = "";
    left: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    right: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    result: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    ir_type: !mut string = "";
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, op: string, left: IRValue, right: IRValue, result: IRValue, ir_type: string, loc: IRSourceLocation) {
        this.op = op;
        this.left = left;
        this.right = right;
        this.result = result;
        this.ir_type = ir_type;
        this.location = loc;
    }

    fun display(this) -> string {
        return this.result.display() + ":" + this.ir_type + " = BINOP " + this.op + " " + this.left.display() + ", " + this.right.display();
    }
}

