        return this.result.display() + ":" + this.payload_type + " = RDENUM " + this.enum_value.display() + ", ." + this.variant_name;
    }
}

// 18a. ISINSTANCE - interface/class type check (runtime metadata lookup)
class IRIsInstance {
    obj: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
