    target: !mut IRLabel = new IRLabel("");
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, target: IRLabel, loc: IRSourceLocation) {
        this.target = target;
        this.location = loc;
    }

    fun display(this) -> string {
