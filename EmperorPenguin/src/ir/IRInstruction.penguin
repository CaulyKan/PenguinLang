class IRWrmbr {
    obj: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    field_name: !mut string = "";
    value: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, obj: IRValue, field_name: string, value: IRValue, loc: IRSourceLocation) {
        this.obj = obj;
        this.field_name = field_name;
        this.value = value;
        this.location = loc;
    }

    fun display(this) -> string {
        return "WRMBR " + this.obj.display() + ", ." + this.field_name + ", " + this.value.display();
    }
}

