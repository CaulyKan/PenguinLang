    }
}

// 9. BR_COND - conditional branch
class IRBrCond {
    cond: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    true_label: !mut IRLabel = new IRLabel("");
    false_label: !mut IRLabel = new IRLabel("");
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, cond: IRValue, true_label: IRLabel, false_label: IRLabel, loc: IRSourceLocation) {
        this.cond = cond;
        this.true_label = true_label;
        this.false_label = false_label;
        this.location = loc;
    }

    fun display(this) -> string {
        return "BR_COND " + this.cond.display() + ", " + this.true_label.name + ", " + this.false_label.name;
    }
}

