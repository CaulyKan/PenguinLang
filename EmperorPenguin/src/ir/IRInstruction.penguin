// 6. RDMBR - read member (replaces GEP + LOAD)
class IRRdmbr {
    result: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    obj: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    field_name: !mut string = "";
    ir_type: !mut string = "";
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, result: IRValue, obj: IRValue, field_name: string, ir_type: string, loc: IRSourceLocation) {
        this.result = result;
        this.obj = obj;
        this.field_name = field_name;
        this.ir_type = ir_type;
        this.location = loc;
    }

    fun display(this) -> string {
        return this.result.display() + ":" + this.ir_type + " = RDMBR " + this.obj.display() + ", ." + this.field_name;
    }
}

