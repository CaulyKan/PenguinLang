// 11. RET_VOID - return void
class IRRetVoid {
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, loc: IRSourceLocation) {
        this.location = loc;
    }

    fun display(this) -> string {
        return "RET_VOID";
    }
}

// 12a. CALL - function call with result
class IRCall {
    func_name: !mut string = "";
    args: !mut _utils.List<IRValue> = new _utils.List<IRValue>();
    result_value: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    ret_type: !mut string = "";
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, func_name: string, args: mut _utils.List<IRValue>, result: IRValue, ret_type: string, loc: IRSourceLocation) {
        this.func_name = func_name;
        this.args = args;
        this.result_value = result;
        this.ret_type = ret_type;
        this.location = loc;
    }

    fun display(this) -> string {
        let sb = new mut StringBuilder();
        // Only show result if ret_type is not void
        if (this.ret_type != "void") {
            sb.append(this.result_value.display());
            sb.append(":" + this.ret_type + " = ");
        }
        sb.append("CALL @" + this.func_name + "(");
        let i: mut i64 = 0;
        while (i < cast<i64>(this.args.size())) {
            if (i > 0) { sb.append(", "); }
            sb.append(this.args.at(cast<u64>(i)).some.display());
            i = i + 1;
        }
        sb.append(")");
        return sb.to_string();
    }
}

// 12b. CALL_VOID - void function call
class IRCallVoid {
    func_name: !mut string = "";
    args: !mut _utils.List<IRValue> = new _utils.List<IRValue>();
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, func_name: string, args: mut _utils.List<IRValue>, loc: IRSourceLocation) {
        this.func_name = func_name;
        this.args = args;
        this.location = loc;
    }

    fun display(this) -> string {
        let sb = new mut StringBuilder();
        sb.append("CALL @" + this.func_name + "(");
        let i: mut i64 = 0;
        while (i < cast<i64>(this.args.size())) {
            if (i > 0) { sb.append(", "); }
            sb.append(this.args.at(cast<u64>(i)).some.display());
            i = i + 1;
        }
        sb.append(")");
        return sb.to_string();
    }
}

// 13. CALL_VIRT - virtual call through interface_map
class IRCallVirt {
    obj: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    interface_id: !mut string = "";
    vtable_slot: !mut i64 = 0;
    args: mut _utils.List<IRValue> = new _utils.List<IRValue>();
    result_value: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    ret_type: !mut string = "";
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, obj: IRValue, interface_id: string, vtable_slot: i64, args: mut _utils.List<IRValue>, result: IRValue, ret_type: string, loc: IRSourceLocation) {
        this.obj = obj;
        this.interface_id = interface_id;
        this.vtable_slot = vtable_slot;
        this.args = args;
        this.result_value = result;
        this.ret_type = ret_type;
        this.location = loc;
    }

    fun display(this) -> string {
        let sb = new mut StringBuilder();
        if (this.ret_type != "void") {
            sb.append(this.result_value.display());
            sb.append(":" + this.ret_type + " = ");
        }
        sb.append("CALL_VIRT " + this.obj.display() + ", interface=" + this.interface_id + ", slot=" + cast<string>(this.vtable_slot) + "(");
        let i: mut i64 = 0;
        while (i < cast<i64>(this.args.size())) {
            if (i > 0) { sb.append(", "); }
            sb.append(this.args.at(cast<u64>(i)).some.display());
            i = i + 1;
        }
        sb.append(")");
        return sb.to_string();
    }
}

// 14. NEW - object creation
class IRNew {
    type_name: !mut string = "";
    args: mut _utils.List<IRValue> = new _utils.List<IRValue>();
    result: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, type_name: string, args: mut _utils.List<IRValue>, result: IRValue, loc: IRSourceLocation) {
        this.type_name = type_name;
        this.args = args;
        this.result = result;
        this.location = loc;
    }

    fun display(this) -> string {
        let sb = new mut StringBuilder();
        sb.append(this.result.display() + ":ptr = NEW " + this.type_name + "(");
        let i: mut i64 = 0;
        while (i < cast<i64>(this.args.size())) {
            if (i > 0) { sb.append(", "); }
            sb.append(this.args.at(cast<u64>(i)).some.display());
            i = i + 1;
        }
        sb.append(")");
        return sb.to_string();
    }
}

// 15. NEW_ENUM - enum creation
class IRNewEnum {
    type_name: !mut string = "";
    variant_idx: !mut i64 = 0;
    variant_name: !mut string = "";
    payload: !mut Option<IRValue> = new Option<IRValue>.none();
    result: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, type_name: string, variant_idx: i64, variant_name: string, payload: Option<IRValue>, result: IRValue, loc: IRSourceLocation) {
        this.type_name = type_name;
        this.variant_idx = variant_idx;
        this.variant_name = variant_name;
        this.payload = payload;
        this.result = result;
        this.location = loc;
    }

    fun display(this) -> string {
        let sb = new mut StringBuilder();
        sb.append(this.result.display() + " = NEW_ENUM " + this.type_name + "." + this.variant_name);
        if (this.payload.is_some()) {
            sb.append("(" + this.payload.some.display() + ")");
        }
        return sb.to_string();
    }
}

// 16. ISENUM - enum pattern matching (check if enum value is a specific variant)
class IRIsEnum {
    enum_value: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    variant_idx: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    result: !mut IRValue = new IRValue.constant(new IRConstant("", ""));
    location: !mut IRSourceLocation = new IRSourceLocation("", 0, 0);

    fun new(mut this, enum_value: IRValue, variant_idx: IRValue, result: IRValue, loc: IRSourceLocation) {
        this.enum_value = enum_value;
        this.variant_idx = variant_idx;
        this.result = result;
        this.location = loc;
    }

    fun display(this) -> string {
        return this.result.display() + ":bool = ISENUM " + this.enum_value.display() + ", " + this.variant_idx.display();
    }
}

