namespace bound {

class FunctionInstantiation {
    func_name: !mut string = "";
    generic_args: mut _utils.List<BoundType> = new _utils.List<BoundType>();

    fun new(mut this, func_name: string, generic_args: mut _utils.List<BoundType>) {
        this.func_name = func_name;
        this.generic_args = generic_args;
    }
}

class SemanticModel {
    type_registry: mut BoundTypeRegistry;
    errors: mut _utils.List<SemanticError> = new _utils.List<SemanticError>();
    global_scope: mut BoundScope;
    current_unit: mut Option<BoundCompilationUnit> = new Option<BoundCompilationUnit>.none();
    _current_validating_func: mut string = "";
    ast_definitions: mut _utils.List<ast.Definition> = new _utils.List<ast.Definition>();

    fun new(mut this) {
        this.type_registry = new BoundTypeRegistry();
        this.global_scope = new BoundScope(new ScopeKind.GlobalScope(), "<global>", "<global>", new Option<BoundScope>.none());
        this.register_builtin_interfaces();
        this.register_builtin_functions();
    }

    fun register_builtin_interfaces(mut this) {
        this.register_builtin_interface("ICopy");
        this.register_builtin_interface("IRef");
    }

    fun make_primitive_type(this, name: string) -> mut BoundType {
        let t: mut BoundType = new BoundType();
        t.kind = new TypeKind.PrimitiveKind();
        if (name == "string") {
            t.primitive = new PrimitiveType.StringType();
        }
        if (name == "void") {
            t.primitive = new PrimitiveType.VoidType();
        }
        if (name == "i32") {
            t.primitive = new PrimitiveType.I32();
        }
        if (name == "i64") {
            t.primitive = new PrimitiveType.I64();
        }
        if (name == "bool") {
            t.primitive = new PrimitiveType.BoolType();
        }
        return t;
    }

    fun register_builtin_extern_fun(mut this, name: string, param_type_names: _utils.List<string>, ret_type_name: string) {
        let full_name: string = "<global>." + name;
        let sym: mut BoundFunctionSymbol = new BoundFunctionSymbol(name, full_name);
        sym.return_type = this.make_primitive_type(ret_type_name);
        sym.is_extern = true;
        let pi: mut i64 = 0;
        while (pi < cast<i64>(param_type_names.size())) {
            let p_type_name: string = param_type_names.at(cast<u64>(pi)).some;
            let p: mut BoundFunctionParameter = new BoundFunctionParameter("p" + cast<string>(pi), pi, false, false);
            p.bound_type = this.make_primitive_type(p_type_name);
            sym.parameters.push(p);
            pi = pi + 1;
        }
        this.global_scope.add_symbol(new BoundSymbol.function_sym(sym));
    }

    fun register_builtin_functions(mut this) {
        let string_params: mut _utils.List<string> = new _utils.List<string>();
        string_params.push("string");
        this.register_builtin_extern_fun("print", string_params, "void");
        this.register_builtin_extern_fun("println", string_params, "void");
        let no_params: mut _utils.List<string> = new _utils.List<string>();
        this.register_builtin_extern_fun("_emperor_gc_collect", no_params, "void");
        this.register_builtin_extern_fun("_emperor_gc_info", no_params, "i64");
    }

    fun register_builtin_interface(mut this, name: string) {
        let full_name: string = "<global>." + name;
        let iface_scope: mut BoundScope = new BoundScope(new ScopeKind.InterfaceScope(), name, full_name, new Option<BoundScope>.some(this.global_scope));
        let type_sym: mut BoundTypeSymbol = new BoundTypeSymbol(name, full_name);
        let t: mut BoundType = new BoundType();
        t.kind = new TypeKind.InterfaceKind();
        let iface_def: mut BoundInterfaceDefinition = new BoundInterfaceDefinition(name, full_name);
        iface_def.scope = new Option<BoundScope>.some(iface_scope);
        t.type_definition = new Option<BoundDefinition>.some(new BoundDefinition.interface_def(iface_def));
        type_sym.bound_type = t;
        iface_def.type_symbol = new Option<BoundTypeSymbol>.some(type_sym);
        iface_def.bound_type = t;
        this.global_scope.add_symbol(new BoundSymbol.type_sym(type_sym));
    }

    fun bind(mut this, unit: ast.CompilationUnit, source_file: string) -> BoundCompilationUnit {
        let result: mut BoundCompilationUnit = new BoundCompilationUnit();
        result.source_file = source_file;
        result.type_registry = this.type_registry;
        result.global_scope = this.global_scope;
        this.ast_definitions = unit.definitions;
        this.pass_build_scopes(unit, result);
        this.pass_resolve_types(unit, result);
        this.pass_monomorphize(unit, result);
        this.pass_bind_symbols(result);
        this.pass_constructors(result);
        this.pass_interface_implementation(unit, result);
        this.pass_classify_value_types(result);
        this.pass_bind_expressions(unit, result);
        this.pass_validate_control_flow(result);
        result.errors = this.errors;
        return result;
    }

    fun pass_build_scopes(mut this, unit: ast.CompilationUnit, result: BoundCompilationUnit) {
        let i: mut i64 = 0;
        while (i < cast<i64>(unit.definitions.size())) {
            let def: ast.Definition = unit.definitions.at(cast<u64>(i)).some;
            let bound: Option<BoundDefinition> = this.bind_definition(def, result.global_scope);
            if (bound.is_some()) {
                result.definitions.push(bound.some);
            }
            i = i + 1;
        }
    }

    fun bind_definition(mut this, def: ast.Definition, scope: mut BoundScope) -> Option<BoundDefinition> {
        if (def is ast.Definition.function_def) {
            return this.bind_function_def(def.function_def, scope);
        }
        if (def is ast.Definition.class_def) {
            return this.bind_class_def(def.class_def, scope);
        }
        if (def is ast.Definition.enum_def) {
            return this.bind_enum_def(def.enum_def, scope);
        }
        if (def is ast.Definition.interface_def) {
            return this.bind_interface_def(def.interface_def, scope);
        }
        if (def is ast.Definition.namespace_def) {
            return this.bind_namespace_def(def.namespace_def, scope);
        }
        if (def is ast.Definition.initial_routine) {
            return this.bind_initial_routine(def.initial_routine, scope);
        }
        if (def is ast.Definition.impl_def) {
            return this.bind_impl_def(def.impl_def, scope);
        }
        if (def is ast.Definition.impl_for_def) {
            return this.bind_impl_for_def(def.impl_for_def, scope);
        }
        if (def is ast.Definition.type_ref_def) {
            return this.bind_type_ref_def(def.type_ref_def, scope);
        }
        if (def is ast.Definition.global_var) {
            return this.bind_global_var_def(def.global_var, scope);
        }
        return new Option<BoundDefinition>.none();
    }

    fun extract_template_params(this, template_decl: Option<ast.TemplateDeclaration>, generic_params: mut _utils.List<string>) {
        if (template_decl.is_some()) {
            let td: ast.TemplateDeclaration = template_decl.some;
            let j: mut i64 = 0;
            while (j < cast<i64>(td.parameters.size())) {
                let param: ast.TemplateParameter = td.parameters.at(cast<u64>(j)).some;
                generic_params.push(param.name);
                j = j + 1;
            }
        }
    }

    fun bind_function_def(mut this, def: ast.FunctionDefinition, scope: mut BoundScope) -> Option<BoundDefinition> {
        let full_name: string = scope.full_name + "." + def.name;
        let result: mut BoundFunctionDefinition = new BoundFunctionDefinition(def.name, full_name, def.is_extern, def.is_pure, def.is_new, def.is_extern);
        this.extract_template_params(def.template_decl, result.generic_params);
        if (!def.is_extern && def.body.is_some()) {
            let func_scope: mut BoundScope = new BoundScope(new ScopeKind.FunctionScope(), def.name, full_name + ".<body>", new Option<BoundScope>.some(scope));
            result.scope = new Option<BoundScope>.some(func_scope);
        }
        let sym: mut BoundFunctionSymbol = new BoundFunctionSymbol(def.name, full_name);
        sym.is_extern = def.is_extern;
        sym.is_static = result.is_static;
        sym.is_pure = def.is_pure;
        sym.is_new = def.is_new;
        result.symbol = new Option<BoundFunctionSymbol>.some(sym);
        if (cast<i64>(result.generic_params.size()) > 0) {
            result.is_generic_template = true;
        }
        scope.add_symbol(new BoundSymbol.function_sym(sym));
        return new Option<BoundDefinition>.some(new BoundDefinition.function_def(result));
    }

    fun bind_class_def(mut this, def: ast.ClassDefinition, scope: mut BoundScope) -> Option<BoundDefinition> {
        let full_name: string = scope.full_name + "." + def.name;
        let result: mut BoundClassDefinition = new BoundClassDefinition(def.name, full_name);
        this.extract_template_params(def.template_decl, result.generic_params);
        if (cast<i64>(result.generic_params.size()) > 0) {
            result.is_generic_template = true;
        }
        let class_scope: mut BoundScope = new BoundScope(new ScopeKind.ClassScope(), def.name, full_name, new Option<BoundScope>.some(scope));
        result.scope = new Option<BoundScope>.some(class_scope);
        let type_sym: mut BoundTypeSymbol = new BoundTypeSymbol(def.name, full_name);
        this.extract_template_params(def.template_decl, type_sym.generic_params);
        let t: mut BoundType = new BoundType();
        t.kind = new TypeKind.ClassKind();
        t.type_definition = new Option<BoundDefinition>.some(new BoundDefinition.class_def(result));
        type_sym.bound_type = t;
        result.type_symbol = new Option<BoundTypeSymbol>.some(type_sym);
        result.bound_type = t;
        scope.add_symbol(new BoundSymbol.type_sym(type_sym));
        let i: mut i64 = 0;
        while (i < cast<i64>(def.members.size())) {
            let member: ast.Definition = def.members.at(cast<u64>(i)).some;
            if (member is ast.Definition.class_field) {
                let ast_field: ast.ClassFieldDefinition = member.class_field;
                let field: mut BoundClassFieldDefinition = new BoundClassFieldDefinition(ast_field.name);
                let field_full_name: string = full_name + "." + ast_field.name;
                let fsym: mut BoundVariableSymbol = new BoundVariableSymbol();
                fsym.name = ast_field.name;
                fsym.full_name = field_full_name;
                fsym.variable_kind = new VariableSymbolKind.Field();
                fsym.is_mutable = true;
                fsym.enclosing_scope = new Option<BoundScope>.some(class_scope);
                field.field_symbol = new Option<BoundVariableSymbol>.some(fsym);
                class_scope.add_symbol(new BoundSymbol.variable(fsym));
                result.fields.push(new BoundDefinition.class_field(field));
            }
            if (member is ast.Definition.function_def) {
                let bound_member: Option<BoundDefinition> = this.bind_function_def(member.function_def, class_scope);
                if (bound_member.is_some()) {
                    result.methods.push(bound_member.some);
                }
            }
            if (member is ast.Definition.impl_def) {
                let bound_impl: Option<BoundDefinition> = this.bind_impl_def(member.impl_def, class_scope);
                if (bound_impl.is_some()) {
                    result.interface_impls.push(bound_impl.some);
                }
            }
            i = i + 1;
        }
        result.ast_source = new Option<ast.Definition>.some(new ast.Definition.class_def(def));
        return new Option<BoundDefinition>.some(new BoundDefinition.class_def(result));
    }

    fun bind_enum_def(mut this, def: ast.EnumDefinition, scope: mut BoundScope) -> Option<BoundDefinition> {
        let full_name: string = scope.full_name + "." + def.name;
        let result: mut BoundEnumDefinition = new BoundEnumDefinition(def.name, full_name);
        this.extract_template_params(def.template_decl, result.generic_params);
        let enum_scope: mut BoundScope = new BoundScope(new ScopeKind.EnumScope(), def.name, full_name, new Option<BoundScope>.some(scope));
        result.scope = new Option<BoundScope>.some(enum_scope);
        let type_sym: mut BoundTypeSymbol = new BoundTypeSymbol(def.name, full_name);
        this.extract_template_params(def.template_decl, type_sym.generic_params);
        let t: mut BoundType = new BoundType();
        t.kind = new TypeKind.EnumKind();
        t.type_definition = new Option<BoundDefinition>.some(new BoundDefinition.enum_def(result));
        type_sym.bound_type = t;
        result.type_symbol = new Option<BoundTypeSymbol>.some(type_sym);
        result.bound_type = t;
        scope.add_symbol(new BoundSymbol.type_sym(type_sym));
        // Register generic type params in enum scope so payload types can resolve them
        if (cast<i64>(result.generic_params.size()) > 0) {
            let gi: mut i64 = 0;
            while (gi < cast<i64>(result.generic_params.size())) {
                let param_name: string = result.generic_params.at(cast<u64>(gi)).some;
                let param_sym: mut BoundTypeSymbol = new BoundTypeSymbol(param_name, full_name + "." + param_name);
                let pt: mut BoundType = new BoundType();
                pt.kind = new TypeKind.ClassKind();
                let dummy_def: mut BoundClassDefinition = new BoundClassDefinition(param_name, full_name + "." + param_name);
                pt.type_definition = new Option<BoundDefinition>.some(new BoundDefinition.class_def(dummy_def));
                param_sym.bound_type = pt;
                enum_scope.add_symbol(new BoundSymbol.type_sym(param_sym));
                gi = gi + 1;
            }
        }
        let member_idx: mut i64 = 0;
        let i: mut i64 = 0;
        while (i < cast<i64>(def.members.size())) {
            let member: ast.Definition = def.members.at(cast<u64>(i)).some;
            if (member is ast.Definition.enum_member) {
                // Resolve payload type from type_spec
                let payload_type: mut BoundType = this.type_registry.void_type;
                if (member.enum_member.type_spec.is_some()) {
                    payload_type = this.resolve_type_specifier(member.enum_member.type_spec.some, enum_scope);
                }
                let m: mut BoundEnumMemberDefinition = new BoundEnumMemberDefinition(member.enum_member.name, member_idx, payload_type);
                let msym: mut BoundEnumMemberSymbol = new BoundEnumMemberSymbol(member.enum_member.name, full_name + "." + member.enum_member.name, t, member_idx, payload_type);
                m.member_symbol = new Option<BoundEnumMemberSymbol>.some(msym);
                enum_scope.add_symbol(new BoundSymbol.enum_member(msym));
                result.members.push(m);
                member_idx = member_idx + 1;
            }
            if (member is ast.Definition.impl_def) {
                let bound_impl: Option<BoundDefinition> = this.bind_impl_def(member.impl_def, enum_scope);
                if (bound_impl.is_some()) {
                    result.interface_impls.push(bound_impl.some);
                }
            }
            if (member is ast.Definition.function_def) {
                let bound_method: Option<BoundDefinition> = this.bind_function_def(member.function_def, enum_scope);
                if (bound_method.is_some()) {
                    result.methods.push(bound_method.some);
                }
            }
            i = i + 1;
        }
        result.ast_source = new Option<ast.Definition>.some(new ast.Definition.enum_def(def));
        return new Option<BoundDefinition>.some(new BoundDefinition.enum_def(result));
    }

    fun bind_interface_def(mut this, def: ast.InterfaceDefinition, scope: mut BoundScope) -> Option<BoundDefinition> {
        let full_name: string = scope.full_name + "." + def.name;
        let result: mut BoundInterfaceDefinition = new BoundInterfaceDefinition(def.name, full_name);
        this.extract_template_params(def.template_decl, result.generic_params);
        let iface_scope: mut BoundScope = new BoundScope(new ScopeKind.InterfaceScope(), def.name, full_name, new Option<BoundScope>.some(scope));
        result.scope = new Option<BoundScope>.some(iface_scope);
        let type_sym: mut BoundTypeSymbol = new BoundTypeSymbol(def.name, full_name);
        this.extract_template_params(def.template_decl, type_sym.generic_params);
        let t: mut BoundType = new BoundType();
        t.kind = new TypeKind.InterfaceKind();
        t.type_definition = new Option<BoundDefinition>.some(new BoundDefinition.interface_def(result));
        type_sym.bound_type = t;
        result.type_symbol = new Option<BoundTypeSymbol>.some(type_sym);
        result.bound_type = t;
        scope.add_symbol(new BoundSymbol.type_sym(type_sym));
        let i: mut i64 = 0;
        while (i < cast<i64>(def.members.size())) {
            let member: ast.Definition = def.members.at(cast<u64>(i)).some;
            if (member is ast.Definition.function_def) {
                let bound_member: Option<BoundDefinition> = this.bind_function_def(member.function_def, iface_scope);
                if (bound_member.is_some()) {
                    result.methods.push(bound_member.some);
                }
            }
            i = i + 1;
        }
        result.ast_source = new Option<ast.Definition>.some(new ast.Definition.interface_def(def));
        return new Option<BoundDefinition>.some(new BoundDefinition.interface_def(result));
    }

    fun bind_namespace_def(mut this, def: ast.NamespaceDefinition, scope: mut BoundScope) -> Option<BoundDefinition> {
        let ns_scope: mut BoundScope = scope.add_or_merge_namespace(def.name);
        let result: mut BoundNamespaceDefinition = new BoundNamespaceDefinition(def.name, ns_scope.full_name);
        result.scope = new Option<BoundScope>.some(ns_scope);
        if (!ns_scope.lookup_symbol_local(def.name).is_some()) {
            let ns_sym: BoundNamespaceSymbol = new BoundNamespaceSymbol(def.name, ns_scope.full_name, new Option<BoundScope>.some(ns_scope));
            scope.add_symbol(new BoundSymbol.namespace_sym(ns_sym));
        }
        let i: mut i64 = 0;
        while (i < cast<i64>(def.children.size())) {
            let child: ast.Definition = def.children.at(cast<u64>(i)).some;
            let bound: Option<BoundDefinition> = this.bind_definition(child, ns_scope);
            if (bound.is_some()) {
                result.children.push(bound.some);
            }
            i = i + 1;
        }
        return new Option<BoundDefinition>.some(new BoundDefinition.namespace_def(result));
    }

    fun bind_initial_routine(mut this, def: ast.InitialRoutineDefinition, scope: mut BoundScope) -> Option<BoundDefinition> {
        let full_name: string = scope.full_name + ".<initial>";
        let result: mut BoundInitialRoutineDefinition = new BoundInitialRoutineDefinition(full_name);
        let init_scope: mut BoundScope = new BoundScope(new ScopeKind.InitialRoutineScope(), "<initial>", full_name + ".<body>", new Option<BoundScope>.some(scope));
        result.scope = new Option<BoundScope>.some(init_scope);
        let sym: mut BoundFunctionSymbol = new BoundFunctionSymbol("<initial>", full_name);
        result.symbol = new Option<BoundFunctionSymbol>.some(sym);
        scope.add_symbol(new BoundSymbol.function_sym(sym));
        return new Option<BoundDefinition>.some(new BoundDefinition.initial_routine(result));
    }

    fun bind_impl_def(mut this, def: ast.InterfaceImplementation, scope: mut BoundScope) -> Option<BoundDefinition> {
        let result: mut BoundInterfaceImplementation = new BoundInterfaceImplementation();
        let i: mut i64 = 0;
        while (i < cast<i64>(def.functions.size())) {
            let func: ast.Definition = def.functions.at(cast<u64>(i)).some;
            if (func is ast.Definition.function_def) {
                let bound: Option<BoundDefinition> = this.bind_function_def(func.function_def, scope);
                if (bound.is_some()) {
                    result.methods.push(bound.some);
                }
            }
            i = i + 1;
        }
        return new Option<BoundDefinition>.some(new BoundDefinition.impl_def(result));
    }

    fun bind_impl_for_def(mut this, def: ast.InterfaceForImplementation, scope: mut BoundScope) -> Option<BoundDefinition> {
        let result: mut BoundInterfaceForImplementation = new BoundInterfaceForImplementation();
        let i: mut i64 = 0;
        while (i < cast<i64>(def.functions.size())) {
            let func: ast.Definition = def.functions.at(cast<u64>(i)).some;
            if (func is ast.Definition.function_def) {
                let bound: Option<BoundDefinition> = this.bind_function_def(func.function_def, scope);
                if (bound.is_some()) {
                    result.methods.push(bound.some);
                }
            }
            i = i + 1;
        }
        return new Option<BoundDefinition>.some(new BoundDefinition.impl_for_def(result));
    }

    fun bind_type_ref_def(mut this, def: ast.TypeReferenceDefinition, scope: mut BoundScope) -> Option<BoundDefinition> {
        let result: mut BoundTypeReferenceDefinition = new BoundTypeReferenceDefinition(def.name);
        let type_sym: mut BoundTypeSymbol = new BoundTypeSymbol(def.name, scope.full_name + "." + def.name);
        result.type_symbol = new Option<BoundTypeSymbol>.some(type_sym);
        scope.add_symbol(new BoundSymbol.type_sym(type_sym));
        return new Option<BoundDefinition>.some(new BoundDefinition.type_ref_def(result));
    }

    fun bind_global_var_def(mut this, def: ast.GlobalVariableDefinition, scope: mut BoundScope) -> Option<BoundDefinition> {
        let full_name: string = scope.full_name + "." + def.name;
        let result: mut BoundGlobalVariableDefinition = new BoundGlobalVariableDefinition();
        result.name = def.name;
        result.full_name = full_name;
        result.is_mutable = def.is_mutable;
        result.scope = new Option<BoundScope>.some(scope);
        result.ast_source = new Option<ast.Definition>.some(new ast.Definition.global_var(def));
        let var_sym: mut BoundVariableSymbol = new BoundVariableSymbol();
        var_sym.name = def.name;
        var_sym.full_name = full_name;
        var_sym.variable_kind = new VariableSymbolKind.Global();
        var_sym.is_mutable = def.is_mutable;
        var_sym.enclosing_scope = new Option<BoundScope>.some(scope);
        result.variable_symbol = new Option<BoundVariableSymbol>.some(var_sym);
        scope.add_symbol(new BoundSymbol.variable(var_sym));
        return new Option<BoundDefinition>.some(new BoundDefinition.global_var_def(result));
    }

    fun report_error(mut this, message: string, line: i64, col: i64) {
        this.errors.push(new SemanticError(message, line, col));
    }

    fun substitute_generic_args(this, bt: mut BoundType, concrete_type: BoundType, generic_def: BoundDefinition) -> mut BoundType {
        if (cast<i64>(concrete_type.generic_args.size()) == 0) { return bt; }
        let bt_name: string = bt.display_name();
        if (generic_def is BoundDefinition.enum_def) {
            let e: BoundEnumDefinition = generic_def.enum_def;
            let pi: mut i64 = 0;
            while (pi < cast<i64>(e.generic_params.size()) && pi < cast<i64>(concrete_type.generic_args.size())) {
                if (bt_name == e.generic_params.at(cast<u64>(pi)).some) {
                    let arg: mut BoundType = concrete_type.generic_args.at(cast<u64>(pi)).some;
                    return arg;
                }
                pi = pi + 1;
            }
        }
        if (generic_def is BoundDefinition.class_def) {
            let c: BoundClassDefinition = generic_def.class_def;
            let pi: mut i64 = 0;
            while (pi < cast<i64>(c.generic_params.size()) && pi < cast<i64>(concrete_type.generic_args.size())) {
                if (bt_name == c.generic_params.at(cast<u64>(pi)).some) {
                    let arg: mut BoundType = concrete_type.generic_args.at(cast<u64>(pi)).some;
                    return arg;
                }
                pi = pi + 1;
            }
        }
        return bt;
    }

    fun pass_bind_symbols(mut this, result: BoundCompilationUnit) {
        let i: mut i64 = 0;
        while (i < cast<i64>(result.definitions.size())) {
            let def: BoundDefinition = result.definitions.at(cast<u64>(i)).some;
            this.bind_symbols_for_def(def);
            i = i + 1;
        }
    }

    fun bind_symbols_for_def(mut this, def: BoundDefinition) {
        if (def is BoundDefinition.function_def) {
            this.bind_function_symbols(def.function_def);
        }
        if (def is BoundDefinition.class_def) {
            this.bind_class_symbols(def.class_def);
        }
        if (def is BoundDefinition.enum_def) {
            let e: BoundEnumDefinition = def.enum_def;
            let i: mut i64 = 0;
            while (i < cast<i64>(e.members.size())) {
                let member: BoundEnumMemberDefinition = e.members.at(cast<u64>(i)).some;
                if (member.member_symbol.is_some()) {
                    let sym: mut BoundEnumMemberSymbol = member.member_symbol.some;
                    sym.bound_type = e.bound_type;
                }
                i = i + 1;
            }
            // Bind symbols for direct enum methods
            i = 0;
            while (i < cast<i64>(e.methods.size())) {
                let md: BoundDefinition = e.methods.at(cast<u64>(i)).some;
                this.bind_symbols_for_def(md);
                i = i + 1;
            }
            i = 0;
            while (i < cast<i64>(e.interface_impls.size())) {
                let impl_def: BoundDefinition = e.interface_impls.at(cast<u64>(i)).some;
                if (impl_def is BoundDefinition.impl_def) {
                    let iface_impl: BoundInterfaceImplementation = impl_def.impl_def;
                    let j: mut i64 = 0;
                    while (j < cast<i64>(iface_impl.methods.size())) {
                        let md: BoundDefinition = iface_impl.methods.at(cast<u64>(j)).some;
                        this.bind_symbols_for_def(md);
                        j = j + 1;
                    }
                }
                i = i + 1;
            }
        }
        if (def is BoundDefinition.interface_def) {
            let iface: BoundInterfaceDefinition = def.interface_def;
            let i: mut i64 = 0;
            while (i < cast<i64>(iface.methods.size())) {
                let md: BoundDefinition = iface.methods.at(cast<u64>(i)).some;
                this.bind_symbols_for_def(md);
                i = i + 1;
            }
        }
        if (def is BoundDefinition.namespace_def) {
            let ns: BoundNamespaceDefinition = def.namespace_def;
            let i: mut i64 = 0;
            while (i < cast<i64>(ns.children.size())) {
                let child: BoundDefinition = ns.children.at(cast<u64>(i)).some;
                this.bind_symbols_for_def(child);
                i = i + 1;
            }
        }
        if (def is BoundDefinition.initial_routine) {
            this.bind_function_symbols_for_init(def.initial_routine);
        }
    }

    fun bind_function_symbols(mut this, func: BoundFunctionDefinition) {
        if (func.scope.is_none()) { return; }
        let func_scope: mut BoundScope = func.scope.some;
        let i: mut i64 = 0;
        while (i < cast<i64>(func.parameters.size())) {
            let param: BoundFunctionParameter = func.parameters.at(cast<u64>(i)).some;
            let param_sym: mut BoundVariableSymbol = new BoundVariableSymbol();
            param_sym.name = param.name;
            param_sym.full_name = func.full_name + "." + param.name;
            param_sym.bound_type = param.bound_type;
            param_sym.variable_kind = new VariableSymbolKind.Parameter();
            param_sym.is_mutable = param.is_mutable;
            param_sym.parameter_index = param.index;
            param_sym.enclosing_scope = new Option<BoundScope>.some(func_scope);
            func_scope.add_symbol(new BoundSymbol.variable(param_sym));
            i = i + 1;
        }
    }

    fun bind_function_symbols_for_init(mut this, init: BoundInitialRoutineDefinition) {
        if (init.scope.is_none()) { return; }
    }

    fun bind_class_symbols(mut this, cls: BoundClassDefinition) {
        if (cls.scope.is_none()) { return; }
        let i: mut i64 = 0;
        while (i < cast<i64>(cls.methods.size())) {
            let md: BoundDefinition = cls.methods.at(cast<u64>(i)).some;
            this.bind_symbols_for_def(md);
            i = i + 1;
        }
        i = 0;
        while (i < cast<i64>(cls.constructors.size())) {
            let cd: BoundDefinition = cls.constructors.at(cast<u64>(i)).some;
            this.bind_symbols_for_def(cd);
            i = i + 1;
        }
        i = 0;
        while (i < cast<i64>(cls.interface_impls.size())) {
            let impl_def: BoundDefinition = cls.interface_impls.at(cast<u64>(i)).some;
            if (impl_def is BoundDefinition.impl_def) {
                let iface_impl: BoundInterfaceImplementation = impl_def.impl_def;
                let j: mut i64 = 0;
                while (j < cast<i64>(iface_impl.methods.size())) {
                    let md: BoundDefinition = iface_impl.methods.at(cast<u64>(j)).some;
                    this.bind_symbols_for_def(md);
                    j = j + 1;
                }
            }
            i = i + 1;
        }
    }

    fun pass_resolve_types(mut this, unit: ast.CompilationUnit, result: BoundCompilationUnit) {
        let i: mut i64 = 0;
        while (i < cast<i64>(result.definitions.size())) {
            let ast_def: ast.Definition = unit.definitions.at(cast<u64>(i)).some;
            let updated: BoundDefinition = this.resolve_pair(ast_def, result.definitions.at(cast<u64>(i)).some, result.global_scope);
            result.definitions.set(cast<u64>(i), updated);
            i = i + 1;
        }
    }

    fun resolve_pair(mut this, ast_def: ast.Definition, bound_def: BoundDefinition, scope: BoundScope) -> BoundDefinition {
        if (bound_def is BoundDefinition.function_def && ast_def is ast.Definition.function_def) {
            let bf: mut BoundFunctionDefinition = bound_def.function_def;
            this.resolve_function_pair(ast_def.function_def, bf, scope);
            return new BoundDefinition.function_def(bf);
        }
        if (bound_def is BoundDefinition.class_def && ast_def is ast.Definition.class_def) {
            let bc: mut BoundClassDefinition = bound_def.class_def;
            this.resolve_class_pair(ast_def.class_def, bc, scope);
            return new BoundDefinition.class_def(bc);
        }
        if (bound_def is BoundDefinition.enum_def && ast_def is ast.Definition.enum_def) {
            let be: mut BoundEnumDefinition = bound_def.enum_def;
            this.resolve_enum_types(be, scope, ast_def.enum_def);
            return new BoundDefinition.enum_def(be);
        }
        if (bound_def is BoundDefinition.interface_def && ast_def is ast.Definition.interface_def) {
            let bi: mut BoundInterfaceDefinition = bound_def.interface_def;
            this.resolve_interface_pair(ast_def.interface_def, bi, scope);
            return new BoundDefinition.interface_def(bi);
        }
        if (bound_def is BoundDefinition.namespace_def && ast_def is ast.Definition.namespace_def) {
            let bn: mut BoundNamespaceDefinition = bound_def.namespace_def;
            this.resolve_namespace_pair(ast_def.namespace_def, bn, scope);
            return new BoundDefinition.namespace_def(bn);
        }
        if (bound_def is BoundDefinition.initial_routine) {
            let init: mut BoundInitialRoutineDefinition = bound_def.initial_routine;
            if (init.scope.is_some() && init.symbol.is_some()) {
                let sym: mut BoundFunctionSymbol = init.symbol.some;
                sym.bound_type = this.type_registry.make_function_type(
                    this.type_registry.void_type, new _utils.List<BoundType>(), false);
                init.symbol = new Option<BoundFunctionSymbol>.some(sym);
            }
            return new BoundDefinition.initial_routine(init);
        }
        if (bound_def is BoundDefinition.global_var_def && ast_def is ast.Definition.global_var) {
            let gv: mut BoundGlobalVariableDefinition = bound_def.global_var_def;
            if (ast_def.global_var.type_spec.is_some()) {
                gv.bound_type = this.resolve_type_specifier(ast_def.global_var.type_spec.some, scope);
                if (gv.variable_symbol.is_some()) {
                    let sym: mut BoundVariableSymbol = gv.variable_symbol.some;
                    sym.bound_type = gv.bound_type;
                    gv.variable_symbol = new Option<BoundVariableSymbol>.some(sym);
                }
            }
            return new BoundDefinition.global_var_def(gv);
        }
        if (bound_def is BoundDefinition.type_ref_def && ast_def is ast.Definition.type_ref_def) {
            let tr: mut BoundTypeReferenceDefinition = bound_def.type_ref_def;
            if (tr.type_symbol.is_some() && ast_def.type_ref_def.type_spec.is_some()) {
                let tsym: mut BoundTypeSymbol = tr.type_symbol.some;
                let alias_t: mut BoundType = new BoundType();
                alias_t.kind = new TypeKind.TypeReferenceKind();
                alias_t.generic_args.push(
                    this.resolve_type_specifier(ast_def.type_ref_def.type_spec.some, scope));
                tsym.bound_type = alias_t;
                tr.type_symbol = new Option<BoundTypeSymbol>.some(tsym);
            }
            return new BoundDefinition.type_ref_def(tr);
        }
        return bound_def;
    }

    fun resolve_function_pair(mut this, ast_func: ast.FunctionDefinition, bound_func: mut BoundFunctionDefinition, scope: BoundScope) {
        let sym: mut BoundFunctionSymbol = bound_func.symbol.some;
        let ret: mut BoundType = this.type_registry.void_type;
        if (ast_func.return_type.is_some()) {
            ret = this.resolve_type_specifier(ast_func.return_type.some, scope);
        }
        sym.return_type = ret;
        bound_func.return_type = ret;
        let func_type_params: mut _utils.List<BoundType> = new _utils.List<BoundType>();
        let pi: mut i64 = 0;
        while (pi < cast<i64>(ast_func.parameters.size())) {
            let p: ast.Parameter = ast_func.parameters.at(cast<u64>(pi)).some;
            let bp: mut BoundFunctionParameter = new BoundFunctionParameter(p.name, pi, p.is_mutable, p.is_this);
            if (p.type_spec.is_some()) {
                bp.bound_type = this.resolve_type_specifier(p.type_spec.some, scope);
            }
            bound_func.parameters.push(bp);
            func_type_params.push(bp.bound_type);
            pi = pi + 1;
        }
        let is_async: bool = ast_func.is_async;
        sym.bound_type = this.type_registry.make_function_type(ret, func_type_params, is_async);
        sym.is_async = is_async;
        bound_func.symbol = new Option<BoundFunctionSymbol>.some(sym);
    }

    fun resolve_class_method_pair(mut this, ast_func: ast.FunctionDefinition, bound_func: mut BoundFunctionDefinition, scope: BoundScope, cls: mut BoundClassDefinition) {
        let sym: mut BoundFunctionSymbol = bound_func.symbol.some;
        let ret: mut BoundType = this.type_registry.void_type;
        if (ast_func.return_type.is_some()) {
            ret = this.resolve_type_specifier(ast_func.return_type.some, scope);
        }
        sym.return_type = ret;
        bound_func.return_type = ret;
        let func_type_params: mut _utils.List<BoundType> = new _utils.List<BoundType>();
        let pi: mut i64 = 0;
        while (pi < cast<i64>(ast_func.parameters.size())) {
            let p: ast.Parameter = ast_func.parameters.at(cast<u64>(pi)).some;
            let bp: mut BoundFunctionParameter = new BoundFunctionParameter(p.name, pi, p.is_mutable, p.is_this);
            if (p.type_spec.is_some()) {
                bp.bound_type = this.resolve_type_specifier(p.type_spec.some, scope);
            } else if (p.is_this) {
                if (bound_func.is_new) {
                    bp.bound_type = cls.bound_type.with_mutability(new Mutability.Mutable());
                } else {
                    bp.bound_type = cls.bound_type;
                }
            }
            bound_func.parameters.push(bp);
            func_type_params.push(bp.bound_type);
            pi = pi + 1;
        }
        let is_async: bool = ast_func.is_async;
        sym.bound_type = this.type_registry.make_function_type(ret, func_type_params, is_async);
        sym.is_async = is_async;
        bound_func.symbol = new Option<BoundFunctionSymbol>.some(sym);
    }

    fun resolve_class_pair(mut this, ast_cls: ast.ClassDefinition, bound_cls: mut BoundClassDefinition, scope: BoundScope) {
        let class_scope: BoundScope = bound_cls.scope.some;
        let i: mut i64 = 0;
        while (i < cast<i64>(ast_cls.members.size())) {
            let ast_member: ast.Definition = ast_cls.members.at(cast<u64>(i)).some;
            if (ast_member is ast.Definition.class_field) {
                let field_idx: mut i64 = 0;
                while (field_idx < cast<i64>(bound_cls.fields.size())) {
                    let bd: BoundDefinition = bound_cls.fields.at(cast<u64>(field_idx)).some;
                    if (bd is BoundDefinition.class_field && bd.class_field.name == ast_member.class_field.name) {
                        let field: mut BoundClassFieldDefinition = bd.class_field;
                        if (ast_member.class_field.type_spec.is_some()) {
                            field.bound_type = this.resolve_type_specifier(ast_member.class_field.type_spec.some, class_scope);
                        }
                        if (field.field_symbol.is_some()) {
                            let fsym: mut BoundVariableSymbol = field.field_symbol.some;
                            fsym.bound_type = field.bound_type;
                            field.field_symbol = new Option<BoundVariableSymbol>.some(fsym);
                        }
                        bound_cls.fields.set(cast<u64>(field_idx), new BoundDefinition.class_field(field));
                    }
                    field_idx = field_idx + 1;
                }
            }
            if (ast_member is ast.Definition.function_def) {
                let j: mut i64 = 0;
                while (j < cast<i64>(bound_cls.methods.size())) {
                    let md: BoundDefinition = bound_cls.methods.at(cast<u64>(j)).some;
                    if (md is BoundDefinition.function_def && md.function_def.name == ast_member.function_def.name) {
                        let mf: mut BoundFunctionDefinition = md.function_def;
                        this.resolve_class_method_pair(ast_member.function_def, mf, class_scope, bound_cls);
                        bound_cls.methods.set(cast<u64>(j), new BoundDefinition.function_def(mf));
                    }
                    j = j + 1;
                }
            }
            if (ast_member is ast.Definition.impl_def) {
                let ast_impl: ast.InterfaceImplementation = ast_member.impl_def;
                let k: mut i64 = 0;
                while (k < cast<i64>(bound_cls.interface_impls.size())) {
                    let bd_impl: BoundDefinition = bound_cls.interface_impls.at(cast<u64>(k)).some;
                    if (bd_impl is BoundDefinition.impl_def) {
                        let bound_iface_impl: mut BoundInterfaceImplementation = bd_impl.impl_def;
                        let fi: mut i64 = 0;
                        while (fi < cast<i64>(ast_impl.functions.size())) {
                            let ast_func_def: ast.Definition = ast_impl.functions.at(cast<u64>(fi)).some;
                            if (ast_func_def is ast.Definition.function_def) {
                                let mi: mut i64 = 0;
                                while (mi < cast<i64>(bound_iface_impl.methods.size())) {
                                    let bound_method: BoundDefinition = bound_iface_impl.methods.at(cast<u64>(mi)).some;
                                    if (bound_method is BoundDefinition.function_def && bound_method.function_def.name == ast_func_def.function_def.name) {
                                        let bm: mut BoundFunctionDefinition = bound_method.function_def;
                                        this.resolve_class_method_pair(ast_func_def.function_def, bm, class_scope, bound_cls);
                                        bound_iface_impl.methods.set(cast<u64>(mi), new BoundDefinition.function_def(bm));
                                    }
                                    mi = mi + 1;
                                }
                            }
                            fi = fi + 1;
                        }
                        bound_cls.interface_impls.set(cast<u64>(k), new BoundDefinition.impl_def(bound_iface_impl));
                    }
                    k = k + 1;
                }
            }
            i = i + 1;
        }
    }

    fun resolve_enum_types(mut this, e: mut BoundEnumDefinition, scope: BoundScope, ast_enum: ast.EnumDefinition) {
        let i: mut i64 = 0;
        while (i < cast<i64>(e.members.size())) {
            let member: mut BoundEnumMemberDefinition = e.members.at(cast<u64>(i)).some;
            let is_void: bool = member.member_type.kind is bound.TypeKind.PrimitiveKind
                && member.member_type.primitive is bound.PrimitiveType.VoidType;
            if (is_void) {
                member.member_type = e.bound_type;
            }
            i = i + 1;
        }
        // Resolve interface implementation method types
        let enum_scope: BoundScope = e.scope.some;
        let ai: mut i64 = 0;
        while (ai < cast<i64>(ast_enum.members.size())) {
            let ast_member: ast.Definition = ast_enum.members.at(cast<u64>(ai)).some;
            if (ast_member is ast.Definition.impl_def) {
                let ast_impl: ast.InterfaceImplementation = ast_member.impl_def;
                let k: mut i64 = 0;
                while (k < cast<i64>(e.interface_impls.size())) {
                    let bd_impl: BoundDefinition = e.interface_impls.at(cast<u64>(k)).some;
                    if (bd_impl is BoundDefinition.impl_def) {
                        let bound_iface_impl: mut BoundInterfaceImplementation = bd_impl.impl_def;
                        let fi: mut i64 = 0;
                        while (fi < cast<i64>(ast_impl.functions.size())) {
                            let ast_func_def: ast.Definition = ast_impl.functions.at(cast<u64>(fi)).some;
                            if (ast_func_def is ast.Definition.function_def) {
                                let mi: mut i64 = 0;
                                while (mi < cast<i64>(bound_iface_impl.methods.size())) {
                                    let bound_method: BoundDefinition = bound_iface_impl.methods.at(cast<u64>(mi)).some;
                                    if (bound_method is BoundDefinition.function_def && bound_method.function_def.name == ast_func_def.function_def.name) {
                                        let bm: mut BoundFunctionDefinition = bound_method.function_def;
                                        this.resolve_enum_method_pair(ast_func_def.function_def, bm, enum_scope, e);
                                        bound_iface_impl.methods.set(cast<u64>(mi), new BoundDefinition.function_def(bm));
                                    }
                                    mi = mi + 1;
                                }
                            }
                            fi = fi + 1;
                        }
                        e.interface_impls.set(cast<u64>(k), new BoundDefinition.impl_def(bound_iface_impl));
                    }
                    k = k + 1;
                }
            }
            ai = ai + 1;
        }
        // Resolve direct enum method types
        let di: mut i64 = 0;
        while (di < cast<i64>(e.methods.size())) {
            let md: BoundDefinition = e.methods.at(cast<u64>(di)).some;
            if (md is BoundDefinition.function_def) {
                let mi: mut i64 = 0;
                while (mi < cast<i64>(ast_enum.members.size())) {
                    let ast_member: ast.Definition = ast_enum.members.at(cast<u64>(mi)).some;
                    if (ast_member is ast.Definition.function_def) {
                        if (ast_member.function_def.name == md.function_def.name) {
                            let bm: mut BoundFunctionDefinition = md.function_def;
                            this.resolve_enum_method_pair(ast_member.function_def, bm, enum_scope, e);
                            e.methods.set(cast<u64>(di), new BoundDefinition.function_def(bm));
                        }
                    }
                    mi = mi + 1;
                }
            }
            di = di + 1;
        }
    }

    fun resolve_enum_method_pair(mut this, ast_func: ast.FunctionDefinition, bound_func: mut BoundFunctionDefinition, scope: BoundScope, e: mut BoundEnumDefinition) {
        let sym: mut BoundFunctionSymbol = bound_func.symbol.some;
        let ret: mut BoundType = this.type_registry.void_type;
        if (ast_func.return_type.is_some()) {
            ret = this.resolve_type_specifier(ast_func.return_type.some, scope);
        }
        sym.return_type = ret;
        bound_func.return_type = ret;
        let func_type_params: mut _utils.List<BoundType> = new _utils.List<BoundType>();
        // Skip parameter resolution if already done (e.g. during specialize_enum_def)
        if (cast<i64>(bound_func.parameters.size()) == 0) {
            let pi: mut i64 = 0;
            while (pi < cast<i64>(ast_func.parameters.size())) {
                let p: ast.Parameter = ast_func.parameters.at(cast<u64>(pi)).some;
                let bp: mut BoundFunctionParameter = new BoundFunctionParameter(p.name, pi, p.is_mutable, p.is_this);
                if (p.type_spec.is_some()) {
                    bp.bound_type = this.resolve_type_specifier(p.type_spec.some, scope);
                } else if (p.is_this) {
                    bp.bound_type = e.bound_type;
                }
                bound_func.parameters.push(bp);
                func_type_params.push(bp.bound_type);
                pi = pi + 1;
            }
        } else {
            let pi: mut i64 = 0;
            while (pi < cast<i64>(bound_func.parameters.size())) {
                func_type_params.push(bound_func.parameters.at(cast<u64>(pi)).some.bound_type);
                pi = pi + 1;
            }
        }
        let is_async: bool = ast_func.is_async;
        sym.bound_type = this.type_registry.make_function_type(ret, func_type_params, is_async);
        sym.is_async = is_async;
        bound_func.symbol = new Option<BoundFunctionSymbol>.some(sym);
    }

    fun resolve_interface_pair(mut this, ast_iface: ast.InterfaceDefinition, bound_iface: mut BoundInterfaceDefinition, scope: BoundScope) {
        let iface_scope: BoundScope = bound_iface.scope.some;
        let i: mut i64 = 0;
        while (i < cast<i64>(ast_iface.members.size())) {
            let ast_member: ast.Definition = ast_iface.members.at(cast<u64>(i)).some;
            if (ast_member is ast.Definition.function_def) {
                let j: mut i64 = 0;
                while (j < cast<i64>(bound_iface.methods.size())) {
                    let md: BoundDefinition = bound_iface.methods.at(cast<u64>(j)).some;
                    if (md is BoundDefinition.function_def && md.function_def.name == ast_member.function_def.name) {
                        let mf: mut BoundFunctionDefinition = md.function_def;
                        this.resolve_interface_method_pair(ast_member.function_def, mf, iface_scope, bound_iface);
                        bound_iface.methods.set(cast<u64>(j), new BoundDefinition.function_def(mf));
                    }
                    j = j + 1;
                }
            }
            i = i + 1;
        }
    }

    fun resolve_interface_method_pair(mut this, ast_func: ast.FunctionDefinition, bound_func: mut BoundFunctionDefinition, scope: BoundScope, iface: mut BoundInterfaceDefinition) {
        let sym: mut BoundFunctionSymbol = bound_func.symbol.some;
        let ret: mut BoundType = this.type_registry.void_type;
        if (ast_func.return_type.is_some()) {
            ret = this.resolve_type_specifier(ast_func.return_type.some, scope);
        }
        sym.return_type = ret;
        bound_func.return_type = ret;
        let func_type_params: mut _utils.List<BoundType> = new _utils.List<BoundType>();
        let pi: mut i64 = 0;
        while (pi < cast<i64>(ast_func.parameters.size())) {
            let p: ast.Parameter = ast_func.parameters.at(cast<u64>(pi)).some;
            let bp: mut BoundFunctionParameter = new BoundFunctionParameter(p.name, pi, p.is_mutable, p.is_this);
            if (p.type_spec.is_some()) {
                bp.bound_type = this.resolve_type_specifier(p.type_spec.some, scope);
            } else if (p.is_this) {
                bp.bound_type = iface.bound_type;
            }
            bound_func.parameters.push(bp);
            func_type_params.push(bp.bound_type);
            pi = pi + 1;
        }
        let is_async: bool = ast_func.is_async;
        sym.bound_type = this.type_registry.make_function_type(ret, func_type_params, is_async);
        sym.is_async = is_async;
        bound_func.symbol = new Option<BoundFunctionSymbol>.some(sym);
    }

    fun resolve_namespace_pair(mut this, ast_ns: ast.NamespaceDefinition, bound_ns: mut BoundNamespaceDefinition, scope: BoundScope) {
        let ns_scope: BoundScope = bound_ns.scope.some;
        let i: mut i64 = 0;
        while (i < cast<i64>(ast_ns.children.size())) {
            let ast_child: ast.Definition = ast_ns.children.at(cast<u64>(i)).some;
            let j: mut i64 = 0;
            while (j < cast<i64>(bound_ns.children.size())) {
                let bound_child: BoundDefinition = bound_ns.children.at(cast<u64>(j)).some;
                if (ast_child is ast.Definition.function_def && bound_child is BoundDefinition.function_def) {
                    if (ast_child.function_def.name == bound_child.function_def.name) {
                        bound_ns.children.set(cast<u64>(j), this.resolve_pair(ast_child, bound_child, ns_scope));
                    }
                }
                if (ast_child is ast.Definition.class_def && bound_child is BoundDefinition.class_def) {
                    if (ast_child.class_def.name == bound_child.class_def.name) {
                        bound_ns.children.set(cast<u64>(j), this.resolve_pair(ast_child, bound_child, ns_scope));
                    }
                }
                if (ast_child is ast.Definition.enum_def && bound_child is BoundDefinition.enum_def) {
                    if (ast_child.enum_def.name == bound_child.enum_def.name) {
                        bound_ns.children.set(cast<u64>(j), this.resolve_pair(ast_child, bound_child, ns_scope));
                    }
                }
                if (ast_child is ast.Definition.interface_def && bound_child is BoundDefinition.interface_def) {
                    if (ast_child.interface_def.name == bound_child.interface_def.name) {
                        bound_ns.children.set(cast<u64>(j), this.resolve_pair(ast_child, bound_child, ns_scope));
                    }
                }
                if (ast_child is ast.Definition.namespace_def && bound_child is BoundDefinition.namespace_def) {
                    if (ast_child.namespace_def.name == bound_child.namespace_def.name) {
                        bound_ns.children.set(cast<u64>(j), this.resolve_pair(ast_child, bound_child, ns_scope));
                    }
                }
                if (ast_child is ast.Definition.global_var && bound_child is BoundDefinition.global_var_def) {
                    if (ast_child.global_var.name == bound_child.global_var_def.name) {
                        bound_ns.children.set(cast<u64>(j), this.resolve_pair(ast_child, bound_child, ns_scope));
                    }
                }
                j = j + 1;
            }
            i = i + 1;
        }
    }

    fun resolve_generic_args(this, type_spec: ast.TypeSpecifier, scope: BoundScope) -> mut _utils.List<BoundType> {
        let args: mut _utils.List<BoundType> = new _utils.List<BoundType>();
        let k: mut i64 = 0;
        while (k < cast<i64>(type_spec.generic_args.size())) {
            args.push(this.resolve_type_specifier(type_spec.generic_args.at(cast<u64>(k)).some, scope));
            k = k + 1;
        }
        return args;
    }

    fun apply_mutability(this, bt: BoundType, is_mutable: bool) -> mut BoundType {
        if (is_mutable) {
            return bt.with_mutability(new Mutability.Mutable());
        }
        return bt;
    }

    fun resolve_type_specifier(this, type_spec: ast.TypeSpecifier, scope: BoundScope) -> mut BoundType {
        if (type_spec.is_function_type || type_spec.is_async_function_type) {
            let param_types: mut _utils.List<BoundType> = new _utils.List<BoundType>();
            let i: mut i64 = 0;
            while (i < cast<i64>(type_spec.function_params.size())) {
                param_types.push(this.resolve_type_specifier(
                    type_spec.function_params.at(cast<u64>(i)).some, scope));
                i = i + 1;
            }
            let ret: mut BoundType = this.type_registry.void_type;
            if (type_spec.return_type.is_some()) {
                ret = this.resolve_type_specifier(type_spec.return_type.some, scope);
            }
            return this.type_registry.make_function_type(ret, param_types, type_spec.is_async_function_type);
        }
        let prim: Option<BoundType> = this.type_registry.resolve_type(type_spec.name);
        if (prim.is_some()) {
            return this.apply_mutability(prim.some, type_spec.is_mutable);
        }
        let qual_result: Option<BoundType> = this.try_resolve_qualified_type(type_spec, scope);
        if (qual_result.is_some()) {
            return this.apply_mutability(qual_result.some, type_spec.is_mutable);
        }
        let type_sym: Option<BoundSymbol> = scope.lookup_type_in_scope(type_spec.name);
        if (type_sym.is_some()) {
            let result: mut BoundType = type_sym.some.type_sym.bound_type;
            if (cast<i64>(type_spec.generic_args.size()) > 0) {
                result = result.with_generic_args(this.resolve_generic_args(type_spec, scope));
            }
            return this.apply_mutability(result, type_spec.is_mutable);
        }
        return this.type_registry.make_error_type();
    }

    fun try_resolve_qualified_type(this, type_spec: ast.TypeSpecifier, scope: BoundScope) -> Option<BoundType> {
        if (cast<i64>(type_spec.qualified_parts.size()) == 0) {
            return new Option<BoundType>.none();
        }
        let full_parts: mut _utils.List<string> = new _utils.List<string>();
        let qi: mut i64 = 0;
        while (qi < cast<i64>(type_spec.qualified_parts.size())) {
            full_parts.push(type_spec.qualified_parts.at(cast<u64>(qi)).some);
            qi = qi + 1;
        }
        full_parts.push(type_spec.name);
        let found: Option<BoundSymbol> = scope.resolve_qualified(full_parts);
        if (found.is_none()) {
            return new Option<BoundType>.none();
        }
        if (found.some is BoundSymbol.type_sym) {
            // OK - continue to resolve
        } else {
            return new Option<BoundType>.none();
        }
        let resolved: mut BoundType = found.some.type_sym.bound_type;
        if (cast<i64>(type_spec.generic_args.size()) > 0) {
            resolved = resolved.with_generic_args(this.resolve_generic_args(type_spec, scope));
        }
        return new Option<BoundType>.some(resolved);
    }

    fun mangle_generic_name(base_name: string, generic_args: _utils.List<BoundType>) -> string {
        let sb: mut StringBuilder = new StringBuilder();
        sb.append(base_name);
        let i: mut i64 = 0;
        while (i < cast<i64>(generic_args.size())) {
            sb.append("__");
            let arg_name: string = generic_args.at(cast<u64>(i)).some.display_name();
            let sanitized: mut StringBuilder = new StringBuilder();
            let j: mut i64 = 0;
            while (j < string_length(arg_name)) {
                let ch: string = string_char_at(arg_name, j);
                if (ch == " " || ch == "<" || ch == ">" || ch == ",") {
                    sanitized.append("_");
                } else {
                    sanitized.append(ch);
                }
                j = j + 1;
            }
            sb.append(sanitized.to_string());
            i = i + 1;
        }
        return sb.to_string();
    }

    fun is_instantiation_already_exists(this, mangled_name: string, scope: BoundScope) -> bool {
        let found: Option<BoundSymbol> = scope.lookup_type_in_scope(mangled_name);
        if (found.is_some()) { return true; }
        return false;
    }

    fun pass_monomorphize(mut this, unit: ast.CompilationUnit, result: mut BoundCompilationUnit) {
        // Iterative monomorphization: specialize, resolve, then re-collect from
        // the newly resolved definitions for transitive instantiations.
        let total_specialized: mut i64 = 0;
        let max_iterations: mut i64 = 10;
        let iteration: mut i64 = 0;
        while (iteration < max_iterations) {
            let instantiations: mut _utils.List<BoundType> = new _utils.List<BoundType>();
            this.collect_generic_instantiations(result.definitions, instantiations);
            this.collect_generic_instantiations_from_ast(unit.definitions, result.global_scope, instantiations);

            let specialized_defs: mut _utils.List<BoundDefinition> = new _utils.List<BoundDefinition>();
            let specialized_asts: mut _utils.List<ast.Definition> = new _utils.List<ast.Definition>();
            let i: mut i64 = 0;
            while (i < cast<i64>(instantiations.size())) {
                let inst: BoundType = instantiations.at(cast<u64>(i)).some;
                if (inst.type_definition.is_some()) {
                    let template_def: BoundDefinition = inst.type_definition.some;
                    if (template_def is BoundDefinition.class_def) {
                        let cls: BoundClassDefinition = template_def.class_def;
                        if (cast<i64>(cls.generic_params.size()) > 0) {
                            let mangled: string = this.mangle_generic_name(cls.name, inst.generic_args);
                            if (!this.is_instantiation_already_exists(mangled, result.global_scope)) {
                                let ast_def: Option<ast.Definition> = this.find_ast_def_by_name(unit.definitions, cls.name);
                                if (ast_def.is_some()) {
                                    let spec_result: Option<BoundDefinition> = this.specialize_class_def(
                                        cls, inst.generic_args, mangled, result.global_scope);
                                    if (spec_result.is_some()) {
                                        specialized_defs.push(spec_result.some);
                                        specialized_asts.push(ast_def.some);
                                    }
                                }
                            }
                        }
                    }
                    if (template_def is BoundDefinition.enum_def) {
                        let e: BoundEnumDefinition = template_def.enum_def;
                        if (cast<i64>(e.generic_params.size()) > 0) {
                            let mangled: string = this.mangle_generic_name(e.name, inst.generic_args);
                            if (!this.is_instantiation_already_exists(mangled, result.global_scope)) {
                                let ast_def: Option<ast.Definition> = this.find_ast_def_by_name(unit.definitions, e.name);
                                if (ast_def.is_some()) {
                                    let spec_result: Option<BoundDefinition> = this.specialize_enum_def(
                                        e, inst.generic_args, mangled, result.global_scope);
                                    if (spec_result.is_some()) {
                                        specialized_defs.push(spec_result.some);
                                        specialized_asts.push(ast_def.some);
                                    }
                                }
                            }
                        }
                    }
                }
                i = i + 1;
            }

            // Collect function instantiations from AST
            let func_instantiations: mut _utils.List<FunctionInstantiation> = new _utils.List<FunctionInstantiation>();
            this.collect_function_instantiations_from_ast(unit.definitions, result.global_scope, func_instantiations);

            let fi: mut i64 = 0;
            while (fi < cast<i64>(func_instantiations.size())) {
                let inst: FunctionInstantiation = func_instantiations.at(cast<u64>(fi)).some;
                let mangled: string = this.mangle_generic_name(inst.func_name, inst.generic_args);
                let already_exists: mut bool = false;
                let check_i: mut i64 = 0;
                while (check_i < cast<i64>(specialized_defs.size())) {
                    let sd: BoundDefinition = specialized_defs.at(cast<u64>(check_i)).some;
                    if (sd is BoundDefinition.function_def) {
                        if (sd.function_def.name == mangled) {
                            already_exists = true;
                        }
                    }
                    check_i = check_i + 1;
                }
                // Also check result.definitions for specializations from previous iterations
                if (!already_exists) {
                    let check_j: mut i64 = 0;
                    while (check_j < cast<i64>(result.definitions.size())) {
                        let sd: BoundDefinition = result.definitions.at(cast<u64>(check_j)).some;
                        if (sd is BoundDefinition.function_def) {
                            if (sd.function_def.name == mangled) {
                                already_exists = true;
                            }
                        }
                        check_j = check_j + 1;
                    }
                }
                if (!already_exists) {
                    let tmpl_def: Option<BoundDefinition> = this.find_bound_function_def(result.definitions, inst.func_name);
                    if (tmpl_def.is_some() && tmpl_def.some is BoundDefinition.function_def) {
                        let tmpl_func: BoundFunctionDefinition = tmpl_def.some.function_def;
                        if (cast<i64>(tmpl_func.generic_params.size()) > 0) {
                            let ast_def: Option<ast.Definition> = this.find_ast_def_by_name(unit.definitions, inst.func_name);
                            if (ast_def.is_some()) {
                                // Find the specialized class scope if this is a method in a specialized generic class
                                let method_class_scope: Option<BoundScope> = this.find_method_class_scope(result.definitions, specialized_defs, inst.func_name);
                                let spec_result: Option<BoundDefinition> = this.specialize_function_def(
                                    tmpl_func, inst.generic_args, mangled, result.global_scope, method_class_scope);
                                if (spec_result.is_some()) {
                                    specialized_defs.push(spec_result.some);
                                    specialized_asts.push(ast_def.some);
                                }
                            }
                        }
                    }
                }
                fi = fi + 1;
            }

            if (cast<i64>(specialized_defs.size()) == 0) {
                // No new specializations found, we're done
                return;
            }

            // Resolve types BEFORE pushing so mut reference updates persist
            let k: mut i64 = 0;
            while (k < cast<i64>(specialized_defs.size())) {
                let spec_def: BoundDefinition = specialized_defs.at(cast<u64>(k)).some;
                let ast_def: ast.Definition = specialized_asts.at(cast<u64>(k)).some;
                if (spec_def is BoundDefinition.function_def) {
                    if (spec_def.function_def.scope.is_some()) {
                        this.resolve_pair(ast_def, spec_def, spec_def.function_def.scope.some);
                    } else {
                        this.resolve_pair(ast_def, spec_def, result.global_scope);
                    }
                    // Fix up 'this' parameter type for class method specializations
                    let parent_cls: Option<BoundClassDefinition> = this.find_parent_class_for_method(result.definitions, specialized_defs, spec_def.function_def.full_name);
                    if (parent_cls.is_some()) {
                        this.fix_this_param_type(spec_def.function_def, parent_cls.some);
                    }
                } else {
                    this.resolve_pair(ast_def, spec_def, result.global_scope);
                }
                k = k + 1;
            }

            let j: mut i64 = 0;
            while (j < cast<i64>(specialized_defs.size())) {
                result.definitions.push(specialized_defs.at(cast<u64>(j)).some);
                j = j + 1;
            }
            total_specialized = total_specialized + cast<i64>(specialized_defs.size());
            iteration = iteration + 1;
        }
    }

    fun find_ast_def_by_name(this, defs: _utils.List<ast.Definition>, name: string) -> Option<ast.Definition> {
        let i: mut i64 = 0;
        while (i < cast<i64>(defs.size())) {
            let def: ast.Definition = defs.at(cast<u64>(i)).some;
            if (def is ast.Definition.function_def) {
                if (def.function_def.name == name) {
                    return new Option<ast.Definition>.some(def);
                }
            }
            if (def is ast.Definition.class_def) {
                if (def.class_def.name == name) {
                    return new Option<ast.Definition>.some(def);
                }
                // Also search class methods for generic method instantiation
                let members: _utils.List<ast.Definition> = def.class_def.members;
                let mi: mut i64 = 0;
                while (mi < cast<i64>(members.size())) {
                    let member: ast.Definition = members.at(cast<u64>(mi)).some;
                    if (member is ast.Definition.function_def) {
                        if (member.function_def.name == name) {
                            return new Option<ast.Definition>.some(member);
                        }
                    }
                    mi = mi + 1;
                }
            }
            if (def is ast.Definition.enum_def) {
                if (def.enum_def.name == name) {
                    return new Option<ast.Definition>.some(def);
                }
            }
            if (def is ast.Definition.namespace_def) {
                let found: Option<ast.Definition> = this.find_ast_def_by_name(def.namespace_def.children, name);
                if (found.is_some()) { return found; }
            }
            i = i + 1;
        }
        return new Option<ast.Definition>.none();
    }

    fun find_ast_def_by_name_from_scope(this, name: string, scope: BoundScope) -> Option<ast.Definition> {
        return this.find_ast_def_by_name(this.ast_definitions, name);
    }

    fun mangle_generic_name_for_ir(base_name: string, generic_args: _utils.List<BoundType>) -> string {
        return mangle_generic_name(base_name, generic_args);
    }

    fun replace_name_in_full_name(this, full_name: string, old_name: string, new_name: string) -> string {
        let dot_pos: i64 = string_find(full_name, "." + old_name);
        if (dot_pos >= 0) {
            let before: string = string_substring(full_name, 0, dot_pos);
            return before + "." + new_name;
        }
        return new_name;
    }

    fun collect_generic_instantiations(this, defs: _utils.List<BoundDefinition>, instantiations: mut _utils.List<BoundType>) {
        let i: mut i64 = 0;
        while (i < cast<i64>(defs.size())) {
            let def: BoundDefinition = defs.at(cast<u64>(i)).some;
            this.collect_instantiations_from_def(def, instantiations);
            i = i + 1;
        }
    }

    fun collect_instantiations_from_def(this, def: BoundDefinition, instantiations: mut _utils.List<BoundType>) {
        if (def is BoundDefinition.class_def) {
            let cls: BoundClassDefinition = def.class_def;
            // Skip template classes - their type params produce error types
            if (cls.is_generic_template) { return; }
            let fi: mut i64 = 0;
            while (fi < cast<i64>(cls.fields.size())) {
                let fd: BoundDefinition = cls.fields.at(cast<u64>(fi)).some;
                if (fd is BoundDefinition.class_field) {
                    this.try_add_instantiation(fd.class_field.bound_type, instantiations);
                }
                fi = fi + 1;
            }
            let mi: mut i64 = 0;
            while (mi < cast<i64>(cls.methods.size())) {
                let md: BoundDefinition = cls.methods.at(cast<u64>(mi)).some;
                if (md is BoundDefinition.function_def) {
                    this.try_add_instantiation(md.function_def.return_type, instantiations);
                    let pi: mut i64 = 0;
                    while (pi < cast<i64>(md.function_def.parameters.size())) {
                        this.try_add_instantiation(md.function_def.parameters.at(cast<u64>(pi)).some.bound_type, instantiations);
                        pi = pi + 1;
                    }
                }
                mi = mi + 1;
            }
        }
        if (def is BoundDefinition.function_def) {
            let func: BoundFunctionDefinition = def.function_def;
            this.try_add_instantiation(func.return_type, instantiations);
            let pi: mut i64 = 0;
            while (pi < cast<i64>(func.parameters.size())) {
                this.try_add_instantiation(func.parameters.at(cast<u64>(pi)).some.bound_type, instantiations);
                pi = pi + 1;
            }
        }
        if (def is BoundDefinition.initial_routine) {
            let init: BoundInitialRoutineDefinition = def.initial_routine;
            if (init.scope.is_some()) {
                this.collect_instantiations_from_scope(init.scope.some, instantiations);
            }
        }
        if (def is BoundDefinition.namespace_def) {
            let ns: BoundNamespaceDefinition = def.namespace_def;
            let ci: mut i64 = 0;
            while (ci < cast<i64>(ns.children.size())) {
                this.collect_instantiations_from_def(ns.children.at(cast<u64>(ci)).some, instantiations);
                ci = ci + 1;
            }
        }
    }

    fun collect_instantiations_from_scope(this, scope: BoundScope, instantiations: mut _utils.List<BoundType>) {
        let si: mut i64 = 0;
        while (si < cast<i64>(scope.symbols.size())) {
            let sym: BoundSymbol = scope.symbols.at(cast<u64>(si)).some;
            if (sym is BoundSymbol.variable) {
                this.try_add_instantiation(sym.variable.bound_type, instantiations);
            }
            si = si + 1;
        }
        let ci: mut i64 = 0;
        while (ci < cast<i64>(scope.children.size())) {
            this.collect_instantiations_from_scope(scope.children.at(cast<u64>(ci)).some, instantiations);
            ci = ci + 1;
        }
    }

    fun try_add_instantiation(this, bt: BoundType, instantiations: mut _utils.List<BoundType>) {
        if (cast<i64>(bt.generic_args.size()) > 0 && bt.type_definition.is_some()) {
            let already: mut bool = false;
            let j: mut i64 = 0;
            while (j < cast<i64>(instantiations.size())) {
                if (bt.is_same_type(instantiations.at(cast<u64>(j)).some)) {
                    already = true;
                }
                j = j + 1;
            }
            if (!already) {
                instantiations.push(bt);
            }
        }
        let i: mut i64 = 0;
        while (i < cast<i64>(bt.generic_args.size())) {
            this.try_add_instantiation(bt.generic_args.at(cast<u64>(i)).some, instantiations);
            i = i + 1;
        }
    }

    fun collect_generic_instantiations_from_ast(this, defs: _utils.List<ast.Definition>, scope: BoundScope, instantiations: mut _utils.List<BoundType>) {
        let i: mut i64 = 0;
        while (i < cast<i64>(defs.size())) {
            let def: ast.Definition = defs.at(cast<u64>(i)).some;
            if (def is ast.Definition.initial_routine) {
                if (def.initial_routine.body.is_some()) {
                    this.collect_from_ast_expr_safe(def.initial_routine.body.some, scope, instantiations);
                }
            }
            if (def is ast.Definition.class_def) {
                // Skip template class bodies - their type params aren't resolvable here
                if (def.class_def.template_decl.is_none()) {
                    let members: _utils.List<ast.Definition> = def.class_def.members;
                    let mi: mut i64 = 0;
                    while (mi < cast<i64>(members.size())) {
                        let member: ast.Definition = members.at(cast<u64>(mi)).some;
                        if (member is ast.Definition.function_def) {
                            if (member.function_def.body.is_some()) {
                                this.collect_from_ast_expr_safe(member.function_def.body.some, scope, instantiations);
                            }
                        }
                        mi = mi + 1;
                    }
                }
            }
            if (def is ast.Definition.namespace_def) {
                this.collect_generic_instantiations_from_ast(def.namespace_def.children, scope, instantiations);
            }
            i = i + 1;
        }
    }

    fun collect_from_ast_expr_safe(this, expr: ast.Expression, scope: BoundScope, instantiations: mut _utils.List<BoundType>) {
        if (expr is ast.Expression.new_expr) {
            let ne: ast.NewExpression = expr.new_expr;
            if (cast<i64>(ne.generic_args.size()) > 0) {
                let resolved: Option<BoundType> = this.resolve_new_generic_args_from_ast(ne.type_name, ne.generic_args, scope);
                if (resolved.is_some()) {
                    this.try_add_instantiation(resolved.some, instantiations);
                }
            }
        }
        // Recurse into sub-expressions safely
        if (expr is ast.Expression.function_call) {
            let fc: ast.FunctionCallExpression = expr.function_call;
            if (fc.callee.is_some()) {
                this.collect_from_ast_expr_safe(fc.callee.some, scope, instantiations);
            }
            let ai: mut i64 = 0;
            while (ai < cast<i64>(fc.arguments.size())) {
                this.collect_from_ast_expr_safe(fc.arguments.at(cast<u64>(ai)).some, scope, instantiations);
                ai = ai + 1;
            }
        }
        if (expr is ast.Expression.code_block) {
            let blk: ast.CodeBlockExpression = expr.code_block;
            let si: mut i64 = 0;
            while (si < cast<i64>(blk.statements.size())) {
                let stmt: ast.Statement = blk.statements.at(cast<u64>(si)).some;
                if (stmt is ast.Statement.let_decl) {
                    if (stmt.let_decl.initializer.is_some()) {
                        this.collect_from_ast_expr_safe(stmt.let_decl.initializer.some, scope, instantiations);
                    }
                }
                if (stmt is ast.Statement.expression) {
                    if (stmt.expression.expression.is_some()) {
                        this.collect_from_ast_expr_safe(stmt.expression.expression.some, scope, instantiations);
                    }
                }
                si = si + 1;
            }
        }
        if (expr is ast.Expression.cast_expr) {
            let ce: ast.CastExpression = expr.cast_expr;
            if (ce.inner.is_some()) {
                this.collect_from_ast_expr_safe(ce.inner.some, scope, instantiations);
            }
        }
        if (expr is ast.Expression.member_access) {
            let ma: ast.MemberAccessExpression = expr.member_access;
            if (ma.base_expr.is_some()) {
                this.collect_from_ast_expr_safe(ma.base_expr.some, scope, instantiations);
            }
        }
    }

    fun resolve_new_generic_args_from_ast(this, type_name: string, generic_args: _utils.List<ast.TypeSpecifier>, scope: BoundScope) -> Option<BoundType> {
        let found: Option<BoundSymbol> = scope.lookup_type_in_scope(type_name);
        if (found.is_none()) { return new Option<BoundType>.none(); }
        if (!(found.some is BoundSymbol.type_sym)) { return new Option<BoundType>.none(); }
        let base_type: BoundType = found.some.type_sym.bound_type;
        if (base_type.type_definition.is_none()) { return new Option<BoundType>.none(); }

        let args: mut _utils.List<BoundType> = new _utils.List<BoundType>();
        let k: mut i64 = 0;
        while (k < cast<i64>(generic_args.size())) {
            let resolved_arg: BoundType = this.resolve_type_specifier(generic_args.at(cast<u64>(k)).some, scope);
            args.push(resolved_arg);
            k = k + 1;
        }
        return new Option<BoundType>.some(base_type.with_generic_args(args));
    }

    fun specialize_class_def(mut this, tmpl: BoundClassDefinition, type_args: _utils.List<BoundType>, mangled_name: string, global_scope: mut BoundScope) -> Option<BoundDefinition> {
        let ast_def: Option<ast.Definition> = this.find_ast_def_by_name_from_scope(tmpl.name, global_scope);
        if (ast_def.is_none()) { return new Option<BoundDefinition>.none(); }
        if (!(ast_def.some is ast.Definition.class_def)) { return new Option<BoundDefinition>.none(); }

        let ast_class: ast.ClassDefinition = ast_def.some.class_def;
        // Use the original template's scope parent (namespace scope) so that
        // type resolution within the specialized class can find sibling types
        let scope_parent: mut Option<BoundScope> = new Option<BoundScope>.some(global_scope);
        if (tmpl.scope.is_some()) {
            scope_parent = tmpl.scope.some.parent;
        }
        let parent_full_name: mut string = global_scope.full_name;
        if (scope_parent.is_some()) {
            parent_full_name = scope_parent.some.full_name;
        }
        let full_name: string = parent_full_name + "." + mangled_name;
        let result: mut BoundClassDefinition = new BoundClassDefinition(mangled_name, full_name);
        let class_scope: mut BoundScope = new BoundScope(new ScopeKind.ClassScope(), mangled_name, full_name, scope_parent);

        let pi: mut i64 = 0;
        while (pi < cast<i64>(tmpl.generic_params.size()) && pi < cast<i64>(type_args.size())) {
            let param_name: string = tmpl.generic_params.at(cast<u64>(pi)).some;
            let arg_type: BoundType = type_args.at(cast<u64>(pi)).some;
            let param_sym: mut BoundTypeSymbol = new BoundTypeSymbol(param_name, full_name + "." + param_name);
            param_sym.bound_type = arg_type.with_mutability(arg_type.mutability);
            class_scope.add_symbol(new BoundSymbol.type_sym(param_sym));
            pi = pi + 1;
        }

        result.scope = new Option<BoundScope>.some(class_scope);
        let type_sym: mut BoundTypeSymbol = new BoundTypeSymbol(mangled_name, full_name);
        let t: mut BoundType = new BoundType();
        t.kind = new TypeKind.ClassKind();
        t.type_definition = new Option<BoundDefinition>.some(new BoundDefinition.class_def(result));
        type_sym.bound_type = t;
        result.type_symbol = new Option<BoundTypeSymbol>.some(type_sym);
        result.bound_type = t;
        global_scope.add_symbol(new BoundSymbol.type_sym(type_sym));

        let i: mut i64 = 0;
        while (i < cast<i64>(ast_class.members.size())) {
            let member: ast.Definition = ast_class.members.at(cast<u64>(i)).some;
            if (member is ast.Definition.class_field) {
                let ast_field: ast.ClassFieldDefinition = member.class_field;
                let field: mut BoundClassFieldDefinition = new BoundClassFieldDefinition(ast_field.name);
                let field_full_name: string = full_name + "." + ast_field.name;
                let fsym: mut BoundVariableSymbol = new BoundVariableSymbol();
                fsym.name = ast_field.name;
                fsym.full_name = field_full_name;
                fsym.variable_kind = new VariableSymbolKind.Field();
                fsym.is_mutable = true;
                fsym.enclosing_scope = new Option<BoundScope>.some(class_scope);
                if (ast_field.type_spec.is_some()) {
                    field.bound_type = this.resolve_type_specifier(ast_field.type_spec.some, class_scope);
                }
                fsym.bound_type = field.bound_type;
                field.field_symbol = new Option<BoundVariableSymbol>.some(fsym);
                class_scope.add_symbol(new BoundSymbol.variable(fsym));
                result.fields.push(new BoundDefinition.class_field(field));
            }
            if (member is ast.Definition.function_def) {
                let bound_member: Option<BoundDefinition> = this.bind_function_def(member.function_def, class_scope);
                if (bound_member.is_some()) {
                    if (bound_member.some is BoundDefinition.function_def) {
                        result.methods.push(new BoundDefinition.function_def(bound_member.some.function_def));
                    } else {
                        result.methods.push(bound_member.some);
                    }
                }
            }
            if (member is ast.Definition.impl_def) {
                let bound_impl: Option<BoundDefinition> = this.bind_impl_def(member.impl_def, class_scope);
                if (bound_impl.is_some()) {
                    result.interface_impls.push(bound_impl.some);
                }
            }
            i = i + 1;
        }

        return new Option<BoundDefinition>.some(new BoundDefinition.class_def(result));
    }

    fun specialize_enum_def(mut this, tmpl: BoundEnumDefinition, type_args: _utils.List<BoundType>, mangled_name: string, global_scope: mut BoundScope) -> Option<BoundDefinition> {
        let ast_def: Option<ast.Definition> = this.find_ast_def_by_name_from_scope(tmpl.name, global_scope);
        if (ast_def.is_none()) { return new Option<BoundDefinition>.none(); }
        if (!(ast_def.some is ast.Definition.enum_def)) { return new Option<BoundDefinition>.none(); }

        let ast_enum: ast.EnumDefinition = ast_def.some.enum_def;
        let scope_parent: mut Option<BoundScope> = new Option<BoundScope>.some(global_scope);
        if (tmpl.scope.is_some()) {
            scope_parent = tmpl.scope.some.parent;
        }
        let parent_full_name: mut string = global_scope.full_name;
        if (scope_parent.is_some()) {
            parent_full_name = scope_parent.some.full_name;
        }
        let full_name: string = parent_full_name + "." + mangled_name;
        let result: mut BoundEnumDefinition = new BoundEnumDefinition(mangled_name, full_name);
        let enum_scope: mut BoundScope = new BoundScope(new ScopeKind.EnumScope(), mangled_name, full_name, scope_parent);

        let pi: mut i64 = 0;
        while (pi < cast<i64>(tmpl.generic_params.size()) && pi < cast<i64>(type_args.size())) {
            let param_name: string = tmpl.generic_params.at(cast<u64>(pi)).some;
            let arg_type: BoundType = type_args.at(cast<u64>(pi)).some;
            let param_sym: mut BoundTypeSymbol = new BoundTypeSymbol(param_name, full_name + "." + param_name);
            param_sym.bound_type = arg_type.with_mutability(arg_type.mutability);
            enum_scope.add_symbol(new BoundSymbol.type_sym(param_sym));
            pi = pi + 1;
        }

        result.scope = new Option<BoundScope>.some(enum_scope);
        let type_sym: mut BoundTypeSymbol = new BoundTypeSymbol(mangled_name, full_name);
        let t: mut BoundType = new BoundType();
        t.kind = new TypeKind.EnumKind();
        t.type_definition = new Option<BoundDefinition>.some(new BoundDefinition.enum_def(result));
        type_sym.bound_type = t;
        result.type_symbol = new Option<BoundTypeSymbol>.some(type_sym);
        result.bound_type = t;
        global_scope.add_symbol(new BoundSymbol.type_sym(type_sym));

        let member_idx: mut i64 = 0;
        let i: mut i64 = 0;
        while (i < cast<i64>(ast_enum.members.size())) {
            let member: ast.Definition = ast_enum.members.at(cast<u64>(i)).some;
            if (member is ast.Definition.enum_member) {
                let payload_type: mut BoundType = this.type_registry.void_type;
                if (member.enum_member.type_spec.is_some()) {
                    payload_type = this.resolve_type_specifier(member.enum_member.type_spec.some, enum_scope);
                }
                let m: mut BoundEnumMemberDefinition = new BoundEnumMemberDefinition(member.enum_member.name, member_idx, payload_type);
                let msym: mut BoundEnumMemberSymbol = new BoundEnumMemberSymbol(member.enum_member.name, full_name + "." + member.enum_member.name, t, member_idx, payload_type);
                m.member_symbol = new Option<BoundEnumMemberSymbol>.some(msym);
                enum_scope.add_symbol(new BoundSymbol.enum_member(msym));
                result.members.push(m);
                member_idx = member_idx + 1;
            }
            if (member is ast.Definition.impl_def) {
                let bound_impl: Option<BoundDefinition> = this.bind_impl_def(member.impl_def, enum_scope);
                if (bound_impl.is_some()) {
                    result.interface_impls.push(bound_impl.some);
                }
            }
            if (member is ast.Definition.function_def) {
                let bound_method: Option<BoundDefinition> = this.bind_function_def(member.function_def, enum_scope);
                if (bound_method.is_some()) {
                    let bm: mut BoundDefinition = bound_method.some;
                    if (bm is BoundDefinition.function_def) {
                        this.resolve_enum_method_pair(member.function_def, bm.function_def, enum_scope, result);
                        bm = new BoundDefinition.function_def(bm.function_def);
                    }
                    result.methods.push(bm);
                }
            }
            i = i + 1;
        }

        return new Option<BoundDefinition>.some(new BoundDefinition.enum_def(result));
    }

    fun pass_constructors(mut this, result: BoundCompilationUnit) {
        let i: mut i64 = 0;
        while (i < cast<i64>(result.definitions.size())) {
            let updated: BoundDefinition = this.init_constructors_for_def(result.definitions.at(cast<u64>(i)).some, result.global_scope);
            result.definitions.set(cast<u64>(i), updated);
            i = i + 1;
        }
        let j: mut i64 = 0;
        while (j < cast<i64>(result.definitions.size())) {
            let updated: BoundDefinition = this.process_constructors_for_def(result.definitions.at(cast<u64>(j)).some);
            result.definitions.set(cast<u64>(j), updated);
            j = j + 1;
        }
    }

    fun init_constructors_for_def(mut this, def: BoundDefinition, global_scope: mut BoundScope) -> BoundDefinition {
        if (def is BoundDefinition.class_def) {
            let cls: mut BoundClassDefinition = def.class_def;
            this.init_class_constructor(cls, global_scope);
            return new BoundDefinition.class_def(cls);
        }
        if (def is BoundDefinition.interface_def) {
            let iface: mut BoundInterfaceDefinition = def.interface_def;
            this.init_interface_constructor(iface, global_scope);
            return new BoundDefinition.interface_def(iface);
        }
        if (def is BoundDefinition.namespace_def) {
            let ns: mut BoundNamespaceDefinition = def.namespace_def;
            let k: mut i64 = 0;
            while (k < cast<i64>(ns.children.size())) {
                let updated: BoundDefinition = this.init_constructors_for_def(ns.children.at(cast<u64>(k)).some, global_scope);
                ns.children.set(cast<u64>(k), updated);
                k = k + 1;
            }
            return new BoundDefinition.namespace_def(ns);
        }
        return def;
    }

    fun process_constructors_for_def(mut this, def: BoundDefinition) -> BoundDefinition {
        if (def is BoundDefinition.namespace_def) {
            let ns: mut BoundNamespaceDefinition = def.namespace_def;
            let k: mut i64 = 0;
            while (k < cast<i64>(ns.children.size())) {
                let updated: BoundDefinition = this.process_constructors_for_def(ns.children.at(cast<u64>(k)).some);
                ns.children.set(cast<u64>(k), updated);
                k = k + 1;
            }
            return new BoundDefinition.namespace_def(ns);
        }
        return def;
    }

    fun init_class_constructor(mut this, cls: mut BoundClassDefinition, global_scope: mut BoundScope) {
        let found_idx: mut i64 = -1;
        let i: mut i64 = 0;
        while (i < cast<i64>(cls.methods.size())) {
            let md: BoundDefinition = cls.methods.at(cast<u64>(i)).some;
            if (md is BoundDefinition.function_def) {
                if (md.function_def.is_new) {
                    found_idx = i;
                }
            }
            i = i + 1;
        }
        if (found_idx >= 0) {
            let ctor_def: BoundDefinition = cls.methods.at(cast<u64>(found_idx)).some;
            let ctor: mut BoundFunctionDefinition = ctor_def.function_def;
            cls.constructor = new Option<BoundFunctionDefinition>.some(ctor);
            cls.constructors.push(ctor_def);
        } else {
            let ctor_full_name: string = cls.full_name + ".new";
            let ctor: mut BoundFunctionDefinition = new BoundFunctionDefinition("new", ctor_full_name, false, false, true, false);
            let this_param: mut BoundFunctionParameter = new BoundFunctionParameter("this", 0, true, true);
            this_param.bound_type = cls.bound_type.with_mutability(new Mutability.Mutable());
            ctor.parameters.push(this_param);
            ctor.return_type = this.type_registry.void_type;
            let ctor_scope: mut BoundScope = new BoundScope(new ScopeKind.FunctionScope(), "new", ctor_full_name + ".<body>", cls.scope);
            ctor.scope = new Option<BoundScope>.some(ctor_scope);
            let sym: mut BoundFunctionSymbol = new BoundFunctionSymbol("new", ctor_full_name);
            sym.is_new = true;
            let param_types: mut _utils.List<BoundType> = new _utils.List<BoundType>();
            param_types.push(this_param.bound_type);
            sym.bound_type = this.type_registry.make_function_type(this.type_registry.void_type, param_types, false);
            sym.return_type = this.type_registry.void_type;
            ctor.symbol = new Option<BoundFunctionSymbol>.some(sym);
            if (cls.scope.is_some()) {
                let class_scope: mut BoundScope = cls.scope.some;
                class_scope.add_symbol(new BoundSymbol.function_sym(sym));
            }
            cls.constructor = new Option<BoundFunctionDefinition>.some(ctor);
            cls.constructors.push(new BoundDefinition.function_def(ctor));
        }
    }

    fun init_interface_constructor(mut this, iface: mut BoundInterfaceDefinition, global_scope: mut BoundScope) {
        let found_idx: mut i64 = -1;
        let i: mut i64 = 0;
        while (i < cast<i64>(iface.methods.size())) {
            let md: BoundDefinition = iface.methods.at(cast<u64>(i)).some;
            if (md is BoundDefinition.function_def) {
                if (md.function_def.is_new) {
                    found_idx = i;
                }
            }
            i = i + 1;
        }
        if (found_idx >= 0) {
            let ctor_def: BoundDefinition = iface.methods.at(cast<u64>(found_idx)).some;
            let ctor: BoundFunctionDefinition = ctor_def.function_def;
        } else {
            let ctor_full_name: string = iface.full_name + ".new";
            let ctor: mut BoundFunctionDefinition = new BoundFunctionDefinition("new", ctor_full_name, false, false, true, false);
            let this_param: mut BoundFunctionParameter = new BoundFunctionParameter("this", 0, true, true);
            this_param.bound_type = iface.bound_type.with_mutability(new Mutability.Mutable());
            ctor.parameters.push(this_param);
            ctor.return_type = this.type_registry.void_type;
            let sym: mut BoundFunctionSymbol = new BoundFunctionSymbol("new", ctor_full_name);
            sym.is_new = true;
            let param_types: mut _utils.List<BoundType> = new _utils.List<BoundType>();
            param_types.push(this_param.bound_type);
            sym.bound_type = this.type_registry.make_function_type(this.type_registry.void_type, param_types, false);
            sym.return_type = this.type_registry.void_type;
            ctor.symbol = new Option<BoundFunctionSymbol>.some(sym);
            if (iface.scope.is_some()) {
                let iface_scope: mut BoundScope = iface.scope.some;
                iface_scope.add_symbol(new BoundSymbol.function_sym(sym));
            }
        }
    }

    fun pass_interface_implementation(mut this, unit: ast.CompilationUnit, result: BoundCompilationUnit) {
        let ast_count: i64 = cast<i64>(unit.definitions.size());
        let i: mut i64 = 0;
        while (i < cast<i64>(result.definitions.size())) {
            if (i < ast_count) {
                let ast_def: ast.Definition = unit.definitions.at(cast<u64>(i)).some;
                let bound_def: BoundDefinition = result.definitions.at(cast<u64>(i)).some;
                result.definitions.set(cast<u64>(i), this.build_vtables_for_def(ast_def, bound_def, result.global_scope));
            } else {
                let bound_def: BoundDefinition = result.definitions.at(cast<u64>(i)).some;
                result.definitions.set(cast<u64>(i), this.build_vtables_for_specialized_def(bound_def, result.global_scope));
            }
            i = i + 1;
        }
    }

    fun build_vtables_for_specialized_def(mut this, bound_def: BoundDefinition, global_scope: mut BoundScope) -> BoundDefinition {
        if (bound_def is BoundDefinition.class_def) {
            let cls: mut BoundClassDefinition = bound_def.class_def;
            let ast_def: Option<ast.Definition> = this.find_ast_def_by_name(this.ast_definitions, this.extract_template_name(cls.name));
            if (ast_def.is_some() && ast_def.some is ast.Definition.class_def) {
                this.build_class_vtables(ast_def.some.class_def, cls, global_scope);
            }
            return new BoundDefinition.class_def(cls);
        }
        if (bound_def is BoundDefinition.enum_def) {
            let e: mut BoundEnumDefinition = bound_def.enum_def;
            let ast_def: Option<ast.Definition> = this.find_ast_def_by_name(this.ast_definitions, this.extract_template_name(e.name));
            if (ast_def.is_some() && ast_def.some is ast.Definition.enum_def) {
                this.build_enum_vtables(ast_def.some.enum_def, e, global_scope);
            }
            return new BoundDefinition.enum_def(e);
        }
        return bound_def;
    }

    fun extract_template_name(this, mangled_name: string) -> string {
        let pos: i64 = string_find(mangled_name, "__");
        if (pos >= 0) {
            return string_substring(mangled_name, 0, pos);
        }
        return mangled_name;
    }

    fun build_vtables_for_def(mut this, ast_def: ast.Definition, bound_def: BoundDefinition, global_scope: mut BoundScope) -> BoundDefinition {
        if (bound_def is BoundDefinition.class_def && ast_def is ast.Definition.class_def) {
            let cls: mut BoundClassDefinition = bound_def.class_def;
            this.build_class_vtables(ast_def.class_def, cls, global_scope);
            return new BoundDefinition.class_def(cls);
        }
        if (bound_def is BoundDefinition.interface_def && ast_def is ast.Definition.interface_def) {
            let iface: mut BoundInterfaceDefinition = bound_def.interface_def;
            this.build_interface_vtables(ast_def.interface_def, iface, global_scope);
            return new BoundDefinition.interface_def(iface);
        }
        if (bound_def is BoundDefinition.enum_def && ast_def is ast.Definition.enum_def) {
            let e: mut BoundEnumDefinition = bound_def.enum_def;
            this.build_enum_vtables(ast_def.enum_def, e, global_scope);
            return new BoundDefinition.enum_def(e);
        }
        if (bound_def is BoundDefinition.impl_for_def && ast_def is ast.Definition.impl_for_def) {
            let impl_for: mut BoundInterfaceForImplementation = bound_def.impl_for_def;
            this.process_impl_for(ast_def.impl_for_def, impl_for, global_scope, global_scope);
            return new BoundDefinition.impl_for_def(impl_for);
        }
        if (bound_def is BoundDefinition.namespace_def && ast_def is ast.Definition.namespace_def) {
            let ns: mut BoundNamespaceDefinition = bound_def.namespace_def;
            let ns_scope: mut BoundScope = ns.scope.some;
            let k: mut i64 = 0;
            while (k < cast<i64>(ns.children.size())) {
                let bound_child: BoundDefinition = ns.children.at(cast<u64>(k)).some;
                let ast_child: Option<ast.Definition> = this.find_matching_ast_child(ast_def.namespace_def, bound_child);
                if (ast_child.is_some()) {
                    ns.children.set(cast<u64>(k), this.build_vtables_for_def(ast_child.some, bound_child, ns_scope));
                }
                k = k + 1;
            }
            return new BoundDefinition.namespace_def(ns);
        }
        return bound_def;
    }

    fun find_matching_ast_child(this, ast_ns: ast.NamespaceDefinition, bound_child: BoundDefinition) -> Option<ast.Definition> {
        let i: mut i64 = 0;
        while (i < cast<i64>(ast_ns.children.size())) {
            let ast_child: ast.Definition = ast_ns.children.at(cast<u64>(i)).some;
            if (ast_child is ast.Definition.function_def && bound_child is BoundDefinition.function_def) {
                if (ast_child.function_def.name == bound_child.function_def.name) {
                    return new Option<ast.Definition>.some(ast_child);
                }
            }
            if (ast_child is ast.Definition.class_def && bound_child is BoundDefinition.class_def) {
                if (ast_child.class_def.name == bound_child.class_def.name) {
                    return new Option<ast.Definition>.some(ast_child);
                }
            }
            if (ast_child is ast.Definition.interface_def && bound_child is BoundDefinition.interface_def) {
                if (ast_child.interface_def.name == bound_child.interface_def.name) {
                    return new Option<ast.Definition>.some(ast_child);
                }
            }
            if (ast_child is ast.Definition.enum_def && bound_child is BoundDefinition.enum_def) {
                if (ast_child.enum_def.name == bound_child.enum_def.name) {
                    return new Option<ast.Definition>.some(ast_child);
                }
            }
            if (ast_child is ast.Definition.impl_for_def && bound_child is BoundDefinition.impl_for_def) {
                return new Option<ast.Definition>.some(ast_child);
            }
            if (ast_child is ast.Definition.initial_routine && bound_child is BoundDefinition.initial_routine) {
                return new Option<ast.Definition>.some(ast_child);
            }
            if (ast_child is ast.Definition.global_var && bound_child is BoundDefinition.global_var_def) {
                if (ast_child.global_var.name == bound_child.global_var_def.name) {
                    return new Option<ast.Definition>.some(ast_child);
                }
            }
            i = i + 1;
        }
        return new Option<ast.Definition>.none();
    }

    fun build_class_vtables(mut this, ast_cls: ast.ClassDefinition, bound_cls: mut BoundClassDefinition, global_scope: mut BoundScope) {
        let class_scope: mut BoundScope = bound_cls.scope.some;
        let i: mut i64 = 0;
        while (i < cast<i64>(ast_cls.members.size())) {
            let member: ast.Definition = ast_cls.members.at(cast<u64>(i)).some;
            if (member is ast.Definition.impl_def) {
                let impl_entry: ast.InterfaceImplementation = member.impl_def;
                let iface_type: mut BoundType = this.resolve_type_name(impl_entry.type_name, global_scope);
                let vtable: mut BoundVTable = new BoundVTable();
                vtable.interface_type = iface_type;
                this.build_vtable_slots(impl_entry, vtable, global_scope, class_scope);
                bound_cls.vtables.push(vtable);
            }
            i = i + 1;
        }
    }

    fun build_enum_vtables(mut this, ast_enum: ast.EnumDefinition, bound_enum: mut BoundEnumDefinition, global_scope: mut BoundScope) {
        let enum_scope: mut BoundScope = bound_enum.scope.some;
        let i: mut i64 = 0;
        while (i < cast<i64>(ast_enum.members.size())) {
            let member: ast.Definition = ast_enum.members.at(cast<u64>(i)).some;
            if (member is ast.Definition.impl_def) {
                let impl_entry: ast.InterfaceImplementation = member.impl_def;
                let iface_type: mut BoundType = this.resolve_type_name(impl_entry.type_name, global_scope);
                let vtable: mut BoundVTable = new BoundVTable();
                vtable.interface_type = iface_type;
                this.build_vtable_slots(impl_entry, vtable, global_scope, enum_scope);
                bound_enum.vtables.push(vtable);
            }
            i = i + 1;
        }
    }

    fun build_interface_vtables(mut this, ast_iface: ast.InterfaceDefinition, bound_iface: mut BoundInterfaceDefinition, global_scope: mut BoundScope) {
        let iface_scope: mut BoundScope = bound_iface.scope.some;
        let i: mut i64 = 0;
        while (i < cast<i64>(ast_iface.members.size())) {
            let member: ast.Definition = ast_iface.members.at(cast<u64>(i)).some;
            if (member is ast.Definition.impl_def) {
                let impl_entry: ast.InterfaceImplementation = member.impl_def;
                let iface_type: mut BoundType = this.resolve_type_name(impl_entry.type_name, global_scope);
                let vtable: mut BoundVTable = new BoundVTable();
                vtable.interface_type = iface_type;
                this.build_vtable_slots(impl_entry, vtable, global_scope, iface_scope);
            }
            i = i + 1;
        }
    }

    fun build_vtable_slots(mut this, impl_entry: ast.InterfaceImplementation, vtable: mut BoundVTable, global_scope: mut BoundScope, impl_scope: mut BoundScope) {
        let i: mut i64 = 0;
        while (i < cast<i64>(impl_entry.functions.size())) {
            let func: ast.Definition = impl_entry.functions.at(cast<u64>(i)).some;
            if (func is ast.Definition.function_def) {
                let slot: mut BoundVTableSlot = new BoundVTableSlot();
                let iface_sym: Option<BoundSymbol> = global_scope.lookup_type_in_scope(impl_entry.type_name);
                if (iface_sym.is_some()) {
                    if (iface_sym.some is bound.BoundSymbol.type_sym) {
                        let iface_def: BoundDefinition = iface_sym.some.type_sym.bound_type.type_definition.some;
                        if (iface_def is BoundDefinition.interface_def) {
                            let iface: BoundInterfaceDefinition = iface_def.interface_def;
                            let j: mut i64 = 0;
                            while (j < cast<i64>(iface.methods.size())) {
                                let md: BoundDefinition = iface.methods.at(cast<u64>(j)).some;
                                if (md is BoundDefinition.function_def) {
                                    if (md.function_def.name == func.function_def.name) {
                                        if (md.function_def.symbol.is_some()) {
                                            slot.interface_method = new Option<BoundFunctionSymbol>.some(md.function_def.symbol.some);
                                        }
                                    }
                                }
                                j = j + 1;
                            }
                        }
                    }
                }
                let impl_func_name: string = func.function_def.name;
                let impl_sym: Option<BoundSymbol> = impl_scope.lookup_symbol(impl_func_name);
                if (impl_sym.is_some()) {
                    if (impl_sym.some is bound.BoundSymbol.function_sym) {
                        slot.implementation_method = new Option<BoundFunctionSymbol>.some(impl_sym.some.function_sym);
                    }
                }
                vtable.slots.push(slot);
            }
            i = i + 1;
        }
    }

    fun process_impl_for(mut this, ast_impl: ast.InterfaceForImplementation, bound_impl: mut BoundInterfaceForImplementation, global_scope: mut BoundScope, impl_scope: mut BoundScope) {
        let iface_type: mut BoundType = this.resolve_type_name(ast_impl.type_name, impl_scope);
        let for_type: mut BoundType = this.resolve_type_name(ast_impl.for_type_name, impl_scope);
        bound_impl.interface_type = iface_type;
        bound_impl.for_type = for_type;
        let vtable: mut BoundVTable = new BoundVTable();
        vtable.interface_type = iface_type;
        let i: mut i64 = 0;
        while (i < cast<i64>(ast_impl.functions.size())) {
            let func: ast.Definition = ast_impl.functions.at(cast<u64>(i)).some;
            if (func is ast.Definition.function_def) {
                let slot: mut BoundVTableSlot = new BoundVTableSlot();
                let iface_sym: Option<BoundSymbol> = impl_scope.lookup_type_in_scope(ast_impl.type_name);
                if (iface_sym.is_some()) {
                    if (iface_sym.some is bound.BoundSymbol.type_sym) {
                        let iface_def: BoundDefinition = iface_sym.some.type_sym.bound_type.type_definition.some;
                        if (iface_def is BoundDefinition.interface_def) {
                            let iface: BoundInterfaceDefinition = iface_def.interface_def;
                            let j: mut i64 = 0;
                            while (j < cast<i64>(iface.methods.size())) {
                                let md: BoundDefinition = iface.methods.at(cast<u64>(j)).some;
                                if (md is BoundDefinition.function_def) {
                                    if (md.function_def.name == func.function_def.name) {
                                        if (md.function_def.symbol.is_some()) {
                                            slot.interface_method = new Option<BoundFunctionSymbol>.some(md.function_def.symbol.some);
                                        }
                                    }
                                }
                                j = j + 1;
                            }
                        }
                    }
                }
                if (func.function_def.name != "") {
                    let impl_sym: Option<BoundSymbol> = impl_scope.lookup_symbol(func.function_def.name);
                    if (impl_sym.is_some()) {
                        if (impl_sym.some is bound.BoundSymbol.function_sym) {
                            slot.implementation_method = new Option<BoundFunctionSymbol>.some(impl_sym.some.function_sym);
                        }
                    }
                }
                vtable.slots.push(slot);
            }
            i = i + 1;
        }
        bound_impl.vtable = new Option<BoundVTable>.some(vtable);
    }

    fun pass_classify_value_types(mut this, result: BoundCompilationUnit) {
        let i: mut i64 = 0;
        while (i < cast<i64>(result.definitions.size())) {
            let updated: BoundDefinition = this.classify_def(result.definitions.at(cast<u64>(i)).some, new _utils.List<string>());
            result.definitions.set(cast<u64>(i), updated);
            i = i + 1;
        }
    }

    fun classify_def(mut this, def: BoundDefinition, visiting: mut _utils.List<string>) -> BoundDefinition {
        if (def is BoundDefinition.class_def) {
            let cls: mut BoundClassDefinition = def.class_def;
            this.classify_class(cls, visiting);
            return new BoundDefinition.class_def(cls);
        }
        if (def is BoundDefinition.namespace_def) {
            let ns: mut BoundNamespaceDefinition = def.namespace_def;
            let k: mut i64 = 0;
            while (k < cast<i64>(ns.children.size())) {
                let updated: BoundDefinition = this.classify_def(ns.children.at(cast<u64>(k)).some, visiting);
                ns.children.set(cast<u64>(k), updated);
                k = k + 1;
            }
            return new BoundDefinition.namespace_def(ns);
        }
        return def;
    }

    fun classify_class(mut this, cls: mut BoundClassDefinition, visiting: mut _utils.List<string>) -> bool {
        if (cls.is_value_class.is_some()) {
            return cls.is_value_class.some;
        }

        if (this.is_in_visiting(cls.full_name, visiting)) {
            cls.is_value_class = new Option<bool>.some(false);
            return false;
        }

        if (this.class_has_icopy(cls)) {
            if (this.class_has_iref(cls)) {
                this.report_error("Class '" + cls.name + "' cannot implement both ICopy and IRef", 0, 0);
                cls.is_value_class = new Option<bool>.some(false);
                return false;
            }
            cls.is_value_class = new Option<bool>.some(true);
            return true;
        }

        if (this.class_has_iref(cls)) {
            cls.is_value_class = new Option<bool>.some(false);
            return false;
        }

        visiting.push(cls.full_name);
        let all_value: bool = this.all_fields_value_type(cls, visiting);
        visiting.pop();

        cls.is_value_class = new Option<bool>.some(all_value);
        return all_value;
    }

    fun class_has_user_interfaces(this, cls: BoundClassDefinition) -> bool {
        let vi: mut i64 = 0;
        while (vi < cast<i64>(cls.vtables.size())) {
            let vtable: BoundVTable = cls.vtables.at(cast<u64>(vi)).some;
            let name: string = vtable.interface_type.display_name();
            if (name != "ICopy" && name != "IRef") {
                return true;
            }
            vi = vi + 1;
        }
        return false;
    }

    fun is_in_visiting(this, full_name: string, visiting: _utils.List<string>) -> bool {
        let ci: mut i64 = 0;
        while (ci < cast<i64>(visiting.size())) {
            if (visiting.at(cast<u64>(ci)).some == full_name) {
                return true;
            }
            ci = ci + 1;
        }
        return false;
    }

    fun class_has_icopy(this, cls: BoundClassDefinition) -> bool {
        let vi: mut i64 = 0;
        while (vi < cast<i64>(cls.vtables.size())) {
            let vtable: BoundVTable = cls.vtables.at(cast<u64>(vi)).some;
            if (vtable.interface_type.display_name() == "ICopy") {
                return true;
            }
            vi = vi + 1;
        }
        return false;
    }

    fun class_has_iref(this, cls: BoundClassDefinition) -> bool {
        let vi: mut i64 = 0;
        while (vi < cast<i64>(cls.vtables.size())) {
            let vtable: BoundVTable = cls.vtables.at(cast<u64>(vi)).some;
            if (vtable.interface_type.display_name() == "IRef") {
                return true;
            }
            vi = vi + 1;
        }
        return false;
    }

    fun all_fields_value_type(mut this, cls: BoundClassDefinition, visiting: mut _utils.List<string>) -> bool {
        let fi: mut i64 = 0;
        while (fi < cast<i64>(cls.fields.size())) {
            let field_def: BoundDefinition = cls.fields.at(cast<u64>(fi)).some;
            if (field_def is BoundDefinition.class_field) {
                let field_type: BoundType = field_def.class_field.bound_type;
                if (!this.is_type_value_like(field_type, visiting)) {
                    return false;
                }
            }
            fi = fi + 1;
        }
        return true;
    }

    fun is_type_value_like(mut this, bt: BoundType, visiting: mut _utils.List<string>) -> bool {
        if (bt.kind is TypeKind.PrimitiveKind) {
            if (bt.primitive is PrimitiveType.StringType) { return false; }
            return true;
        }
        if (bt.kind is TypeKind.EnumKind) { return true; }
        if (bt.kind is TypeKind.ClassKind) {
            if (bt.type_definition.is_some()) {
                let def: BoundDefinition = bt.type_definition.some;
                if (def is BoundDefinition.class_def) {
                    return this.classify_class(def.class_def, visiting);
                }
            }
            return false;
        }
        return false;
    }

    fun resolve_type_name(mut this, name: string, scope: mut BoundScope) -> mut BoundType {
        let prim: Option<BoundType> = this.type_registry.resolve_type(name);
        if (prim.is_some()) {
            let result: mut BoundType = prim.some;
            return result;
        }
        let type_sym: Option<BoundSymbol> = scope.lookup_type_in_scope(name);
        if (type_sym.is_some()) {
            let result: mut BoundType = type_sym.some.type_sym.bound_type;
            return result;
        }
        return this.type_registry.make_error_type();
    }

    fun pass_bind_expressions(mut this, unit: ast.CompilationUnit, result: BoundCompilationUnit) {
        this.current_unit = new Option<BoundCompilationUnit>.some(result);
        let ast_count: i64 = cast<i64>(unit.definitions.size());
        let i: mut i64 = 0;
        while (i < cast<i64>(result.definitions.size())) {
            if (i < ast_count) {
                let ast_def: ast.Definition = unit.definitions.at(cast<u64>(i)).some;
                let bound_def: BoundDefinition = result.definitions.at(cast<u64>(i)).some;
                result.definitions.set(cast<u64>(i), this.bind_body_for_def(ast_def, bound_def, result));
            } else {
                let bound_def: BoundDefinition = result.definitions.at(cast<u64>(i)).some;
                result.definitions.set(cast<u64>(i), this.bind_body_for_specialized_def(bound_def, result));
            }
            i = i + 1;
        }
        this.current_unit = new Option<BoundCompilationUnit>.none();
    }

    fun bind_body_for_specialized_def(mut this, bound_def: BoundDefinition, result: BoundCompilationUnit) -> BoundDefinition {
        if (bound_def is BoundDefinition.class_def) {
            let bound_cls: BoundClassDefinition = bound_def.class_def;
            let template_name: string = this.extract_template_name(bound_cls.name);
            let ast_def: Option<ast.Definition> = this.find_ast_def_by_name(this.ast_definitions, template_name);
            if (ast_def.is_some() && ast_def.some is ast.Definition.class_def) {
                return this.bind_body_for_def(ast_def.some, bound_def, result);
            }
            return bound_def;
        }
        if (bound_def is BoundDefinition.enum_def) {
            let bound_enum: BoundEnumDefinition = bound_def.enum_def;
            let template_name: string = this.extract_template_name(bound_enum.name);
            let ast_def: Option<ast.Definition> = this.find_ast_def_by_name(this.ast_definitions, template_name);
            if (ast_def.is_some() && ast_def.some is ast.Definition.enum_def) {
                return this.bind_body_for_def(ast_def.some, bound_def, result);
            }
            return bound_def;
        }
        if (bound_def is BoundDefinition.function_def) {
            let bound_func: BoundFunctionDefinition = bound_def.function_def;
            let template_name: string = this.extract_template_name(bound_func.name);
            let ast_def: Option<ast.Definition> = this.find_ast_def_by_name(this.ast_definitions, template_name);
            if (ast_def.is_some() && ast_def.some is ast.Definition.function_def) {
                return this.bind_body_for_def(ast_def.some, bound_def, result);
            }
            return bound_def;
        }
        return bound_def;
    }

    fun bind_body_for_def(mut this, ast_def: ast.Definition, bound_def: BoundDefinition, result: BoundCompilationUnit) -> BoundDefinition {
        if (bound_def is BoundDefinition.function_def && ast_def is ast.Definition.function_def) {
            let bound_func: mut BoundFunctionDefinition = bound_def.function_def;
            let ast_func: ast.FunctionDefinition = ast_def.function_def;
            if (bound_func.scope.is_some() && ast_func.body.is_some()) {
                let func_scope: mut BoundScope = bound_func.scope.some;
                let bound_body: mut Option<BoundExpression> = this.bind_expression(ast_func.body.some, func_scope);
                bound_func.body = bound_body;
            }
            return new BoundDefinition.function_def(bound_func);
        }
        if (bound_def is BoundDefinition.initial_routine && ast_def is ast.Definition.initial_routine) {
            let bound_init: mut BoundInitialRoutineDefinition = bound_def.initial_routine;
            let ast_init: ast.InitialRoutineDefinition = ast_def.initial_routine;
            if (bound_init.scope.is_some() && ast_init.body.is_some()) {
                let init_scope: mut BoundScope = bound_init.scope.some;
                let bound_init_body: mut Option<BoundExpression> = this.bind_expression(ast_init.body.some, init_scope);
                bound_init.body = bound_init_body;
            }
            return new BoundDefinition.initial_routine(bound_init);
        }
        if (bound_def is BoundDefinition.class_def && ast_def is ast.Definition.class_def) {
            let bound_cls: BoundClassDefinition = bound_def.class_def;
            if (bound_cls.is_generic_template) { return bound_def; }
            let ast_cls: ast.ClassDefinition = ast_def.class_def;
            let bound_cls: mut BoundClassDefinition = bound_def.class_def;
            let i: mut i64 = 0;
            while (i < cast<i64>(ast_cls.members.size())) {
                let ast_member: ast.Definition = ast_cls.members.at(cast<u64>(i)).some;
                if (ast_member is ast.Definition.function_def) {
                    let j: mut i64 = 0;
                    while (j < cast<i64>(bound_cls.methods.size())) {
                        let bound_md: BoundDefinition = bound_cls.methods.at(cast<u64>(j)).some;
                        if (bound_md is BoundDefinition.function_def && bound_md.function_def.name == ast_member.function_def.name) {
                            bound_cls.methods.set(cast<u64>(j), this.bind_body_for_def(ast_member, bound_md, result));
                        }
                        j = j + 1;
                    }
                }
                if (ast_member is ast.Definition.impl_def) {
                    let ast_impl_member: ast.InterfaceImplementation = ast_member.impl_def;
                    let j: mut i64 = 0;
                    while (j < cast<i64>(bound_cls.interface_impls.size())) {
                        let bound_impl_def: BoundDefinition = bound_cls.interface_impls.at(cast<u64>(j)).some;
                        if (bound_impl_def is BoundDefinition.impl_def) {
                            let bound_iface_impl: mut BoundInterfaceImplementation = bound_impl_def.impl_def;
                            let fi: mut i64 = 0;
                            while (fi < cast<i64>(ast_impl_member.functions.size())) {
                                let ast_func_def: ast.Definition = ast_impl_member.functions.at(cast<u64>(fi)).some;
                                if (ast_func_def is ast.Definition.function_def) {
                                    let mi: mut i64 = 0;
                                    while (mi < cast<i64>(bound_iface_impl.methods.size())) {
                                        let bound_method: BoundDefinition = bound_iface_impl.methods.at(cast<u64>(mi)).some;
                                        if (bound_method is BoundDefinition.function_def && bound_method.function_def.name == ast_func_def.function_def.name) {
                                            bound_iface_impl.methods.set(cast<u64>(mi), this.bind_body_for_def(ast_func_def, bound_method, result));
                                        }
                                        mi = mi + 1;
                                    }
                                }
                                fi = fi + 1;
                            }
                            bound_cls.interface_impls.set(cast<u64>(j), new BoundDefinition.impl_def(bound_iface_impl));
                        }
                        j = j + 1;
                    }
                }
                i = i + 1;
            }
            return new BoundDefinition.class_def(bound_cls);
        }
        if (bound_def is BoundDefinition.enum_def && ast_def is ast.Definition.enum_def) {
            let bound_enum: mut BoundEnumDefinition = bound_def.enum_def;
            let ast_enum: ast.EnumDefinition = ast_def.enum_def;
            let i: mut i64 = 0;
            while (i < cast<i64>(ast_enum.members.size())) {
                let ast_member: ast.Definition = ast_enum.members.at(cast<u64>(i)).some;
                if (ast_member is ast.Definition.function_def) {
                    let j: mut i64 = 0;
                    while (j < cast<i64>(bound_enum.methods.size())) {
                        let bound_md: BoundDefinition = bound_enum.methods.at(cast<u64>(j)).some;
                        if (bound_md is BoundDefinition.function_def && bound_md.function_def.name == ast_member.function_def.name) {
                            bound_enum.methods.set(cast<u64>(j), this.bind_body_for_def(ast_member, bound_md, result));
                        }
                        j = j + 1;
                    }
                }
                i = i + 1;
            }
            return new BoundDefinition.enum_def(bound_enum);
        }
        if (bound_def is BoundDefinition.namespace_def && ast_def is ast.Definition.namespace_def) {
            let ast_ns: ast.NamespaceDefinition = ast_def.namespace_def;
            let bound_ns: mut BoundNamespaceDefinition = bound_def.namespace_def;
            let k: mut i64 = 0;
            while (k < cast<i64>(ast_ns.children.size())) {
                let ast_child: ast.Definition = ast_ns.children.at(cast<u64>(k)).some;
                let m: mut i64 = 0;
                while (m < cast<i64>(bound_ns.children.size())) {
                    let bound_child: BoundDefinition = bound_ns.children.at(cast<u64>(m)).some;
                    if (ast_child is ast.Definition.function_def && bound_child is BoundDefinition.function_def) {
                        if (ast_child.function_def.name == bound_child.function_def.name) {
                            bound_ns.children.set(cast<u64>(m), this.bind_body_for_def(ast_child, bound_child, result));
                        }
                    }
                    if (ast_child is ast.Definition.class_def && bound_child is BoundDefinition.class_def) {
                        if (ast_child.class_def.name == bound_child.class_def.name) {
                            bound_ns.children.set(cast<u64>(m), this.bind_body_for_def(ast_child, bound_child, result));
                        }
                    }
                    if (ast_child is ast.Definition.interface_def && bound_child is BoundDefinition.interface_def) {
                        if (ast_child.interface_def.name == bound_child.interface_def.name) {
                            bound_ns.children.set(cast<u64>(m), this.bind_body_for_def(ast_child, bound_child, result));
                        }
                    }
                    if (ast_child is ast.Definition.initial_routine && bound_child is BoundDefinition.initial_routine) {
                        bound_ns.children.set(cast<u64>(m), this.bind_body_for_def(ast_child, bound_child, result));
                    }
                    if (ast_child is ast.Definition.enum_def && bound_child is BoundDefinition.enum_def) {
                        if (ast_child.enum_def.name == bound_child.enum_def.name) {
                            bound_ns.children.set(cast<u64>(m), this.bind_body_for_def(ast_child, bound_child, result));
                        }
                    }
                    if (ast_child is ast.Definition.namespace_def && bound_child is BoundDefinition.namespace_def) {
                        if (ast_child.namespace_def.name == bound_child.namespace_def.name) {
                            bound_ns.children.set(cast<u64>(m), this.bind_body_for_def(ast_child, bound_child, result));
                        }
                    }
                    if (ast_child is ast.Definition.global_var && bound_child is BoundDefinition.global_var_def) {
                        if (ast_child.global_var.name == bound_child.global_var_def.name) {
                            bound_ns.children.set(cast<u64>(m), this.bind_body_for_def(ast_child, bound_child, result));
                        }
                    }
                    m = m + 1;
                }
                k = k + 1;
            }
            return new BoundDefinition.namespace_def(bound_ns);
        }
        if (bound_def is BoundDefinition.interface_def && ast_def is ast.Definition.interface_def) {
            let ast_iface: ast.InterfaceDefinition = ast_def.interface_def;
            let bound_iface: mut BoundInterfaceDefinition = bound_def.interface_def;
            let i: mut i64 = 0;
            while (i < cast<i64>(ast_iface.members.size())) {
                let ast_member: ast.Definition = ast_iface.members.at(cast<u64>(i)).some;
                if (ast_member is ast.Definition.function_def) {
                    let j: mut i64 = 0;
                    while (j < cast<i64>(bound_iface.methods.size())) {
                        let bound_md: BoundDefinition = bound_iface.methods.at(cast<u64>(j)).some;
                        if (bound_md is BoundDefinition.function_def && bound_md.function_def.name == ast_member.function_def.name) {
                            bound_iface.methods.set(cast<u64>(j), this.bind_body_for_def(ast_member, bound_md, result));
                        }
                        j = j + 1;
                    }
                }
                i = i + 1;
            }
            return new BoundDefinition.interface_def(bound_iface);
        }
        if (bound_def is BoundDefinition.enum_def && ast_def is ast.Definition.enum_def) {
            let ast_enum: ast.EnumDefinition = ast_def.enum_def;
            let bound_enum: mut BoundEnumDefinition = bound_def.enum_def;
            let i: mut i64 = 0;
            while (i < cast<i64>(ast_enum.members.size())) {
                let ast_member: ast.Definition = ast_enum.members.at(cast<u64>(i)).some;
                if (ast_member is ast.Definition.impl_def) {
                    let ast_impl_member: ast.InterfaceImplementation = ast_member.impl_def;
                    let j: mut i64 = 0;
                    while (j < cast<i64>(bound_enum.interface_impls.size())) {
                        let bound_impl_def: BoundDefinition = bound_enum.interface_impls.at(cast<u64>(j)).some;
                        if (bound_impl_def is BoundDefinition.impl_def) {
                            let bound_iface_impl: mut BoundInterfaceImplementation = bound_impl_def.impl_def;
                            let fi: mut i64 = 0;
                            while (fi < cast<i64>(ast_impl_member.functions.size())) {
                                let ast_func_def: ast.Definition = ast_impl_member.functions.at(cast<u64>(fi)).some;
                                if (ast_func_def is ast.Definition.function_def) {
                                    let mi: mut i64 = 0;
                                    while (mi < cast<i64>(bound_iface_impl.methods.size())) {
                                        let bound_method: BoundDefinition = bound_iface_impl.methods.at(cast<u64>(mi)).some;
                                        if (bound_method is BoundDefinition.function_def && bound_method.function_def.name == ast_func_def.function_def.name) {
                                            bound_iface_impl.methods.set(cast<u64>(mi), this.bind_body_for_def(ast_func_def, bound_method, result));
                                        }
                                        mi = mi + 1;
                                    }
                                }
                                fi = fi + 1;
                            }
                            bound_enum.interface_impls.set(cast<u64>(j), new BoundDefinition.impl_def(bound_iface_impl));
                        }
                        j = j + 1;
                    }
                }
                i = i + 1;
            }
            return new BoundDefinition.enum_def(bound_enum);
        }
        if (bound_def is BoundDefinition.global_var_def && ast_def is ast.Definition.global_var) {
            let gv: mut BoundGlobalVariableDefinition = bound_def.global_var_def;
            if (gv.scope.is_some() && ast_def.global_var.initializer.is_some()) {
                let gv_scope: mut BoundScope = gv.scope.some;
                let bound_init: mut Option<BoundExpression> = this.bind_expression(ast_def.global_var.initializer.some, gv_scope);
                gv.initializer = bound_init;
                if (bound_init.is_some()) {
                    let init_type: mut BoundType = bound_init.some.get_bound_type();
                    if (gv.bound_type.kind is TypeKind.PrimitiveKind && gv.bound_type.primitive is PrimitiveType.VoidType) {
                        gv.bound_type = init_type;
                        if (gv.variable_symbol.is_some()) {
                            let sym: mut BoundVariableSymbol = gv.variable_symbol.some;
                            sym.bound_type = init_type;
                            gv.variable_symbol = new Option<BoundVariableSymbol>.some(sym);
                        }
                    }
                }
            }
            return new BoundDefinition.global_var_def(gv);
        }
        return bound_def;
    }

    fun bind_expression(mut this, expr: ast.Expression, scope: mut BoundScope) -> Option<BoundExpression> {
        if (expr is ast.Expression.constant) {
            return this.bind_constant(expr.constant, scope);
        }
        if (expr is ast.Expression.string_literal) {
            return this.bind_string_literal(expr.string_literal, scope);
        }
        if (expr is ast.Expression.bool_literal) {
            return this.bind_bool_literal(expr.bool_literal, scope);
        }
        if (expr is ast.Expression.void_literal) {
            return this.bind_void_literal(scope);
        }
        if (expr is ast.Expression.parenthesized) {
            if (expr.parenthesized.inner.is_some()) {
                return this.bind_expression(expr.parenthesized.inner.some, scope);
            }
        }
        if (expr is ast.Expression.identifier) {
            return this.bind_identifier(expr.identifier, scope);
        }
        if (expr is ast.Expression.binary) {
            return this.bind_binary(expr.binary, scope);
        }
        if (expr is ast.Expression.unary) {
            return this.bind_unary(expr.unary, scope);
        }
        if (expr is ast.Expression.member_access) {
            return this.bind_member_access(expr.member_access, scope);
        }
        if (expr is ast.Expression.function_call) {
            return this.bind_function_call(expr.function_call, scope);
        }
        if (expr is ast.Expression.if_expr) {
            return this.bind_if_expr(expr.if_expr, scope);
        }
        if (expr is ast.Expression.while_expr) {
            return this.bind_while_expr(expr.while_expr, scope);
        }
        if (expr is ast.Expression.code_block) {
            return this.bind_code_block(expr.code_block, scope);
        }
        if (expr is ast.Expression.cast_expr) {
            return this.bind_cast(expr.cast_expr, scope);
        }
        if (expr is ast.Expression.new_expr) {
            return this.bind_new_expr(expr.new_expr, scope);
        }
        return new Option<BoundExpression>.none();
    }

    fun bind_constant(mut this, expr: ast.ConstantExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        let bt: BoundType = this.type_registry.resolve_type("i64").some;
        let result: mut BoundLiteralExpression = new BoundLiteralExpression(expr.value, bt, new LiteralKind.IntegerLiteral());
        return new Option<BoundExpression>.some(new BoundExpression.literal(result));
    }

    fun bind_string_literal(mut this, expr: ast.StringLiteralExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        let bt: BoundType = this.type_registry.resolve_type("string").some;
        let result: mut BoundLiteralExpression = new BoundLiteralExpression(expr.value, bt, new LiteralKind.StringLiteral());
        return new Option<BoundExpression>.some(new BoundExpression.literal(result));
    }

    fun bind_bool_literal(mut this, expr: ast.BoolLiteralExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        let bt: BoundType = this.type_registry.resolve_type("bool").some;
        let result: mut BoundLiteralExpression = new BoundLiteralExpression(expr.value, bt, new LiteralKind.BoolLiteral());
        return new Option<BoundExpression>.some(new BoundExpression.literal(result));
    }

    fun bind_void_literal(mut this, scope: mut BoundScope) -> Option<BoundExpression> {
        let result: mut BoundLiteralExpression = new BoundLiteralExpression("void", this.type_registry.void_type, new LiteralKind.VoidLiteral());
        return new Option<BoundExpression>.some(new BoundExpression.literal(result));
    }

    fun bind_identifier(mut this, expr: ast.IdentifierExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        let sym: Option<BoundSymbol> = scope.lookup_symbol(expr.name);
        if (sym.is_some()) {
            let bt: BoundType = this.resolve_symbol_type(sym.some);
            let result: mut BoundIdentifierExpression = new BoundIdentifierExpression(bt, sym);
            return new Option<BoundExpression>.some(new BoundExpression.identifier(result));
        }
        let result: mut BoundIdentifierExpression = new BoundIdentifierExpression(new BoundType(), sym);
        return new Option<BoundExpression>.some(new BoundExpression.identifier(result));
    }

    fun resolve_symbol_type(this, sym: BoundSymbol) -> BoundType {
        if (sym is BoundSymbol.variable) {
            return sym.variable.bound_type;
        }
        if (sym is BoundSymbol.function_sym) {
            return sym.function_sym.bound_type;
        }
        if (sym is BoundSymbol.type_sym) {
            return sym.type_sym.bound_type;
        }
        if (sym is BoundSymbol.enum_member) {
            return sym.enum_member.bound_type;
        }
        return new BoundType();
    }

    fun bind_binary(mut this, expr: ast.BinaryExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        let operands: mut _utils.List<BoundExpression> = new _utils.List<BoundExpression>();
        let i: mut i64 = 0;
        while (i < cast<i64>(expr.operands.size())) {
            let bound_op: Option<BoundExpression> = this.bind_expression(expr.operands.at(cast<u64>(i)).some, scope);
            if (bound_op.is_some()) {
                operands.push(bound_op.some);
            }
            i = i + 1;
        }
        let operators: mut _utils.List<ast.BinaryOperator> = new _utils.List<ast.BinaryOperator>();
        let j: mut i64 = 0;
        while (j < cast<i64>(expr.operators.size())) {
            operators.push(expr.operators.at(cast<u64>(j)).some);
            j = j + 1;
        }
        if (cast<i64>(operands.size()) > 0) {
            let bt: BoundType = operands.at(cast<u64>(0)).some.get_bound_type();
            // `is` operator produces bool result
            if (cast<i64>(operators.size()) > 0) {
                let first_op: ast.BinaryOperator = operators.at(cast<u64>(0)).some;
                if (first_op is ast.BinaryOperator.Is) {
                    let bool_type: BoundType = this.type_registry.resolve_type("bool").some;
                    let result: mut BoundBinaryExpression = new BoundBinaryExpression(bool_type, operators, operands);
                    return new Option<BoundExpression>.some(new BoundExpression.binary(result));
                }
            }
            let result: mut BoundBinaryExpression = new BoundBinaryExpression(bt, operators, operands);
            return new Option<BoundExpression>.some(new BoundExpression.binary(result));
        }
        let result: mut BoundBinaryExpression = new BoundBinaryExpression(new BoundType(), operators, operands);
        return new Option<BoundExpression>.some(new BoundExpression.binary(result));
    }

    fun bind_unary(mut this, expr: ast.UnaryExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        if (expr.operand.is_some()) {
            let bound_inner: Option<BoundExpression> = this.bind_expression(expr.operand.some, scope);
            if (bound_inner.is_some()) {
                let bt: BoundType = bound_inner.some.get_bound_type();
                let result: mut BoundUnaryExpression = new BoundUnaryExpression(bt, expr.operator_value, bound_inner);
                return new Option<BoundExpression>.some(new BoundExpression.unary(result));
            }
        }
        let result: mut BoundUnaryExpression = new BoundUnaryExpression(new BoundType(), expr.operator_value, new Option<BoundExpression>.none());
        return new Option<BoundExpression>.some(new BoundExpression.unary(result));
    }

    fun resolve_field_type_from_class(this, base_type: BoundType, cls: BoundClassDefinition, field_name: string, scope: BoundScope) -> mut BoundType {
        // If base type has generic args, look up the field in the specialized class
        if (cast<i64>(base_type.generic_args.size()) > 0) {
            let mangled: string = this.mangle_generic_name(cls.name, base_type.generic_args);
            let spec_sym: Option<BoundSymbol> = scope.lookup_type_in_scope(mangled);
            if (spec_sym.is_some() && spec_sym.some is BoundSymbol.type_sym) {
                let spec_bt: BoundType = spec_sym.some.type_sym.bound_type;
                if (spec_bt.type_definition.is_some()) {
                    let spec_td: BoundDefinition = spec_bt.type_definition.some;
                    if (spec_td is BoundDefinition.class_def) {
                        let spec_cls: BoundClassDefinition = spec_td.class_def;
                        let fi: mut i64 = 0;
                        while (fi < cast<i64>(spec_cls.fields.size())) {
                            let fd: BoundDefinition = spec_cls.fields.at(cast<u64>(fi)).some;
                            if (fd is BoundDefinition.class_field) {
                                if (fd.class_field.name == field_name) {
                                    return fd.class_field.bound_type;
                                }
                            }
                            fi = fi + 1;
                        }
                    }
                }
            }
        }
        // Fallback: search in generic class fields
        let fi: mut i64 = 0;
        while (fi < cast<i64>(cls.fields.size())) {
            let fd: BoundDefinition = cls.fields.at(cast<u64>(fi)).some;
            if (fd is BoundDefinition.class_field) {
                if (fd.class_field.name == field_name) {
                    return fd.class_field.bound_type;
                }
            }
            fi = fi + 1;
        }
        return new BoundType();
    }

    fun bind_member_access(mut this, expr: ast.MemberAccessExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        if (expr.base_expr.is_some()) {
            let bound_base: Option<BoundExpression> = this.bind_expression(expr.base_expr.some, scope);
            if (bound_base.is_some()) {
                let base_type: BoundType = bound_base.some.get_bound_type();
                if (base_type.type_definition.is_some()) {
                    let td: BoundDefinition = base_type.type_definition.some;
                    if (td is BoundDefinition.class_def) {
                        let cls: BoundClassDefinition = td.class_def;
                        if (cls.scope.is_some()) {
                            let found: Option<BoundSymbol> = cls.scope.some.lookup_symbol(expr.member_name);
                            if (found.is_some()) {
                                let bt: mut BoundType = this.resolve_symbol_type(found.some);
                                // For fields, look up the field definition for accurate type
                                if (found.some is BoundSymbol.variable) {
                                    if (found.some.variable.variable_kind is VariableSymbolKind.Field) {
                                        bt = this.resolve_field_type_from_class(base_type, cls, expr.member_name, scope);
                                    }
                                }
                                let result: mut BoundMemberAccessExpression = new BoundMemberAccessExpression(bt, bound_base, expr.member_name, found);
                                return new Option<BoundExpression>.some(new BoundExpression.member_access(result));
                            }
                            // Fallback: search implemented interface scopes for default methods
                            let vi: mut i64 = 0;
                            while (vi < cast<i64>(cls.vtables.size())) {
                                let vtable: BoundVTable = cls.vtables.at(cast<u64>(vi)).some;
                                let iface_type: BoundType = vtable.interface_type;
                                if (iface_type.type_definition.is_some()) {
                                    let iface_def: BoundDefinition = iface_type.type_definition.some;
                                    if (iface_def is BoundDefinition.interface_def) {
                                        let iface: BoundInterfaceDefinition = iface_def.interface_def;
                                        if (iface.scope.is_some()) {
                                            let iface_found: Option<BoundSymbol> = iface.scope.some.lookup_symbol(expr.member_name);
                                            if (iface_found.is_some()) {
                                                let bt: BoundType = this.resolve_symbol_type(iface_found.some);
                                                let result: mut BoundMemberAccessExpression = new BoundMemberAccessExpression(bt, bound_base, expr.member_name, iface_found);
                                                return new Option<BoundExpression>.some(new BoundExpression.member_access(result));
                                            }
                                        }
                                    }
                                }
                                vi = vi + 1;
                            }
                        }
                    }
                    if (td is BoundDefinition.enum_def) {
                        let e: BoundEnumDefinition = td.enum_def;
                        if (e.scope.is_some()) {
                            let found: Option<BoundSymbol> = e.scope.some.lookup_symbol(expr.member_name);
                            if (found.is_some()) {
                                let sym: BoundSymbol = found.some;
                                let bt: mut BoundType = this.resolve_symbol_type(sym);
                                if (sym is BoundSymbol.enum_member) {
                                    bt = sym.enum_member.member_type;
                                    bt = this.substitute_generic_args(bt, base_type, new BoundDefinition.enum_def(e));
                                }
                                let result: mut BoundMemberAccessExpression = new BoundMemberAccessExpression(bt, bound_base, expr.member_name, found);
                                return new Option<BoundExpression>.some(new BoundExpression.member_access(result));
                            }
                        }
                        // Fallback: search implemented interface scopes for methods
                        let vi: mut i64 = 0;
                        while (vi < cast<i64>(e.vtables.size())) {
                            let vtable: BoundVTable = e.vtables.at(cast<u64>(vi)).some;
                            let iface_type: BoundType = vtable.interface_type;
                            if (iface_type.type_definition.is_some()) {
                                let iface_def: BoundDefinition = iface_type.type_definition.some;
                                if (iface_def is BoundDefinition.interface_def) {
                                    let iface: BoundInterfaceDefinition = iface_def.interface_def;
                                    if (iface.scope.is_some()) {
                                        let iface_found: Option<BoundSymbol> = iface.scope.some.lookup_symbol(expr.member_name);
                                        if (iface_found.is_some()) {
                                            let bt: BoundType = this.resolve_symbol_type(iface_found.some);
                                            let result: mut BoundMemberAccessExpression = new BoundMemberAccessExpression(bt, bound_base, expr.member_name, iface_found);
                                            return new Option<BoundExpression>.some(new BoundExpression.member_access(result));
                                        }
                                    }
                                }
                            }
                            vi = vi + 1;
                        }
                    }
                    if (td is BoundDefinition.interface_def) {
                        let iface: BoundInterfaceDefinition = td.interface_def;
                        if (iface.scope.is_some()) {
                            let found: Option<BoundSymbol> = iface.scope.some.lookup_symbol(expr.member_name);
                            if (found.is_some()) {
                                let bt: BoundType = this.resolve_symbol_type(found.some);
                                let result: mut BoundMemberAccessExpression = new BoundMemberAccessExpression(bt, bound_base, expr.member_name, found);
                                return new Option<BoundExpression>.some(new BoundExpression.member_access(result));
                            }
                        }
                    }
                }
                // Handle namespace-qualified access (e.g., Foo.msg where Foo is a namespace)
                if (bound_base.some is BoundExpression.identifier) {
                    let base_id: BoundIdentifierExpression = bound_base.some.identifier;
                    if (base_id.symbol.is_some()) {
                        let base_sym: BoundSymbol = base_id.symbol.some;
                        if (base_sym is BoundSymbol.namespace_sym) {
                            let ns_scope: Option<BoundScope> = base_sym.namespace_sym.namespace_scope;
                            if (ns_scope.is_some()) {
                                let found: Option<BoundSymbol> = ns_scope.some.lookup_symbol(expr.member_name);
                                if (found.is_some()) {
                                    let bt: BoundType = this.resolve_symbol_type(found.some);
                                    let result: mut BoundMemberAccessExpression = new BoundMemberAccessExpression(bt, bound_base, expr.member_name, found);
                                    return new Option<BoundExpression>.some(new BoundExpression.member_access(result));
                                }
                            }
                        }
                    }
                }
                let result: mut BoundMemberAccessExpression = new BoundMemberAccessExpression(new BoundType(), bound_base, expr.member_name, new Option<BoundSymbol>.none());
                return new Option<BoundExpression>.some(new BoundExpression.member_access(result));
            }
        }
        let result: mut BoundMemberAccessExpression = new BoundMemberAccessExpression(new BoundType(), new Option<BoundExpression>.none(), expr.member_name, new Option<BoundSymbol>.none());
        return new Option<BoundExpression>.some(new BoundExpression.member_access(result));
    }

    fun find_function_return_type(this, sym: mut BoundFunctionSymbol) -> BoundType {
        if (this.current_unit.is_some()) {
            let found: BoundType = this.search_function_return_type_in_defs(sym.full_name, this.current_unit.some.definitions);
            if (found.kind is TypeKind.PrimitiveKind) {
                let pt: PrimitiveType = found.primitive;
                if (!(pt is PrimitiveType.VoidType)) {
                    return found;
                }
            } else {
                return found;
            }
        }
        return sym.return_type;
    }

    fun is_nonvoid_type(this, t: BoundType) -> bool {
        if (t.kind is TypeKind.PrimitiveKind) {
            return !(t.primitive is PrimitiveType.VoidType);
        }
        return true;
    }

    fun search_function_return_type_in_defs(this, target_full_name: string, defs: mut _utils.List<BoundDefinition>) -> BoundType {
        let i: mut i64 = 0;
        while (i < cast<i64>(defs.size())) {
            let def: BoundDefinition = defs.at(cast<u64>(i)).some;
            if (def is BoundDefinition.function_def) {
                if (def.function_def.full_name == target_full_name) {
                    return def.function_def.return_type;
                }
            }
            if (def is BoundDefinition.namespace_def) {
                let ns_result: BoundType = this.search_function_return_type_in_defs(target_full_name, def.namespace_def.children);
                if (this.is_nonvoid_type(ns_result)) {
                    return ns_result;
                }
            }
            if (def is BoundDefinition.class_def) {
                let cls_result: BoundType = this.search_function_return_type_in_defs(target_full_name, def.class_def.methods);
                if (this.is_nonvoid_type(cls_result)) {
                    return cls_result;
                }
                let ctor_result: BoundType = this.search_function_return_type_in_defs(target_full_name, def.class_def.constructors);
                if (this.is_nonvoid_type(ctor_result)) {
                    return ctor_result;
                }
            }
            i = i + 1;
        }
        return this.type_registry.void_type;
    }

    fun bind_function_call(mut this, expr: ast.FunctionCallExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        let args: mut _utils.List<BoundExpression> = this.bind_arguments(expr.arguments, scope);
        let mut empty_generic_args = new _utils.List<BoundType>();
        if (expr.callee.is_some()) {
            let callee: Option<BoundExpression> = this.bind_expression(expr.callee.some, scope);
            if (callee.is_some()) {
                if (callee.some is BoundExpression.identifier) {
                    let id_expr: BoundIdentifierExpression = callee.some.identifier;
                    if (id_expr.symbol.is_some()) {
                        let sym: BoundSymbol = id_expr.symbol.some;
                        if (sym is BoundSymbol.function_sym) {
                            // Resolve generic args from AST callee
                            let resolved_generic_args: mut _utils.List<BoundType> = new _utils.List<BoundType>();
                            let is_generic_call: mut bool = false;
                            if (expr.callee.is_some()) {
                                let ast_callee: ast.Expression = expr.callee.some;
                                if (ast_callee is ast.Expression.identifier) {
                                    if (cast<i64>(ast_callee.identifier.generic_args.size()) > 0) {
                                        is_generic_call = true;
                                        let gi: mut i64 = 0;
                                        while (gi < cast<i64>(ast_callee.identifier.generic_args.size())) {
                                            resolved_generic_args.push(this.resolve_type_specifier(ast_callee.identifier.generic_args.at(cast<u64>(gi)).some, scope));
                                            gi = gi + 1;
                                        }
                                    }
                                }
                            }
                            // For generic function calls, use specialized function's return type
                            if (is_generic_call) {
                                let mangled: string = this.mangle_generic_name(sym.function_sym.name, resolved_generic_args);
                                let spec_sym: Option<BoundSymbol> = scope.lookup_symbol(mangled);
                                if (spec_sym.is_some() && spec_sym.some is BoundSymbol.function_sym) {
                                    let spec_func_sym: mut BoundFunctionSymbol = spec_sym.some.function_sym;
                                    let bt: mut BoundType = this.find_function_return_type(spec_func_sym);
                                    let result: mut BoundFunctionCallExpression = new BoundFunctionCallExpression(bt, callee, id_expr.symbol, args, false, resolved_generic_args, true);
                                    return new Option<BoundExpression>.some(new BoundExpression.function_call(result));
                                }
                            }
                            let bt: mut BoundType = this.find_function_return_type(sym.function_sym);
                            let result: mut BoundFunctionCallExpression = new BoundFunctionCallExpression(bt, callee, id_expr.symbol, args, false, resolved_generic_args, false);
                            return new Option<BoundExpression>.some(new BoundExpression.function_call(result));
                        }
                    }
                }
                if (callee.some is BoundExpression.member_access) {
                    let ma_expr: BoundMemberAccessExpression = callee.some.member_access;
                    if (ma_expr.member_symbol.is_some()) {
                        let sym: BoundSymbol = ma_expr.member_symbol.some;
                        if (sym is BoundSymbol.function_sym) {
                            // Resolve generic args from AST callee (member access with <T>)
                            let resolved_generic_args: mut _utils.List<BoundType> = new _utils.List<BoundType>();
                            let is_generic_method_call: mut bool = false;
                            if (expr.callee.is_some()) {
                                let ast_callee: ast.Expression = expr.callee.some;
                                if (ast_callee is ast.Expression.member_access) {
                                    if (cast<i64>(ast_callee.member_access.generic_args.size()) > 0) {
                                        is_generic_method_call = true;
                                        let gi: mut i64 = 0;
                                        while (gi < cast<i64>(ast_callee.member_access.generic_args.size())) {
                                            resolved_generic_args.push(this.resolve_type_specifier(ast_callee.member_access.generic_args.at(cast<u64>(gi)).some, scope));
                                            gi = gi + 1;
                                        }
                                    }
                                }
                            }
                            // For generic method calls, look up specialized method
                            if (is_generic_method_call) {
                                let mangled: string = this.mangle_generic_name(sym.function_sym.name, resolved_generic_args);
                                let spec_sym: Option<BoundSymbol> = scope.lookup_symbol(mangled);
                                if (spec_sym.is_some() && spec_sym.some is BoundSymbol.function_sym) {
                                    let spec_func_sym: mut BoundFunctionSymbol = spec_sym.some.function_sym;
                                    let bt: mut BoundType = this.find_function_return_type(spec_func_sym);
                                    let result: mut BoundFunctionCallExpression = new BoundFunctionCallExpression(bt, callee, ma_expr.member_symbol, args, false, resolved_generic_args, true);
                                    return new Option<BoundExpression>.some(new BoundExpression.function_call(result));
                                }
                            }
                            let bt: mut BoundType = this.find_function_return_type(sym.function_sym);
                            // Look up updated return type from class method definitions
                            if (ma_expr.base_expr.is_some()) {
                                let base_type: BoundType = ma_expr.base_expr.some.get_bound_type();
                                // For generic types, look up the specialized definition
                                if (cast<i64>(base_type.generic_args.size()) > 0 && base_type.type_definition.is_some()) {
                                    let orig_def: BoundDefinition = base_type.type_definition.some;
                                    if (orig_def is BoundDefinition.enum_def) {
                                        let spec_name: string = this.mangle_generic_name(orig_def.enum_def.name, base_type.generic_args);
                                        let spec_sym: Option<BoundSymbol> = scope.lookup_type_in_scope(spec_name);
                                        if (spec_sym.is_some()) {
                                            if (spec_sym.some is BoundSymbol.type_sym) {
                                                let spec_type: BoundType = spec_sym.some.type_sym.bound_type;
                                                if (spec_type.type_definition.is_some()) {
                                                    let spec_def: BoundDefinition = spec_type.type_definition.some;
                                                    if (spec_def is BoundDefinition.enum_def) {
                                                        let spec_enum: BoundEnumDefinition = spec_def.enum_def;
                                                        let mi: mut i64 = 0;
                                                        while (mi < cast<i64>(spec_enum.methods.size())) {
                                                            let md: BoundDefinition = spec_enum.methods.at(cast<u64>(mi)).some;
                                                            if (md is BoundDefinition.function_def) {
                                                                if (md.function_def.name == sym.function_sym.name) {
                                                                    bt = md.function_def.return_type;
                                                                }
                                                            }
                                                            mi = mi + 1;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                    if (orig_def is BoundDefinition.class_def) {
                                        let spec_name: string = this.mangle_generic_name(orig_def.class_def.name, base_type.generic_args);
                                        let spec_sym: Option<BoundSymbol> = scope.lookup_type_in_scope(spec_name);
                                        if (spec_sym.is_some()) {
                                            if (spec_sym.some is BoundSymbol.type_sym) {
                                                let spec_type: BoundType = spec_sym.some.type_sym.bound_type;
                                                if (spec_type.type_definition.is_some()) {
                                                    let spec_def: BoundDefinition = spec_type.type_definition.some;
                                                    if (spec_def is BoundDefinition.class_def) {
                                                        let spec_cls: BoundClassDefinition = spec_def.class_def;
                                                        let mi: mut i64 = 0;
                                                        while (mi < cast<i64>(spec_cls.methods.size())) {
                                                            let md: BoundDefinition = spec_cls.methods.at(cast<u64>(mi)).some;
                                                            if (md is BoundDefinition.function_def) {
                                                                if (md.function_def.name == sym.function_sym.name) {
                                                                    bt = md.function_def.return_type;
                                                                }
                                                            }
                                                            mi = mi + 1;
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                } else if (base_type.type_definition.is_some()) {
                                    let td: BoundDefinition = base_type.type_definition.some;
                                    // Interface type: look up return type from interface definition
                                    if (td is BoundDefinition.interface_def) {
                                        let iface: BoundInterfaceDefinition = td.interface_def;
                                        let imi: mut i64 = 0;
                                        while (imi < cast<i64>(iface.methods.size())) {
                                            let md: BoundDefinition = iface.methods.at(cast<u64>(imi)).some;
                                            if (md is BoundDefinition.function_def) {
                                                if (md.function_def.name == sym.function_sym.name) {
                                                    bt = md.function_def.return_type;
                                                }
                                            }
                                            imi = imi + 1;
                                        }
                                    }
                                    if (td is BoundDefinition.class_def) {
                                        let cls: BoundClassDefinition = td.class_def;
                                        let mi: mut i64 = 0;
                                        while (mi < cast<i64>(cls.methods.size())) {
                                            let md: BoundDefinition = cls.methods.at(cast<u64>(mi)).some;
                                            if (md is BoundDefinition.function_def) {
                                                if (md.function_def.name == sym.function_sym.name) {
                                                    bt = md.function_def.return_type;
                                                }
                                            }
                                            mi = mi + 1;
                                        }
                                        let ii: mut i64 = 0;
                                        while (ii < cast<i64>(cls.interface_impls.size())) {
                                            let impl_def: BoundDefinition = cls.interface_impls.at(cast<u64>(ii)).some;
                                            if (impl_def is BoundDefinition.impl_def) {
                                                let iface_impl: BoundInterfaceImplementation = impl_def.impl_def;
                                                let imi: mut i64 = 0;
                                                while (imi < cast<i64>(iface_impl.methods.size())) {
                                                    let md: BoundDefinition = iface_impl.methods.at(cast<u64>(imi)).some;
                                                    if (md is BoundDefinition.function_def) {
                                                        if (md.function_def.name == sym.function_sym.name) {
                                                            bt = md.function_def.return_type;
                                                        }
                                                    }
                                                    imi = imi + 1;
                                                }
                                            }
                                            ii = ii + 1;
                                        }
                                        // Fallback: search interface definitions for default methods
                                        let vi: mut i64 = 0;
                                        while (vi < cast<i64>(cls.vtables.size())) {
                                            let vtable: BoundVTable = cls.vtables.at(cast<u64>(vi)).some;
                                            let iface_type: BoundType = vtable.interface_type;
                                            if (iface_type.type_definition.is_some()) {
                                                let iface_def: BoundDefinition = iface_type.type_definition.some;
                                                if (iface_def is BoundDefinition.interface_def) {
                                                    let iface: BoundInterfaceDefinition = iface_def.interface_def;
                                                    let imi: mut i64 = 0;
                                                    while (imi < cast<i64>(iface.methods.size())) {
                                                        let md: BoundDefinition = iface.methods.at(cast<u64>(imi)).some;
                                                        if (md is BoundDefinition.function_def) {
                                                            if (md.function_def.name == sym.function_sym.name) {
                                                                bt = md.function_def.return_type;
                                                            }
                                                        }
                                                        imi = imi + 1;
                                                    }
                                                }
                                            }
                                            vi = vi + 1;
                                        }
                                    }
                                    if (td is BoundDefinition.enum_def) {
                                        let e: BoundEnumDefinition = td.enum_def;
                                        let mi: mut i64 = 0;
                                        while (mi < cast<i64>(e.methods.size())) {
                                            let md: BoundDefinition = e.methods.at(cast<u64>(mi)).some;
                                            if (md is BoundDefinition.function_def) {
                                                if (md.function_def.name == sym.function_sym.name) {
                                                    bt = md.function_def.return_type;
                                                }
                                            }
                                            mi = mi + 1;
                                        }
                                    }
                                    if (td is BoundDefinition.enum_def) {
                                        let enum_d: BoundEnumDefinition = td.enum_def;
                                        let eii: mut i64 = 0;
                                        while (eii < cast<i64>(enum_d.interface_impls.size())) {
                                            let impl_def: BoundDefinition = enum_d.interface_impls.at(cast<u64>(eii)).some;
                                            if (impl_def is BoundDefinition.impl_def) {
                                                let iface_impl: BoundInterfaceImplementation = impl_def.impl_def;
                                                let eimi: mut i64 = 0;
                                                while (eimi < cast<i64>(iface_impl.methods.size())) {
                                                    let md: BoundDefinition = iface_impl.methods.at(cast<u64>(eimi)).some;
                                                    if (md is BoundDefinition.function_def) {
                                                        if (md.function_def.name == sym.function_sym.name) {
                                                            bt = md.function_def.return_type;
                                                        }
                                                    }
                                                    eimi = eimi + 1;
                                                }
                                            }
                                            eii = eii + 1;
                                        }
                                        let evi: mut i64 = 0;
                                        while (evi < cast<i64>(enum_d.vtables.size())) {
                                            let vtable: BoundVTable = enum_d.vtables.at(cast<u64>(evi)).some;
                                            let iface_type: BoundType = vtable.interface_type;
                                            if (iface_type.type_definition.is_some()) {
                                                let iface_def: BoundDefinition = iface_type.type_definition.some;
                                                if (iface_def is BoundDefinition.interface_def) {
                                                    let iface: BoundInterfaceDefinition = iface_def.interface_def;
                                                    let eimi: mut i64 = 0;
                                                    while (eimi < cast<i64>(iface.methods.size())) {
                                                        let md: BoundDefinition = iface.methods.at(cast<u64>(eimi)).some;
                                                        if (md is BoundDefinition.function_def) {
                                                            if (md.function_def.name == sym.function_sym.name) {
                                                                bt = md.function_def.return_type;
                                                            }
                                                        }
                                                        eimi = eimi + 1;
                                                    }
                                                }
                                            }
                                            evi = evi + 1;
                                        }
                                    }
                                }
                            }
                            let is_virt: mut bool = false;
                            let direct_disp: mut bool = false;
                            let direct_sym: mut Option<BoundSymbol> = ma_expr.member_symbol;
                            if (ma_expr.base_expr.is_some()) {
                                let base_type: BoundType = ma_expr.base_expr.some.get_bound_type();
                                if (base_type.kind is TypeKind.InterfaceKind) {
                                    // Check if this is a temporary box that can be elided:
                                    // cast<Interface>(value).method() → call method directly
                                    if (ma_expr.base_expr.some is BoundExpression.cast_expr) {
                                        let cast_e: BoundCastExpression = ma_expr.base_expr.some.cast_expr;
                                        if (cast_e.needs_boxing) {
                                            direct_disp = true;
                                            // Resolve the concrete implementation method from the value type's vtable
                                            if (cast_e.inner.is_some() && ma_expr.member_symbol.is_some()) {
                                                let inner_type: BoundType = cast_e.inner.some.get_bound_type();
                                                let resolved: Option<BoundFunctionSymbol> = this.resolve_implementation_method(inner_type, base_type, ma_expr.member_symbol.some);
                                                if (resolved.is_some()) {
                                                    direct_sym = new Option<BoundSymbol>.some(new BoundSymbol.function_sym(resolved.some));
                                                }
                                            }
                                        } else {
                                            is_virt = true;
                                        }
                                    } else {
                                        is_virt = true;
                                    }
                                }
                            }
                            let result: mut BoundFunctionCallExpression = new BoundFunctionCallExpression(bt, callee, direct_sym, args, is_virt, empty_generic_args, false);
                            if (direct_disp) {
                                result.direct_dispatch = true;
                            }
                            return new Option<BoundExpression>.some(new BoundExpression.function_call(result));
                        }
                    }
                }
                let result: mut BoundFunctionCallExpression = new BoundFunctionCallExpression(new BoundType(), callee, new Option<BoundSymbol>.none(), args, false, empty_generic_args, false);
                return new Option<BoundExpression>.some(new BoundExpression.function_call(result));
            }
        }
        let result: mut BoundFunctionCallExpression = new BoundFunctionCallExpression(new BoundType(), new Option<BoundExpression>.none(), new Option<BoundSymbol>.none(), args, false, empty_generic_args, false);
        return new Option<BoundExpression>.some(new BoundExpression.function_call(result));
    }

    fun bind_arguments(mut this, args: _utils.List<ast.Expression>, scope: mut BoundScope) -> mut _utils.List<BoundExpression> {
        let result: mut _utils.List<BoundExpression> = new _utils.List<BoundExpression>();
        let i: mut i64 = 0;
        while (i < cast<i64>(args.size())) {
            let bound_arg: Option<BoundExpression> = this.bind_expression(args.at(cast<u64>(i)).some, scope);
            if (bound_arg.is_some()) {
                result.push(bound_arg.some);
            }
            i = i + 1;
        }
        return result;
    }

    fun bind_if_expr(mut this, expr: ast.IfExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        let condition: Option<BoundExpression> = this.bind_optional_expr(expr.condition, scope);
        let then_block: Option<BoundExpression> = this.bind_optional_expr(expr.then_block, scope);
        let else_block: Option<BoundExpression> = this.bind_optional_expr(expr.else_block, scope);
        if (then_block.is_some()) {
            let bt: BoundType = then_block.some.get_bound_type();
            let result: mut BoundIfExpression = new BoundIfExpression(bt, condition, then_block, else_block);
            return new Option<BoundExpression>.some(new BoundExpression.if_expr(result));
        }
        let result: mut BoundIfExpression = new BoundIfExpression(new BoundType(), condition, then_block, else_block);
        return new Option<BoundExpression>.some(new BoundExpression.if_expr(result));
    }

    fun bind_while_expr(mut this, expr: ast.WhileExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        let condition: Option<BoundExpression> = this.bind_optional_expr(expr.condition, scope);
        let body: Option<BoundExpression> = this.bind_optional_expr(expr.body, scope);
        let result: mut BoundWhileExpression = new BoundWhileExpression(this.type_registry.void_type, condition, body);
        return new Option<BoundExpression>.some(new BoundExpression.while_expr(result));
    }

    fun bind_optional_expr(mut this, opt: Option<ast.Expression>, scope: mut BoundScope) -> Option<BoundExpression> {
        if (opt.is_some()) {
            return this.bind_expression(opt.some, scope);
        }
        return new Option<BoundExpression>.none();
    }

    fun bind_optional_stmt(mut this, opt: Option<ast.Statement>, scope: mut BoundScope) -> Option<BoundStatement> {
        if (opt.is_some()) {
            return this.bind_statement(opt.some, scope);
        }
        return new Option<BoundStatement>.none();
    }

    fun bind_code_block(mut this, expr: ast.CodeBlockExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        let block_scope: mut BoundScope = new BoundScope(new ScopeKind.BlockScope(), "<block>", scope.full_name + ".<block>", new Option<BoundScope>.some(scope));
        let stmts: mut _utils.List<BoundStatement> = new _utils.List<BoundStatement>();
        let i: mut i64 = 0;
        while (i < cast<i64>(expr.statements.size())) {
            let stmt: ast.Statement = expr.statements.at(cast<u64>(i)).some;
            let bound_stmt: Option<BoundStatement> = this.bind_statement(stmt, block_scope);
            if (bound_stmt.is_some()) {
                stmts.push(bound_stmt.some);
            }
            i = i + 1;
        }
        if (expr.trailing_expr.is_some()) {
            let trailing: Option<BoundExpression> = this.bind_expression(expr.trailing_expr.some, block_scope);
            if (trailing.is_some()) {
                let bt: BoundType = trailing.some.get_bound_type();
                let result: mut BoundCodeBlockExpression = new BoundCodeBlockExpression(bt, stmts, trailing, new Option<BoundScope>.some(block_scope));
                return new Option<BoundExpression>.some(new BoundExpression.code_block(result));
            }
        }
        let result: mut BoundCodeBlockExpression = new BoundCodeBlockExpression(this.type_registry.void_type, stmts, new Option<BoundExpression>.none(), new Option<BoundScope>.some(block_scope));
        return new Option<BoundExpression>.some(new BoundExpression.code_block(result));
    }

    // Look up the concrete implementation method from a value type's vtable.
    // Given the inner (concrete) type, the interface type, and the interface method symbol,
    // find the corresponding implementation method in the class/enum definition's vtable.
    fun resolve_implementation_method(this, inner_type: BoundType, iface_type: BoundType, iface_method_sym: BoundSymbol) -> Option<BoundFunctionSymbol> {
        if (iface_method_sym is BoundSymbol.function_sym) {
            let method_name: string = iface_method_sym.function_sym.name;
            if (inner_type.type_definition.is_some()) {
                let def: BoundDefinition = inner_type.type_definition.some;
                // Class value type
                if (def is BoundDefinition.class_def) {
                    let class_def: BoundClassDefinition = def.class_def;
                    let vi: mut i64 = 0;
                    while (vi < cast<i64>(class_def.vtables.size())) {
                        let vtable: BoundVTable = class_def.vtables.at(cast<u64>(vi)).some;
                        if (vtable.interface_type.display_name() == iface_type.display_name()) {
                            let si: mut i64 = 0;
                            while (si < cast<i64>(vtable.slots.size())) {
                                let slot: BoundVTableSlot = vtable.slots.at(cast<u64>(si)).some;
                                if (slot.interface_method.is_some()) {
                                    if (slot.interface_method.some.name == method_name) {
                                        return slot.implementation_method;
                                    }
                                }
                                si = si + 1;
                            }
                        }
                        vi = vi + 1;
                    }
                }
                // Enum type
                if (def is BoundDefinition.enum_def) {
                    let enum_def: BoundEnumDefinition = def.enum_def;
                    let vi: mut i64 = 0;
                    while (vi < cast<i64>(enum_def.vtables.size())) {
                        let vtable: BoundVTable = enum_def.vtables.at(cast<u64>(vi)).some;
                        if (vtable.interface_type.display_name() == iface_type.display_name()) {
                            let si: mut i64 = 0;
                            while (si < cast<i64>(vtable.slots.size())) {
                                let slot: BoundVTableSlot = vtable.slots.at(cast<u64>(si)).some;
                                if (slot.interface_method.is_some()) {
                                    if (slot.interface_method.some.name == method_name) {
                                        return slot.implementation_method;
                                    }
                                }
                                si = si + 1;
                            }
                        }
                        vi = vi + 1;
                    }
                }
            }
        }
        return new Option<BoundFunctionSymbol>.none();
    }

    fun bind_cast(mut this, expr: ast.CastExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        let target_type: BoundType = this.resolve_type_name(expr.type_name, scope);
        let inner: Option<BoundExpression> = this.bind_optional_expr(expr.inner, scope);
        let result: mut BoundCastExpression = new BoundCastExpression(target_type, target_type, inner, false);

        if (inner.is_some()) {
            let inner_type: BoundType = inner.some.get_bound_type();
            // Boxing: value type (class or enum) → interface
            if (target_type.kind is bound.TypeKind.InterfaceKind) {
                if (inner_type.is_value_type()) {
                    result.needs_boxing = true;
                    result.source_type_name = this.get_concrete_type_name(inner_type);
                }
            }
            // Unboxing: interface → value type (class or enum)
            if (inner_type.kind is bound.TypeKind.InterfaceKind) {
                if (target_type.is_value_type()) {
                    result.needs_unboxing = true;
                    result.source_type_name = this.get_concrete_type_name(target_type);
                }
            }
        }

        return new Option<BoundExpression>.some(new BoundExpression.cast_expr(result));
    }

    fun get_concrete_type_name(this, bt: bound.BoundType) -> string {
        if (bt.type_definition.is_some()) {
            return bt.type_definition.some.get_name();
        }
        return bt.display_name();
    }

    fun resolve_new_generic_args(this, expr: ast.NewExpression, scope: BoundScope, bt: BoundType) -> mut BoundType {
        if (cast<i64>(expr.generic_args.size()) > 0) {
            let args: mut _utils.List<BoundType> = new _utils.List<BoundType>();
            let k: mut i64 = 0;
            while (k < cast<i64>(expr.generic_args.size())) {
                args.push(this.resolve_type_specifier(expr.generic_args.at(cast<u64>(k)).some, scope));
                k = k + 1;
            }
            return bt.with_generic_args(args);
        }
        return bt;
    }

    fun resolve_type_by_name(this, name: string, scope: mut BoundScope) -> Option<BoundSymbol> {
        let dot_idx: i64 = string_find(name, ".");
        if (dot_idx < 0) {
            return scope.lookup_type_in_scope(name);
        }
        // Split dotted name into parts and use resolve_qualified which traverses parent scopes
        let parts: mut _utils.List<string> = new _utils.List<string>();
        let pos: mut i64 = 0;
        let len: i64 = string_length(name);
        while (pos < len) {
            let next_dot: i64 = string_find_from(name, ".", pos);
            if (next_dot < 0) {
                parts.push(string_substring(name, pos, len - pos));
                pos = len;
            } else {
                parts.push(string_substring(name, pos, next_dot - pos));
                pos = next_dot + 1;
            }
        }
        return scope.resolve_qualified(parts);
    }

    fun find_last_dot(mut this, s: string) -> i64 {
        let len: i64 = string_length(s);
        let last_dot: mut i64 = -1;
        let si: mut i64 = 0;
        while (si < len) {
            let ch: string = string_char_at(s, si);
            if (ch == ".") {
                last_dot = si;
            }
            si = si + 1;
        }
        return last_dot;
    }

    fun try_bind_enum_variant(mut this, expr: ast.NewExpression, scope: mut BoundScope, last_dot: i64) -> Option<BoundExpression> {
        let len: i64 = string_length(expr.type_name);
        let enum_name: string = string_substring(expr.type_name, 0, last_dot);
        let variant_name: string = string_substring(expr.type_name, last_dot + 1, len - last_dot - 1);
        let enum_sym: Option<BoundSymbol> = this.resolve_type_by_name(enum_name, scope);
        if (enum_sym.is_some()) {
            if (enum_sym.some is BoundSymbol.type_sym) {
                let bt: mut BoundType = this.resolve_new_generic_args(expr, scope, enum_sym.some.type_sym.bound_type);
                if (bt.kind is TypeKind.EnumKind && bt.type_definition.is_some()) {
                    let def: BoundDefinition = bt.type_definition.some;
                    if (def is BoundDefinition.enum_def) {
                        let enum_def: BoundEnumDefinition = def.enum_def;
                        let i: mut i64 = 0;
                        while (i < cast<i64>(enum_def.members.size())) {
                            let member: BoundEnumMemberDefinition = enum_def.members.at(cast<u64>(i)).some;
                            if (member.name == variant_name) {
                                let payload: Option<BoundExpression> = new Option<BoundExpression>.none();
                                if (cast<i64>(expr.arguments.size()) > 0) {
                                    let arg: Option<BoundExpression> = this.bind_expression(expr.arguments.at(cast<u64>(0)).some, scope);
                                    if (arg.is_some()) {
                                        let result: mut BoundEnumVariantExpression = new BoundEnumVariantExpression(bt, bt, variant_name, i, member.member_symbol, arg);
                                        return new Option<BoundExpression>.some(new BoundExpression.enum_variant(result));
                                    }
                                }
                                let result: mut BoundEnumVariantExpression = new BoundEnumVariantExpression(bt, bt, variant_name, i, member.member_symbol, payload);
                                return new Option<BoundExpression>.some(new BoundExpression.enum_variant(result));
                            }
                            i = i + 1;
                        }
                    }
                }
            }
        }
        return new Option<BoundExpression>.none();
    }

    fun bind_new_expr(mut this, expr: ast.NewExpression, scope: mut BoundScope) -> Option<BoundExpression> {
        // First, try to resolve the full type_name as a class/struct type
        let type_sym: Option<BoundSymbol> = this.resolve_type_by_name(expr.type_name, scope);
        if (type_sym.is_some()) {
            if (type_sym.some is BoundSymbol.type_sym) {
                let bt: mut BoundType = this.resolve_new_generic_args(expr, scope, type_sym.some.type_sym.bound_type);
                // If this is an enum type, the full name was a type, not a variant — just instantiate
                let args: mut _utils.List<BoundExpression> = new _utils.List<BoundExpression>();
                let i: mut i64 = 0;
                while (i < cast<i64>(expr.arguments.size())) {
                    let bound_arg: Option<BoundExpression> = this.bind_expression(expr.arguments.at(cast<u64>(i)).some, scope);
                    if (bound_arg.is_some()) {
                        args.push(bound_arg.some);
                    }
                    i = i + 1;
                }
                let result: mut BoundNewExpression = new BoundNewExpression(bt, new Option<BoundTypeSymbol>.some(type_sym.some.type_sym), new Option<BoundFunctionSymbol>.none(), args);
                return new Option<BoundExpression>.some(new BoundExpression.new_expr(result));
            }
        }

        // If not found as a type, try as an enum variant (e.g., "Option.some" → enum Option, variant some)
        let last_dot: i64 = this.find_last_dot(expr.type_name);
        if (last_dot >= 0) {
            let enum_result: Option<BoundExpression> = this.try_bind_enum_variant(expr, scope, last_dot);
            if (enum_result.is_some()) {
                return enum_result;
            }
        }

        // Fallback: create with unresolved type
        let args: mut _utils.List<BoundExpression> = new _utils.List<BoundExpression>();
        let i: mut i64 = 0;
        while (i < cast<i64>(expr.arguments.size())) {
            let bound_arg: Option<BoundExpression> = this.bind_expression(expr.arguments.at(cast<u64>(i)).some, scope);
            if (bound_arg.is_some()) {
                args.push(bound_arg.some);
            }
            i = i + 1;
        }
        let result: mut BoundNewExpression = new BoundNewExpression(new BoundType(), new Option<BoundTypeSymbol>.none(), new Option<BoundFunctionSymbol>.none(), args);
        return new Option<BoundExpression>.some(new BoundExpression.new_expr(result));
    }

    fun bind_statement(mut this, stmt: ast.Statement, scope: mut BoundScope) -> Option<BoundStatement> {
        if (stmt is ast.Statement.expression) {
            if (stmt.expression.expression.is_some()) {
                let bound_expr: Option<BoundExpression> = this.bind_expression(stmt.expression.expression.some, scope);
                let result: mut BoundExpressionStatement = new BoundExpressionStatement(bound_expr);
                return new Option<BoundStatement>.some(new BoundStatement.expression(result));
            }
            let result: mut BoundExpressionStatement = new BoundExpressionStatement(new Option<BoundExpression>.none());
            return new Option<BoundStatement>.some(new BoundStatement.expression(result));
        }
        if (stmt is ast.Statement.block_expr) {
            if (stmt.block_expr.expression.is_some()) {
                let bound_expr: Option<BoundExpression> = this.bind_expression(stmt.block_expr.expression.some, scope);
                if (bound_expr.is_some()) {
                    if (bound_expr.some is BoundExpression.code_block) {
                        let cb: BoundCodeBlockExpression = bound_expr.some.code_block;
                        let block_stmts: mut _utils.List<BoundStatement> = new _utils.List<BoundStatement>();
                        let i: mut i64 = 0;
                        while (i < cast<i64>(cb.statements.size())) {
                            block_stmts.push(cb.statements.at(cast<u64>(i)).some);
                            i = i + 1;
                        }
                        let result: mut BoundBlockStatement = new BoundBlockStatement(block_stmts, cb.scope);
                        return new Option<BoundStatement>.some(new BoundStatement.block(result));
                    }
                    let result: mut BoundExpressionStatement = new BoundExpressionStatement(bound_expr);
                    return new Option<BoundStatement>.some(new BoundStatement.expression(result));
                }
            }
        }
        if (stmt is ast.Statement.assignment) {
            if (stmt.assignment.target.is_some()) {
                let target: Option<BoundExpression> = this.bind_expression(stmt.assignment.target.some, scope);
                if (stmt.assignment.value.is_some()) {
                    let value: Option<BoundExpression> = this.bind_expression(stmt.assignment.value.some, scope);
                    let value_type: BoundType = target.some.get_bound_type();
                    if (target.some is bound.BoundExpression.identifier) {
                        if (target.some.identifier.symbol.is_some()) {
                            let result: mut BoundAssignmentStatement = new BoundAssignmentStatement(target, target.some.identifier.symbol, stmt.assignment.operator_value, value, value_type);
                            return new Option<BoundStatement>.some(new BoundStatement.assignment(result));
                        }
                    }
                    let result: mut BoundAssignmentStatement = new BoundAssignmentStatement(target, new Option<BoundSymbol>.none(), stmt.assignment.operator_value, value, value_type);
                    return new Option<BoundStatement>.some(new BoundStatement.assignment(result));
                }
                let value_type: BoundType = target.some.get_bound_type();
                let result: mut BoundAssignmentStatement = new BoundAssignmentStatement(target, new Option<BoundSymbol>.none(), stmt.assignment.operator_value, new Option<BoundExpression>.none(), value_type);
                return new Option<BoundStatement>.some(new BoundStatement.assignment(result));
            }
            if (stmt.assignment.value.is_some()) {
                let value: Option<BoundExpression> = this.bind_expression(stmt.assignment.value.some, scope);
                let result: mut BoundAssignmentStatement = new BoundAssignmentStatement(new Option<BoundExpression>.none(), new Option<BoundSymbol>.none(), stmt.assignment.operator_value, value, new BoundType());
                return new Option<BoundStatement>.some(new BoundStatement.assignment(result));
            }
            let result: mut BoundAssignmentStatement = new BoundAssignmentStatement(new Option<BoundExpression>.none(), new Option<BoundSymbol>.none(), stmt.assignment.operator_value, new Option<BoundExpression>.none(), new BoundType());
            return new Option<BoundStatement>.some(new BoundStatement.assignment(result));
        }
        if (stmt is ast.Statement.if_stmt) {
            let condition: Option<BoundExpression> = this.bind_optional_expr(stmt.if_stmt.condition, scope);
            let then_stmt: Option<BoundStatement> = this.bind_optional_stmt(stmt.if_stmt.then_statement, scope);
            let else_stmt: Option<BoundStatement> = this.bind_optional_stmt(stmt.if_stmt.else_statement, scope);
            let result: mut BoundIfStatement = new BoundIfStatement(condition, then_stmt, else_stmt);
            return new Option<BoundStatement>.some(new BoundStatement.if_stmt(result));
        }
        if (stmt is ast.Statement.while_stmt) {
            let condition: Option<BoundExpression> = this.bind_optional_expr(stmt.while_stmt.condition, scope);
            let body: Option<BoundStatement> = this.bind_optional_stmt(stmt.while_stmt.body, scope);
            let result: mut BoundWhileStatement = new BoundWhileStatement(condition, body);
            return new Option<BoundStatement>.some(new BoundStatement.while_stmt(result));
        }
        if (stmt is ast.Statement.return_stmt) {
            if (stmt.return_stmt.value.is_some()) {
                let value: Option<BoundExpression> = this.bind_expression(stmt.return_stmt.value.some, scope);
                if (value.is_some()) {
                    let ret_type: BoundType = value.some.get_bound_type();
                    let result: mut BoundReturnStatement = new BoundReturnStatement(value, ret_type);
                    return new Option<BoundStatement>.some(new BoundStatement.return_stmt(result));
                }
            }
            let result: mut BoundReturnStatement = new BoundReturnStatement(new Option<BoundExpression>.none(), new BoundType());
            return new Option<BoundStatement>.some(new BoundStatement.return_stmt(result));
        }
        if (stmt is ast.Statement.break_stmt) {
            if (stmt.break_stmt.value.is_some()) {
                let value: Option<BoundExpression> = this.bind_expression(stmt.break_stmt.value.some, scope);
                let result: mut BoundBreakStatement = new BoundBreakStatement(value);
                return new Option<BoundStatement>.some(new BoundStatement.break_stmt(result));
            }
            let result: mut BoundBreakStatement = new BoundBreakStatement(new Option<BoundExpression>.none());
            return new Option<BoundStatement>.some(new BoundStatement.break_stmt(result));
        }
        if (stmt is ast.Statement.continue_stmt) {
            let result: mut BoundContinueStatement = new BoundContinueStatement();
            return new Option<BoundStatement>.some(new BoundStatement.continue_stmt(result));
        }
        if (stmt is ast.Statement.let_decl) {
            let var_sym: mut BoundVariableSymbol = new BoundVariableSymbol();
            var_sym.name = stmt.let_decl.variable_name;
            var_sym.full_name = scope.full_name + "." + stmt.let_decl.variable_name;
            var_sym.is_mutable = stmt.let_decl.is_mutable;
            if (stmt.let_decl.initializer.is_some()) {
                let initializer: Option<BoundExpression> = this.bind_expression(stmt.let_decl.initializer.some, scope);
                if (initializer.is_some()) {
                    let decl_type: mut BoundType = initializer.some.get_bound_type();
                    var_sym.bound_type = decl_type;
                    let result: mut BoundLetDeclarationStatement = new BoundLetDeclarationStatement(
                        new Option<BoundVariableSymbol>.some(var_sym),
                        initializer, decl_type, new Option<BoundScope>.some(scope));
                    scope.add_symbol(new BoundSymbol.variable(var_sym));
                    return new Option<BoundStatement>.some(new BoundStatement.let_decl(result));
                }
            }
            let result: mut BoundLetDeclarationStatement = new BoundLetDeclarationStatement(
                new Option<BoundVariableSymbol>.some(var_sym),
                new Option<BoundExpression>.none(), new BoundType(), new Option<BoundScope>.some(scope));
            scope.add_symbol(new BoundSymbol.variable(var_sym));
            return new Option<BoundStatement>.some(new BoundStatement.let_decl(result));
        }
        return new Option<BoundStatement>.none();
    }

    // --- Pass 7: Validate Control Flow ---

    fun pass_validate_control_flow(mut this, result: BoundCompilationUnit) {
        let i: mut i64 = 0;
        while (i < cast<i64>(result.definitions.size())) {
            let def: BoundDefinition = result.definitions.at(cast<u64>(i)).some;
            this.validate_control_flow_for_def(def);
            i = i + 1;
        }
    }

    fun validate_control_flow_for_def(mut this, def: BoundDefinition) {
        if (def is BoundDefinition.function_def) {
            let func: BoundFunctionDefinition = def.function_def;
            if (func.body.is_some() && func.symbol.is_some()) {
                let sym: BoundFunctionSymbol = func.symbol.some;
                this._current_validating_func = func.name;
                this.validate_expr_control_flow(func.body.some, sym.return_type, 0);
                if (!this.type_registry.is_void(sym.return_type)) {
                    if (!this.expr_always_returns(func.body.some)) {
                        this.report_error("Non-void function '" + func.name + "' must return a value on all paths", 0, 0);
                    }
                }
            }
        }
        if (def is BoundDefinition.initial_routine) {
            let init: BoundInitialRoutineDefinition = def.initial_routine;
            if (init.body.is_some()) {
                this.validate_expr_control_flow(init.body.some, this.type_registry.void_type, 0);
            }
        }
        if (def is BoundDefinition.class_def) {
            let cls: BoundClassDefinition = def.class_def;
            let j: mut i64 = 0;
            while (j < cast<i64>(cls.methods.size())) {
                let md: BoundDefinition = cls.methods.at(cast<u64>(j)).some;
                this.validate_control_flow_for_def(md);
                j = j + 1;
            }
        }
        if (def is BoundDefinition.namespace_def) {
            let ns: BoundNamespaceDefinition = def.namespace_def;
            let j: mut i64 = 0;
            while (j < cast<i64>(ns.children.size())) {
                let child: BoundDefinition = ns.children.at(cast<u64>(j)).some;
                this.validate_control_flow_for_def(child);
                j = j + 1;
            }
        }
    }

    fun validate_expr_control_flow(mut this, expr: BoundExpression, ret_type: BoundType, loop_depth: i64) {
        if (expr is BoundExpression.code_block) {
            let cb: BoundCodeBlockExpression = expr.code_block;
            let i: mut i64 = 0;
            while (i < cast<i64>(cb.statements.size())) {
                this.validate_stmt_control_flow(cb.statements.at(cast<u64>(i)).some, ret_type, loop_depth);
                i = i + 1;
            }
        }
        if (expr is BoundExpression.if_expr) {
            let if_e: BoundIfExpression = expr.if_expr;
            if (if_e.condition.is_some()) { this.validate_expr_control_flow(if_e.condition.some, ret_type, loop_depth); }
            if (if_e.then_block.is_some()) { this.validate_expr_control_flow(if_e.then_block.some, ret_type, loop_depth); }
            if (if_e.else_block.is_some()) { this.validate_expr_control_flow(if_e.else_block.some, ret_type, loop_depth); }
        }
        if (expr is BoundExpression.while_expr) {
            let w: BoundWhileExpression = expr.while_expr;
            if (w.condition.is_some()) { this.validate_expr_control_flow(w.condition.some, ret_type, loop_depth); }
            if (w.body.is_some()) { this.validate_expr_control_flow(w.body.some, ret_type, loop_depth + 1); }
        }
        if (expr is BoundExpression.binary) {
            let bin: BoundBinaryExpression = expr.binary;
            let i: mut i64 = 0;
            while (i < cast<i64>(bin.operands.size())) {
                this.validate_expr_control_flow(bin.operands.at(cast<u64>(i)).some, ret_type, loop_depth);
                i = i + 1;
            }
        }
        if (expr is BoundExpression.unary) {
            let un: BoundUnaryExpression = expr.unary;
            if (un.operand.is_some()) { this.validate_expr_control_flow(un.operand.some, ret_type, loop_depth); }
        }
        if (expr is BoundExpression.function_call) {
            let fc: BoundFunctionCallExpression = expr.function_call;
            if (fc.callee.is_some()) { this.validate_expr_control_flow(fc.callee.some, ret_type, loop_depth); }
            let i: mut i64 = 0;
            while (i < cast<i64>(fc.arguments.size())) {
                this.validate_expr_control_flow(fc.arguments.at(cast<u64>(i)).some, ret_type, loop_depth);
                i = i + 1;
            }
        }
        if (expr is BoundExpression.member_access) {
            let ma: BoundMemberAccessExpression = expr.member_access;
            if (ma.base_expr.is_some()) { this.validate_expr_control_flow(ma.base_expr.some, ret_type, loop_depth); }
        }
        if (expr is BoundExpression.cast_expr) {
            let c: BoundCastExpression = expr.cast_expr;
            if (c.inner.is_some()) { this.validate_expr_control_flow(c.inner.some, ret_type, loop_depth); }
        }
        if (expr is BoundExpression.new_expr) {
            let ne: BoundNewExpression = expr.new_expr;
            let i: mut i64 = 0;
            while (i < cast<i64>(ne.arguments.size())) {
                this.validate_expr_control_flow(ne.arguments.at(cast<u64>(i)).some, ret_type, loop_depth);
                i = i + 1;
            }
        }
        if (expr is BoundExpression.enum_variant) {
            let ev: BoundEnumVariantExpression = expr.enum_variant;
            if (ev.payload.is_some()) {
                this.validate_expr_control_flow(ev.payload.some, ret_type, loop_depth);
            }
        }
    }

    fun validate_stmt_control_flow(mut this, stmt: BoundStatement, ret_type: BoundType, loop_depth: i64) {
        if (stmt is BoundStatement.return_stmt) {
            let ret: BoundReturnStatement = stmt.return_stmt;
            if (ret.value.is_some()) {
                this.validate_expr_control_flow(ret.value.some, ret_type, loop_depth);
                let value_type: BoundType = ret.value.some.get_bound_type();
                if (!this.type_registry.is_void(ret_type) && !this.type_registry.can_implicitly_cast(value_type, ret_type)) {
                    this.report_error("Return type mismatch: expected " + ret_type.display_name() + " but got " + value_type.display_name() + " in " + this._current_validating_func, 0, 0);
                }
            }
        }
        if (stmt is BoundStatement.expression) {
            if (stmt.expression.expression.is_some()) {
                this.validate_expr_control_flow(stmt.expression.expression.some, ret_type, loop_depth);
            }
        }
        if (stmt is BoundStatement.block) {
            let block: BoundBlockStatement = stmt.block;
            let i: mut i64 = 0;
            while (i < cast<i64>(block.statements.size())) {
                this.validate_stmt_control_flow(block.statements.at(cast<u64>(i)).some, ret_type, loop_depth);
                i = i + 1;
            }
        }
        if (stmt is BoundStatement.if_stmt) {
            let if_s: BoundIfStatement = stmt.if_stmt;
            if (if_s.condition.is_some()) { this.validate_expr_control_flow(if_s.condition.some, ret_type, loop_depth); }
            if (if_s.then_statement.is_some()) { this.validate_stmt_control_flow(if_s.then_statement.some, ret_type, loop_depth); }
            if (if_s.else_statement.is_some()) { this.validate_stmt_control_flow(if_s.else_statement.some, ret_type, loop_depth); }
        }
        if (stmt is BoundStatement.while_stmt) {
            let ws: BoundWhileStatement = stmt.while_stmt;
            if (ws.condition.is_some()) { this.validate_expr_control_flow(ws.condition.some, ret_type, loop_depth); }
            if (ws.body.is_some()) { this.validate_stmt_control_flow(ws.body.some, ret_type, loop_depth + 1); }
        }
        if (stmt is BoundStatement.break_stmt) {
            if (loop_depth == 0) {
                this.report_error("break statement not inside a loop", 0, 0);
            }
        }
        if (stmt is BoundStatement.continue_stmt) {
            if (loop_depth == 0) {
                this.report_error("continue statement not inside a loop", 0, 0);
            }
        }
        if (stmt is BoundStatement.assignment) {
            let assign: BoundAssignmentStatement = stmt.assignment;
            if (assign.target.is_some()) { this.validate_expr_control_flow(assign.target.some, ret_type, loop_depth); }
            if (assign.value.is_some()) { this.validate_expr_control_flow(assign.value.some, ret_type, loop_depth); }
        }
        if (stmt is BoundStatement.let_decl) {
            let let_s: BoundLetDeclarationStatement = stmt.let_decl;
            if (let_s.initializer.is_some()) { this.validate_expr_control_flow(let_s.initializer.some, ret_type, loop_depth); }
        }
    }

    fun expr_always_returns(this, expr: BoundExpression) -> bool {
        if (expr is BoundExpression.code_block) {
            let cb: BoundCodeBlockExpression = expr.code_block;
            if (cast<i64>(cb.statements.size()) == 0) { return false; }
            let last_idx: i64 = cast<i64>(cb.statements.size()) - 1;
            let last: BoundStatement = cb.statements.at(cast<u64>(last_idx)).some;
            return this.stmt_always_returns(last);
        }
        return false;
    }

    fun stmt_always_returns(this, stmt: BoundStatement) -> bool {
        if (stmt is BoundStatement.return_stmt) { return true; }
        if (stmt is BoundStatement.expression) {
            if (stmt.expression.expression.is_some()) {
                let expr: BoundExpression = stmt.expression.expression.some;
                if (expr is BoundExpression.if_expr) {
                    let if_e: BoundIfExpression = expr.if_expr;
                    if (if_e.then_block.is_some() && if_e.else_block.is_some()) {
                        return this.expr_always_returns(if_e.then_block.some) && this.expr_always_returns(if_e.else_block.some);
                    }
                }
                if (expr is BoundExpression.while_expr) {
                    let w: BoundWhileExpression = expr.while_expr;
                    if (this.is_literal_true(w.condition) && w.body.is_some()) {
                        return this.expr_always_returns(w.body.some);
                    }
                }
            }
        }
        if (stmt is BoundStatement.if_stmt) {
            let if_s: BoundIfStatement = stmt.if_stmt;
            if (if_s.then_statement.is_some() && if_s.else_statement.is_some()) {
                return this.stmt_always_returns(if_s.then_statement.some) && this.stmt_always_returns(if_s.else_statement.some);
            }
        }
        if (stmt is BoundStatement.while_stmt) {
            let ws: BoundWhileStatement = stmt.while_stmt;
            if (this.is_stmt_condition_literal_true(ws.condition) && ws.body.is_some()) {
                return this.stmt_always_returns(ws.body.some);
            }
        }
        if (stmt is BoundStatement.block) {
            let block: BoundBlockStatement = stmt.block;
            if (cast<i64>(block.statements.size()) == 0) { return false; }
            let last_idx: i64 = cast<i64>(block.statements.size()) - 1;
            return this.stmt_always_returns(block.statements.at(cast<u64>(last_idx)).some);
        }
        return false;
    }

    fun is_literal_true(this, opt: Option<BoundExpression>) -> bool {
        if (opt.is_none()) { return false; }
        let expr: BoundExpression = opt.some;
        if (expr is BoundExpression.literal) {
            if (expr.literal.literal_kind is LiteralKind.BoolLiteral && expr.literal.value == "true") {
                return true;
            }
        }
        return false;
    }

    fun is_stmt_condition_literal_true(this, opt: Option<BoundExpression>) -> bool {
        return this.is_literal_true(opt);
    }

    fun collect_function_instantiations_from_ast(this, defs: _utils.List<ast.Definition>, scope: BoundScope, func_instantiations: mut _utils.List<FunctionInstantiation>) {
        let i: mut i64 = 0;
        while (i < cast<i64>(defs.size())) {
            let def: ast.Definition = defs.at(cast<u64>(i)).some;
            if (def is ast.Definition.initial_routine) {
                if (def.initial_routine.body.is_some()) {
                    this.collect_func_inst_from_expr(def.initial_routine.body.some, scope, func_instantiations);
                }
            }
            if (def is ast.Definition.function_def) {
                if (def.function_def.body.is_some()) {
                    this.collect_func_inst_from_expr(def.function_def.body.some, scope, func_instantiations);
                }
            }
            if (def is ast.Definition.namespace_def) {
                this.collect_function_instantiations_from_ast(def.namespace_def.children, scope, func_instantiations);
            }
            if (def is ast.Definition.class_def) {
                if (def.class_def.template_decl.is_none()) {
                    let members: _utils.List<ast.Definition> = def.class_def.members;
                    let mi: mut i64 = 0;
                    while (mi < cast<i64>(members.size())) {
                        let member: ast.Definition = members.at(cast<u64>(mi)).some;
                        if (member is ast.Definition.function_def) {
                            if (member.function_def.body.is_some()) {
                                this.collect_func_inst_from_expr(member.function_def.body.some, scope, func_instantiations);
                            }
                        }
                        mi = mi + 1;
                    }
                }
            }
            i = i + 1;
        }
    }

    fun collect_func_inst_from_expr(this, expr: ast.Expression, scope: BoundScope, func_instantiations: mut _utils.List<FunctionInstantiation>) {
        if (expr is ast.Expression.function_call) {
            let fc: ast.FunctionCallExpression = expr.function_call;
            if (fc.callee.is_some()) {
                let ast_callee: ast.Expression = fc.callee.some;
                if (ast_callee is ast.Expression.identifier) {
                    if (cast<i64>(ast_callee.identifier.generic_args.size()) > 0) {
                        let func_name: string = ast_callee.identifier.name;
                        let resolved_args: mut _utils.List<BoundType> = new _utils.List<BoundType>();
                        let gi: mut i64 = 0;
                        while (gi < cast<i64>(ast_callee.identifier.generic_args.size())) {
                            resolved_args.push(this.resolve_type_specifier(ast_callee.identifier.generic_args.at(cast<u64>(gi)).some, scope));
                            gi = gi + 1;
                        }
                        func_instantiations.push(new FunctionInstantiation(func_name, resolved_args));
                    }
                }
                // Generic method calls: obj.method<T>(args)
                if (ast_callee is ast.Expression.member_access) {
                    if (cast<i64>(ast_callee.member_access.generic_args.size()) > 0) {
                        let func_name: string = ast_callee.member_access.member_name;
                        let resolved_args: mut _utils.List<BoundType> = new _utils.List<BoundType>();
                        let gi: mut i64 = 0;
                        while (gi < cast<i64>(ast_callee.member_access.generic_args.size())) {
                            resolved_args.push(this.resolve_type_specifier(ast_callee.member_access.generic_args.at(cast<u64>(gi)).some, scope));
                            gi = gi + 1;
                        }
                        func_instantiations.push(new FunctionInstantiation(func_name, resolved_args));
                    }
                }
                this.collect_func_inst_from_expr(fc.callee.some, scope, func_instantiations);
            }
            let ai: mut i64 = 0;
            while (ai < cast<i64>(fc.arguments.size())) {
                this.collect_func_inst_from_expr(fc.arguments.at(cast<u64>(ai)).some, scope, func_instantiations);
                ai = ai + 1;
            }
        }
        if (expr is ast.Expression.code_block) {
            let blk: ast.CodeBlockExpression = expr.code_block;
            let si: mut i64 = 0;
            while (si < cast<i64>(blk.statements.size())) {
                let stmt: ast.Statement = blk.statements.at(cast<u64>(si)).some;
                if (stmt is ast.Statement.let_decl) {
                    if (stmt.let_decl.initializer.is_some()) {
                        this.collect_func_inst_from_expr(stmt.let_decl.initializer.some, scope, func_instantiations);
                    }
                }
                if (stmt is ast.Statement.expression) {
                    if (stmt.expression.expression.is_some()) {
                        this.collect_func_inst_from_expr(stmt.expression.expression.some, scope, func_instantiations);
                    }
                }
                si = si + 1;
            }
        }
        if (expr is ast.Expression.cast_expr) {
            if (expr.cast_expr.inner.is_some()) {
                this.collect_func_inst_from_expr(expr.cast_expr.inner.some, scope, func_instantiations);
            }
        }
        if (expr is ast.Expression.member_access) {
            if (expr.member_access.base_expr.is_some()) {
                this.collect_func_inst_from_expr(expr.member_access.base_expr.some, scope, func_instantiations);
            }
        }
        if (expr is ast.Expression.if_expr) {
            if (expr.if_expr.condition.is_some()) {
                this.collect_func_inst_from_expr(expr.if_expr.condition.some, scope, func_instantiations);
            }
            if (expr.if_expr.then_block.is_some()) {
                this.collect_func_inst_from_expr(expr.if_expr.then_block.some, scope, func_instantiations);
            }
            if (expr.if_expr.else_block.is_some()) {
                this.collect_func_inst_from_expr(expr.if_expr.else_block.some, scope, func_instantiations);
            }
        }
        if (expr is ast.Expression.binary) {
            let bin: ast.BinaryExpression = expr.binary;
            let oi: mut i64 = 0;
            while (oi < cast<i64>(bin.operands.size())) {
                this.collect_func_inst_from_expr(bin.operands.at(cast<u64>(oi)).some, scope, func_instantiations);
                oi = oi + 1;
            }
        }
        if (expr is ast.Expression.unary) {
            if (expr.unary.operand.is_some()) {
                this.collect_func_inst_from_expr(expr.unary.operand.some, scope, func_instantiations);
            }
        }
        if (expr is ast.Expression.new_expr) {
            let ne: ast.NewExpression = expr.new_expr;
            let ai: mut i64 = 0;
            while (ai < cast<i64>(ne.arguments.size())) {
                this.collect_func_inst_from_expr(ne.arguments.at(cast<u64>(ai)).some, scope, func_instantiations);
                ai = ai + 1;
            }
        }
    }

    fun find_bound_function_def(this, defs: _utils.List<BoundDefinition>, name: string) -> Option<BoundDefinition> {
        let i: mut i64 = 0;
        while (i < cast<i64>(defs.size())) {
            let def: BoundDefinition = defs.at(cast<u64>(i)).some;
            if (def is BoundDefinition.function_def) {
                if (def.function_def.name == name) {
                    return new Option<BoundDefinition>.some(def);
                }
            }
            if (def is BoundDefinition.namespace_def) {
                let found: Option<BoundDefinition> = this.find_bound_function_def(def.namespace_def.children, name);
                if (found.is_some()) { return found; }
            }
            if (def is BoundDefinition.class_def) {
                let found: Option<BoundDefinition> = this.find_bound_function_def(def.class_def.methods, name);
                if (found.is_some()) { return found; }
            }
            i = i + 1;
        }
        return new Option<BoundDefinition>.none();
    }

    fun specialize_function_def(mut this, tmpl: BoundFunctionDefinition, type_args: _utils.List<BoundType>, mangled_name: string, parent_scope: mut BoundScope, class_scope: Option<BoundScope>) -> Option<BoundDefinition> {
        let ast_def: Option<ast.Definition> = this.find_ast_def_by_name(this.ast_definitions, tmpl.name);
        if (ast_def.is_none()) { return new Option<BoundDefinition>.none(); }
        if (!(ast_def.some is ast.Definition.function_def)) { return new Option<BoundDefinition>.none(); }

        let ast_func: ast.FunctionDefinition = ast_def.some.function_def;
        // Build the full_name:
        // - For methods in specialized generic classes, use the class_scope's full_name
        //   e.g. <global>.Foo__i32.foo__i64 (not <global>.Foo.foo__i64)
        // - For other methods, use the template's full_name with name replaced
        //   e.g. <global>.Foo.identity -> <global>.Foo.identity__string
        let full_name: string = this.build_specialized_full_name(tmpl, mangled_name, class_scope);
        let result: mut BoundFunctionDefinition = new BoundFunctionDefinition(mangled_name, full_name, ast_func.is_extern, ast_func.is_pure, ast_func.is_new, ast_func.is_extern);

        if (!ast_func.is_extern && ast_func.body.is_some()) {
            // Use class_scope as parent if available (for methods in specialized generic classes)
            // so that class type params (e.g., T=i32) are visible in the method body
            if (class_scope.is_some()) {
                let func_scope: mut BoundScope = new BoundScope(new ScopeKind.FunctionScope(), mangled_name, full_name + ".<body>", new Option<BoundScope>.some(class_scope.some));
                let pi: mut i64 = 0;
                while (pi < cast<i64>(tmpl.generic_params.size()) && pi < cast<i64>(type_args.size())) {
                    let param_name: string = tmpl.generic_params.at(cast<u64>(pi)).some;
                    let arg_type: BoundType = type_args.at(cast<u64>(pi)).some;
                    let param_sym: mut BoundTypeSymbol = new BoundTypeSymbol(param_name, full_name + "." + param_name);
                    param_sym.bound_type = arg_type.with_mutability(arg_type.mutability);
                    func_scope.add_symbol(new BoundSymbol.type_sym(param_sym));
                    pi = pi + 1;
                }
                result.scope = new Option<BoundScope>.some(func_scope);
            } else {
                let func_scope: mut BoundScope = new BoundScope(new ScopeKind.FunctionScope(), mangled_name, full_name + ".<body>", new Option<BoundScope>.some(parent_scope));
                let pi: mut i64 = 0;
                while (pi < cast<i64>(tmpl.generic_params.size()) && pi < cast<i64>(type_args.size())) {
                    let param_name: string = tmpl.generic_params.at(cast<u64>(pi)).some;
                    let arg_type: BoundType = type_args.at(cast<u64>(pi)).some;
                    let param_sym: mut BoundTypeSymbol = new BoundTypeSymbol(param_name, full_name + "." + param_name);
                    param_sym.bound_type = arg_type.with_mutability(arg_type.mutability);
                    func_scope.add_symbol(new BoundSymbol.type_sym(param_sym));
                    pi = pi + 1;
                }
                result.scope = new Option<BoundScope>.some(func_scope);
            }
        }

        let sym: mut BoundFunctionSymbol = new BoundFunctionSymbol(mangled_name, full_name);
        sym.is_extern = ast_func.is_extern;
        sym.is_static = result.is_static;
        sym.is_pure = ast_func.is_pure;
        sym.is_new = ast_func.is_new;
        result.symbol = new Option<BoundFunctionSymbol>.some(sym);
        // add_symbol would overwrite full_name, so we set enclosing_scope manually
        // and push directly to preserve the correct full_name
        sym.enclosing_scope = new Option<BoundScope>.some(parent_scope);
        parent_scope.symbols.push(new BoundSymbol.function_sym(sym));

        return new Option<BoundDefinition>.some(new BoundDefinition.function_def(result));
    }

    // Find the specialized class scope for a method, if its parent class has been specialized.
    // This is needed so that class type params (e.g., T=i32) are visible in method specializations.
    fun find_specialized_class_scope(this, defs: _utils.List<BoundDefinition>, method_name: string) -> Option<BoundScope> {
        let orig_name: string = this.extract_template_name(method_name);
        // Find the template class that owns this method
        let i: mut i64 = 0;
        while (i < cast<i64>(defs.size())) {
            let def: BoundDefinition = defs.at(cast<u64>(i)).some;
            if (def is BoundDefinition.class_def) {
                let cls: BoundClassDefinition = def.class_def;
                let mi: mut i64 = 0;
                while (mi < cast<i64>(cls.methods.size())) {
                    let md: BoundDefinition = cls.methods.at(cast<u64>(mi)).some;
                    if (md is BoundDefinition.function_def) {
                        if (md.function_def.name == orig_name) {
                            if (cls.is_generic_template) {
                                let spec_scope: Option<BoundScope> = this.find_class_specialization_scope(defs, cls.name);
                                if (spec_scope.is_some()) {
                                    return spec_scope;
                                }
                            }
                        }
                    }
                    mi = mi + 1;
                }
            }
            i = i + 1;
        }
        return new Option<BoundScope>.none();
    }

    fun find_class_specialization_scope(this, defs: _utils.List<BoundDefinition>, template_name: string) -> Option<BoundScope> {
        let i: mut i64 = 0;
        while (i < cast<i64>(defs.size())) {
            let def: BoundDefinition = defs.at(cast<u64>(i)).some;
            if (def is BoundDefinition.class_def) {
                let cls: BoundClassDefinition = def.class_def;
                if (!cls.is_generic_template && cls.scope.is_some()) {
                    // Check if this class name starts with template_name + "__"
                    if (string_find(cls.name, template_name + "__") == 0) {
                        return cls.scope;
                    }
                }
            }
            i = i + 1;
        }
        return new Option<BoundScope>.none();
    }

    fun find_method_class_scope(this, existing_defs: _utils.List<BoundDefinition>, new_defs: _utils.List<BoundDefinition>, method_name: string) -> Option<BoundScope> {
        let orig_name: string = this.extract_template_name(method_name);
        // Search existing defs
        let result: Option<BoundScope> = this.find_specialized_class_scope(existing_defs, method_name);
        if (result.is_some()) {
            return result;
        }
        // Search new (current batch) defs
        let mi: mut i64 = 0;
        while (mi < cast<i64>(new_defs.size())) {
            let sd: BoundDefinition = new_defs.at(cast<u64>(mi)).some;
            if (sd is BoundDefinition.class_def) {
                let sd_cls: BoundClassDefinition = sd.class_def;
                if (sd_cls.scope.is_some()) {
                    let sdi: mut i64 = 0;
                    while (sdi < cast<i64>(sd_cls.methods.size())) {
                        let smd: BoundDefinition = sd_cls.methods.at(cast<u64>(sdi)).some;
                        if (smd is BoundDefinition.function_def) {
                            if (smd.function_def.name == orig_name) {
                                return sd_cls.scope;
                            }
                        }
                        sdi = sdi + 1;
                    }
                }
            }
            mi = mi + 1;
        }
        return new Option<BoundScope>.none();
    }

    fun build_specialized_full_name(this, tmpl: BoundFunctionDefinition, mangled_name: string, class_scope: Option<BoundScope>) -> string {
        if (class_scope.is_some()) {
            return class_scope.some.full_name + "." + mangled_name;
        }
        return this.replace_name_in_full_name(tmpl.full_name, tmpl.name, mangled_name);
    }

    // Find the parent class for a method by extracting the class name from the function's full_name
    // e.g. full_name="<global>.Foo__i32.foo__i64" -> parent class is "Foo__i32"
    fun find_parent_class_for_method(this, defs: _utils.List<BoundDefinition>, new_defs: _utils.List<BoundDefinition>, func_full_name: string) -> Option<BoundClassDefinition> {
        // Extract class name from full_name: strip <global>. prefix and last .method part
        let prefix: string = "<global>.";
        let prefix_len: i64 = string_length(prefix);
        let full_len: i64 = string_length(func_full_name);
        let after_prefix: mut string = func_full_name;
        if (full_len > prefix_len) {
            let matches: mut bool = true;
            let ci: mut i64 = 0;
            while (ci < prefix_len) {
                if (string_char_at(func_full_name, ci) != string_char_at(prefix, ci)) {
                    matches = false;
                }
                ci = ci + 1;
            }
            if (matches) {
                after_prefix = string_substring(func_full_name, prefix_len, full_len - prefix_len);
            }
        }
        // Find the last dot to separate class name from method name
        let last_dot: mut i64 = -1;
        let search_pos: mut i64 = 0;
        let after_len: i64 = string_length(after_prefix);
        while (search_pos < after_len) {
            let found: i64 = string_find_from(after_prefix, ".", search_pos);
            if (found < 0) {
                search_pos = after_len;
            } else {
                last_dot = found;
                search_pos = found + 1;
            }
        }
        if (last_dot >= 0) {
            let class_name: string = string_substring(after_prefix, 0, last_dot);
            // Search in existing defs
            let i: mut i64 = 0;
            while (i < cast<i64>(defs.size())) {
                let def: BoundDefinition = defs.at(cast<u64>(i)).some;
                if (def is BoundDefinition.class_def) {
                    if (def.class_def.name == class_name) {
                        return new Option<BoundClassDefinition>.some(def.class_def);
                    }
                }
                i = i + 1;
            }
            // Also search in new_defs (current batch)
            let j: mut i64 = 0;
            while (j < cast<i64>(new_defs.size())) {
                let def: BoundDefinition = new_defs.at(cast<u64>(j)).some;
                if (def is BoundDefinition.class_def) {
                    if (def.class_def.name == class_name) {
                        return new Option<BoundClassDefinition>.some(def.class_def);
                    }
                }
                j = j + 1;
            }
        }
        return new Option<BoundClassDefinition>.none();
    }

    // Fix the 'this' parameter type for a specialized class method
    fun fix_this_param_type(this, func: mut BoundFunctionDefinition, cls: BoundClassDefinition) {
        let pi: mut i64 = 0;
        while (pi < cast<i64>(func.parameters.size())) {
            let bp: mut BoundFunctionParameter = func.parameters.at(cast<u64>(pi)).some;
            if (bp.is_this) {
                if (func.is_new) {
                    bp.bound_type = cls.bound_type.with_mutability(new Mutability.Mutable());
                } else {
                    bp.bound_type = cls.bound_type;
                }
                // Also update the function type on the symbol
                if (func.symbol.is_some()) {
                    let sym: mut BoundFunctionSymbol = func.symbol.some;
                    let param_types: mut _utils.List<BoundType> = new _utils.List<BoundType>();
                    let pj: mut i64 = 0;
                    while (pj < cast<i64>(func.parameters.size())) {
                        param_types.push(func.parameters.at(cast<u64>(pj)).some.bound_type);
                        pj = pj + 1;
                    }
                    sym.bound_type = this.type_registry.make_function_type(func.return_type, param_types, false);
                    func.symbol = new Option<BoundFunctionSymbol>.some(sym);
                }
                return;
            }
            pi = pi + 1;
        }
    }
}

}
