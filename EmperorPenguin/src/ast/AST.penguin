            let self = cast<EventDefinition>(this);
            let s: mut string = "event " + self.name;
            if (self.event_type.is_some()) { s = s + ": " + self.event_type.some.build_text(); }
            return s + ";";
        }
    }
}

class NamespaceDefinition {
    name: mut string = "";
    children: mut _utils.List<Definition> = new _utils.List<Definition>();

    fun new(mut this, name: string) {
        this.name = name;
    }


    impl IDefinition {
        fun build_text(this: IDefinition) -> string {
            let self = cast<NamespaceDefinition>(this);
            let s: mut string = "namespace " + self.name + "{";
            let i: mut i64 = 0;
            while (i < cast<i64>(self.children.size())) {
                s = s + " " + self.children.at(cast<u64>(i)).some.build_text();
                i = i + 1;
            }
            s = s + " }";
            return s;
        }
    }
}

class InitialRoutineDefinition {
    body: mut Option<Expression> = new Option<Expression>.none();
    impl IDefinition {
        fun build_text(this: IDefinition) -> string {
            let self = cast<InitialRoutineDefinition>(this);
            if (self.body.is_some()) { return "initial " + self.body.some.build_text(); }
            return "initial {}";
        }
    }
}

class OnRoutineDefinition {
    event_name: mut string = "";
    event_expr: mut Option<Expression> = new Option<Expression>.none();
    parameter: mut Option<Parameter> = new Option<Parameter>.none();
    body: mut Option<Expression> = new Option<Expression>.none();
    impl IDefinition {
        fun build_text(this: IDefinition) -> string {
            let self = cast<OnRoutineDefinition>(this);
            let mut sb = new StringBuilder();
            sb.append("on ");
            if (self.event_expr.is_some()) { sb.append(self.event_expr.some.build_text()); }
            else { sb.append(self.event_name); }
            if (self.parameter.is_some()) { sb.append("("); sb.append(self.parameter.some.build_text()); sb.append(")"); }
            if (self.body.is_some()) { sb.append(" "); sb.append(self.body.some.build_text()); }
            return sb.to_string();
        }
    }
}

