class GlobalVariableDefinition {
    name: mut string = "";
    type_spec: mut Option<TypeSpecifier> = new Option<TypeSpecifier>.none();
    initializer: mut Option<Expression> = new Option<Expression>.none();
    is_mutable: mut bool = false;

    fun new(mut this, name: string) {
        this.name = name;
    }

    impl IDefinition {
        fun build_text(this: IDefinition) -> string {
            let self = cast<GlobalVariableDefinition>(this);
            let s: mut string = "let ";
            if (self.is_mutable) { s = s + "mut "; }
            s = s + self.name;
            if (self.type_spec.is_some()) { s = s + ": " + self.type_spec.some.build_text(); }
            if (self.initializer.is_some()) { s = s + " = " + self.initializer.some.build_text(); }
            return s + ";";
        }
    }
}

enum Definition {
    function_def: FunctionDefinition;
    class_def: ClassDefinition;
    enum_def: EnumDefinition;
    namespace_def: NamespaceDefinition;
    initial_routine: InitialRoutineDefinition;
    interface_def: InterfaceDefinition;
    impl_def: InterfaceImplementation;
    impl_for_def: InterfaceForImplementation;
    event_def: EventDefinition;
    on_routine_def: OnRoutineDefinition;
    type_ref_def: TypeReferenceDefinition;
    enum_member: EnumMemberDefinition;
    class_field: ClassFieldDefinition;
    global_var: GlobalVariableDefinition;

    fun build_text(this) -> string {
        if (this is Definition.function_def) { return this.function_def.build_text(); }
        if (this is Definition.class_def) { return this.class_def.build_text(); }
        if (this is Definition.enum_def) { return this.enum_def.build_text(); }
        if (this is Definition.namespace_def) { return this.namespace_def.build_text(); }
        if (this is Definition.initial_routine) { return this.initial_routine.build_text(); }
        if (this is Definition.interface_def) { return this.interface_def.build_text(); }
        if (this is Definition.impl_def) { return this.impl_def.build_text(); }
        if (this is Definition.impl_for_def) { return this.impl_for_def.build_text(); }
        if (this is Definition.event_def) { return this.event_def.build_text(); }
        if (this is Definition.on_routine_def) { return this.on_routine_def.build_text(); }
        if (this is Definition.type_ref_def) { return this.type_ref_def.build_text(); }
        if (this is Definition.enum_member) { return this.enum_member.build_text(); }
        if (this is Definition.class_field) { return this.class_field.build_text(); }
        if (this is Definition.global_var) { return this.global_var.build_text(); }
        return "";
    }
}

class CompilationUnit {
    definitions: mut _utils.List<Definition> = new _utils.List<Definition>();
    fun build_text(this) -> string {
        let mut sb = new StringBuilder();
        let i: mut i64 = 0;
        while (i < cast<i64>(this.definitions.size())) {
            if (i > 0) { sb.append(" "); }
            sb.append(this.definitions.at(cast<u64>(i)).some.build_text());
            i = i + 1;
        }
        return sb.to_string();
    }
}
}
