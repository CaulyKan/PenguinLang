        fun build_text(this: IDefinition) -> string {
            let self = cast<TypeReferenceDefinition>(this);
            let s: mut string = "type " + self.name + " = ";
            if (self.type_spec.is_some()) { s = s + self.type_spec.some.build_text(); }
            return s + ";";
        }
    }
}

