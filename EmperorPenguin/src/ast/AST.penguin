class InterfaceImplementation {
    type_name: mut string = "";
    type_spec: mut Option<TypeSpecifier> = new Option<TypeSpecifier>.none();
    functions: mut _utils.List<Definition> = new _utils.List<Definition>();
    where_def: mut Option<WhereDefinition> = new Option<WhereDefinition>.none();

    fun new(mut this, type_name: string) {
        this.type_name = type_name;
    }


    impl IDefinition {
        fun build_text(this: IDefinition) -> string {
            let self = cast<InterfaceImplementation>(this);
            let mut sb = new StringBuilder();
            sb.append("impl ");
            if (self.type_spec.is_some()) { sb.append(self.type_spec.some.build_text()); }
            else { sb.append(self.type_name); }
            if (self.where_def.is_some()) { sb.append(" "); sb.append(self.where_def.some.build_text()); }
            if (cast<i64>(self.functions.size()) > 0) {
                sb.append(" {");
                let i: mut i64 = 0;
                while (i < cast<i64>(self.functions.size())) {
                    sb.append(" ");
                    sb.append(self.functions.at(cast<u64>(i)).some.build_text());
                    i = i + 1;
                }
                sb.append(" }");
            } else {
                sb.append(";");
            }
            return sb.to_string();
        }
    }
}

class InterfaceForImplementation {
    type_name: mut string = "";
    for_type_name: mut string = "";
    type_spec: mut Option<TypeSpecifier> = new Option<TypeSpecifier>.none();
    for_type_spec: mut Option<TypeSpecifier> = new Option<TypeSpecifier>.none();
    functions: mut _utils.List<Definition> = new _utils.List<Definition>();
    where_def: mut Option<WhereDefinition> = new Option<WhereDefinition>.none();

    fun new(mut this, type_name: string, for_type_name: string) {
        this.type_name = type_name;
        this.for_type_name = for_type_name;
    }


    impl IDefinition {
        fun build_text(this: IDefinition) -> string {
            let self = cast<InterfaceForImplementation>(this);
            let mut sb = new StringBuilder();
            sb.append("impl ");
            if (self.type_spec.is_some()) { sb.append(self.type_spec.some.build_text()); }
            else { sb.append(self.type_name); }
            sb.append(" for ");
            if (self.for_type_spec.is_some()) { sb.append(self.for_type_spec.some.build_text()); }
            else { sb.append(self.for_type_name); }
            if (self.where_def.is_some()) { sb.append(" "); sb.append(self.where_def.some.build_text()); }
            if (cast<i64>(self.functions.size()) > 0) {
                sb.append(" {");
                let i: mut i64 = 0;
                while (i < cast<i64>(self.functions.size())) {
                    sb.append(" ");
                    sb.append(self.functions.at(cast<u64>(i)).some.build_text());
                    i = i + 1;
                }
                sb.append(" }");
            } else {
                sb.append(";");
            }
            return sb.to_string();
        }
    }
}

