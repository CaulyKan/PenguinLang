namespace parser {
    class Parser {
        stream: mut TokenStream = new TokenStream(new List<Token>());
        errors: mut List<string> = new List<string>();

        fun new(mut this, tokens: mut List<Token>) {
            this.stream = new TokenStream(tokens);
        }

        fun report_error(this, message: string) {
            let tok: Token = this.stream.peek();
            let err: string = "Line " + cast<string>(tok.line) + ", Col " + cast<string>(tok.col) + ": " + message;
            this.errors.push(err);
            print(err);
        }

        fun has_errors(this) -> bool {
            return cast<i64>(this.errors.size()) > 0;
        }

        // primaryExpression: Constant | StringLiteral+ | boolLiteral | voidLiteral | identifierWithGeneric | lambdaFunctionExpression | '(' expression ')' | codeBlockExpression | ifExpression | whileExpression | 'cast' '<' typeSpecifier '>' '(' expression ')';
        // Classification: Alternative
        fun parse_primaryExpression(this) -> ast.Expression {
            let token: Token = this.stream.peek();
            if (token.token_type is TokenType.Constant) {
                let tok: Token = this.stream.advance();
                let const_expr: ast.ConstantExpression = new ast.ConstantExpression();
                const_expr.value = tok.text;
                return new ast.Expression.constant(const_expr);
            } else if (token.token_type is TokenType.Stringliteral) {
                let tok: Token = this.stream.advance();
                let str_expr: ast.StringLiteralExpression = new ast.StringLiteralExpression();
                str_expr.value = tok.text;
                return new ast.Expression.string_literal(str_expr);
            } else if (token.token_type is TokenType.True || token.token_type is TokenType.False) {
                return this.parse_boolLiteral();
            } else if (token.token_type is TokenType.Void) {
                return this.parse_voidLiteral();
            } else if (token.token_type is TokenType.Identifier || token.token_type is TokenType.ThisKw) {
                return this.parse_identifierWithGeneric();
            } else if (token.token_type is TokenType.Fun || token.token_type is TokenType.Async_fun) {
                return this.parse_lambdaFunctionExpression();
            } else if (token.token_type is TokenType.LParen) {
                this.stream.expect(new TokenType.LParen());
                let inner = this.parse_expression();
                this.stream.expect(new TokenType.RParen());
                let paren_expr: ast.ParenthesizedExpression = new ast.ParenthesizedExpression();
                paren_expr.inner = new Option<ast.Expression>.some(inner);
                return new ast.Expression.parenthesized(paren_expr);
            } else if (token.token_type is TokenType.LBrace) {
                return this.parse_codeBlockExpression();
            } else if (token.token_type is TokenType.If) {
                return this.parse_ifExpression();
            } else if (token.token_type is TokenType.While) {
                return this.parse_whileExpression();
            } else if (token.token_type is TokenType.Cast) {
                this.stream.expect(new TokenType.Cast());
                this.stream.expect(new TokenType.Less());
                let type_token: Token = this.stream.advance();
                this.stream.expect(new TokenType.Greater());
                this.stream.expect(new TokenType.LParen());
                let cast_inner: ast.Expression = this.parse_expression();
                this.stream.expect(new TokenType.RParen());
                let cast_node: ast.CastExpression = new ast.CastExpression();
                cast_node.type_name = type_token.text;
                cast_node.inner = new Option<ast.Expression>.some(cast_inner);
                return new ast.Expression.cast_expr(cast_node);
            } else {
                let const_expr: ast.ConstantExpression = new ast.ConstantExpression();
                return new ast.Expression.constant(const_expr);
            }
        }

        // ifExpression: 'if' '(' expression ')' codeBlockExpression ('else' (codeBlockExpression | ifExpression))?;
        // Classification: Sequence
        fun parse_ifExpression(this) -> ast.Expression {
            this.stream.expect(new TokenType.If());
            this.stream.expect(new TokenType.LParen());
            let condition = this.parse_expression();
            this.stream.expect(new TokenType.RParen());
            let then_block = this.parse_codeBlockExpression();
            let else_block: mut Option<ast.Expression> = new Option<ast.Expression>.none();
            if (this.stream.match(new TokenType.Else())) {
                if (this.stream.peek_type() is TokenType.If) {
                    else_block = new Option<ast.Expression>.some(this.parse_ifExpression());
                } else {
                    else_block = new Option<ast.Expression>.some(this.parse_codeBlockExpression());
                }
            }
            let node = new ast.IfExpression();
            node.condition = new Option<ast.Expression>.some(condition);
            node.then_block = new Option<ast.Expression>.some(then_block);
            node.else_block = else_block;
            return new ast.Expression.if_expr(node);
        }

        // whileExpression: 'while' '(' expression ')' codeBlockExpression;
        // Classification: Sequence
        fun parse_whileExpression(this) -> ast.Expression {
            this.stream.expect(new TokenType.While());
            this.stream.expect(new TokenType.LParen());
            let condition = this.parse_expression();
            this.stream.expect(new TokenType.RParen());
            let body = this.parse_codeBlockExpression();
            let node = new ast.WhileExpression();
            node.condition = new Option<ast.Expression>.some(condition);
            node.body = new Option<ast.Expression>.some(body);
            return new ast.Expression.while_expr(node);
        }

        // codeBlockExpression: '{' codeBlockItem* expression? '}';
        // Classification: Sequence
        fun parse_codeBlockExpression(this) -> ast.Expression {
            this.stream.expect(new TokenType.LBrace());
            let node = new ast.CodeBlockExpression();
            while (!(this.stream.is_at_end())) {
                if (this.stream.peek_type() is TokenType.RBrace) { break; }
                let _loop_guard_pos: mut i64 = this.stream.pos;
                let next: Token = this.stream.peek();
                if (next.token_type is TokenType.If || next.token_type is TokenType.While || next.token_type is TokenType.LBrace) {
                    // Block-like expressions: parse as expression, wrap without semicolon
                    let expr: ast.Expression = this.parse_expression();
                    let bs: ast.BlockExpressionStatement = new ast.BlockExpressionStatement();
                    bs.expression = new Option<ast.Expression>.some(expr);
                    node.statements.push(new ast.Statement.block_expr(bs));
                } else if (next.token_type is TokenType.Let || next.token_type is TokenType.For || next.token_type is TokenType.Return || next.token_type is TokenType.Break || next.token_type is TokenType.Continue || next.token_type is TokenType.Emit || next.token_type is TokenType.Yield || next.token_type is TokenType.InternalSignal || next.token_type is TokenType.Semicolon) {
                    let stmt = this.parse_statement();
                    node.statements.push(stmt);
                } else {
                    // expression or assignment
                    let expr = this.parse_expression();
                    if (this.stream.peek_type() is TokenType.Semicolon) {
                        this.stream.advance();
                        let es: ast.ExpressionStatement = new ast.ExpressionStatement();
                        es.expression = new Option<ast.Expression>.some(expr);
                        node.statements.push(new ast.Statement.expression(es));
                    } else if (this.stream.peek_type() is TokenType.RBrace) {
                        // trailing expression (last expression in block)
                        node.trailing_expr = new Option<ast.Expression>.some(expr);
                        break;
                    } else {
                        // assignment: expr op value ;
                        let op_token: Token = this.stream.advance();
                        let value = this.parse_expression();
                        this.stream.expect(new TokenType.Semicolon());
                        let assign = new ast.AssignmentStatement();
                        assign.target = new Option<ast.Expression>.some(expr);
                        let op3: mut ast.AssignmentOperator = this.token_to_assignment_operator(op_token);
                        assign.operator_value = op3;
                        assign.value = new Option<ast.Expression>.some(value);
                        node.statements.push(new ast.Statement.assignment(assign));
                    }
                }
                if (this.stream.pos == _loop_guard_pos) {
                    print("ERROR: codeBlock parser stuck at pos " + cast<string>(this.stream.pos) + " token: " + this.stream.peek().to_string());
                    break;
                }
            }
            this.stream.expect(new TokenType.RBrace());
            return new ast.Expression.code_block(node);
        }

        // identifierWithGeneric: identifier;
        // In expression context, '<' is always a comparison operator, never a generic bracket.
        fun parse_identifierWithGeneric(this) -> ast.Expression {
            let name_token: Token = this.stream.advance();
            let id_expr: ast.IdentifierExpression = new ast.IdentifierExpression();
            id_expr.name = name_token.text;
            return new ast.Expression.identifier(id_expr);
        }

        // postfixExpression: primaryExpression | postfixExpression '.' identifierWithGeneric | postfixExpression '(' expression? (',' expression)* ')' | 'new' typeSpecifier '(' expression? (',' expression)* ')' | 'async' expression | 'wait' expression?;
        // Classification: LeftRecursive
        fun parse_postfixExpression(this) -> ast.Expression {
            if (this.stream.peek_type() is TokenType.New) {
            this.stream.expect(new TokenType.New());
            let type_token: Token = this.stream.advance();
            this.stream.expect(new TokenType.LParen());
            let args: mut List<ast.Expression> = new List<ast.Expression>();
            if (!(this.stream.peek_type() is TokenType.RParen)) {
                args.push(this.parse_expression());
                while (this.stream.match(new TokenType.Comma())) {
                    args.push(this.parse_expression());
                }
            }
            this.stream.expect(new TokenType.RParen());
            let new_expr: ast.NewExpression = new ast.NewExpression();
            new_expr.type_name = type_token.text;
            new_expr.arguments = args;
            return new ast.Expression.new_expr(new_expr);
            }
            if (this.stream.peek_type() is TokenType.Async) {
            this.stream.expect(new TokenType.Async());
            let async_inner: ast.Expression = this.parse_expression();
            let spawn_expr: ast.SpawnAsyncExpression = new ast.SpawnAsyncExpression();
            spawn_expr.expression = new Option<ast.Expression>.some(async_inner);
            return new ast.Expression.spawn_async(spawn_expr);
            }
            if (this.stream.peek_type() is TokenType.Wait) {
            this.stream.expect(new TokenType.Wait());
            let wait_inner: mut Option<ast.Expression> = new Option<ast.Expression>.none();
            if (!(this.stream.peek_type() is TokenType.Semicolon) && !(this.stream.peek_type() is TokenType.RParen) && !(this.stream.peek_type() is TokenType.RBrace)) {
                wait_inner = new Option<ast.Expression>.some(this.parse_expression());
            }
            let wait_expr: ast.WaitExpression = new ast.WaitExpression();
            wait_expr.expression = wait_inner;
            return new ast.Expression.wait_expr(wait_expr);
            }
            let results = new List<ast.Expression>();
            results.push(this.parse_primaryExpression());
            while (true) {
                let next = this.stream.peek();
                 if (next.token_type is TokenType.Dot) {
            this.stream.expect(new TokenType.Dot());
            let member_token: Token = this.stream.advance();
            let ma_expr: ast.MemberAccessExpression = new ast.MemberAccessExpression();
            ma_expr.base_expr = new Option<ast.Expression>.some(results.at(cast<u64>(results.size() - 1)).some);
            ma_expr.member_name = member_token.text;
            results.push(new ast.Expression.member_access(ma_expr));
                } else if (next.token_type is TokenType.LParen) {
            this.stream.expect(new TokenType.LParen());
            let args = new List<ast.Expression>();
            if (!(this.stream.peek_type() is TokenType.RParen)) {
                args.push(this.parse_expression());
                while (this.stream.match(new TokenType.Comma())) {
                    args.push(this.parse_expression());
                }
            }
            this.stream.expect(new TokenType.RParen());
            let fc_expr: ast.FunctionCallExpression = new ast.FunctionCallExpression();
            fc_expr.callee = new Option<ast.Expression>.some(results.at(cast<u64>(results.size() - 1)).some);
            fc_expr.arguments = args;
            results.push(new ast.Expression.function_call(fc_expr));
                } else {
                    break;
                }
            }
            return results.at(cast<u64>(results.size() - 1)).some;
        }

        // unaryExpression: postfixExpression | unaryOperator postfixExpression;
        // Classification: Alternative
        fun parse_unaryExpression(this) -> ast.Expression {
            let next: Token = this.stream.peek();
            if (next.token_type is TokenType.Ampersand || next.token_type is TokenType.Star || next.token_type is TokenType.Plus || next.token_type is TokenType.Minus || next.token_type is TokenType.Tilde || next.token_type is TokenType.Bang) {
                let op_token: Token = this.stream.advance();
                let op: mut ast.UnaryOperator = this.token_to_unary_operator(op_token);
                let operand: ast.Expression = this.parse_unaryExpression();
                let node: ast.UnaryExpression = new ast.UnaryExpression();
                node.operator_value = op;
                node.operand = new Option<ast.Expression>.some(operand);
                return new ast.Expression.unary(node);
            }
            return this.parse_postfixExpression();
        }


        // multiplicativeExpression: unaryExpression (multiplicativeOperator unaryExpression)*;
        // Classification: Binary
        fun parse_multiplicativeExpression(this) -> ast.Expression {
            let first: ast.Expression = this.parse_unaryExpression();
            let operators = new List<ast.BinaryOperator>();
            let operands = new List<ast.Expression>();
            operands.push(first);
            while (true) {
                let token: Token = this.stream.peek();
                if (this.stream.peek_type() is TokenType.Star || this.stream.peek_type() is TokenType.Slash || this.stream.peek_type() is TokenType.Percent) {
                    let op_token: Token = this.stream.advance();
                    let op: ast.BinaryOperator = this.token_to_binary_operator(op_token);
                    operators.push(op);
                    let right = this.parse_unaryExpression();
                    operands.push(right);
                } else {
                    break;
                }
            }

            if (operators.size() == 0) {
                return first;
            }
            let bin_expr: ast.BinaryExpression = new ast.BinaryExpression();
            bin_expr.operators = operators;
            bin_expr.operands = operands;
            return new ast.Expression.binary(bin_expr);
        }


        // additiveExpression: multiplicativeExpression (additiveOperator multiplicativeExpression)*;
        // Classification: Binary
        fun parse_additiveExpression(this) -> ast.Expression {
            let first: ast.Expression = this.parse_multiplicativeExpression();
            let operators = new List<ast.BinaryOperator>();
            let operands = new List<ast.Expression>();
            operands.push(first);
            while (true) {
                let token: Token = this.stream.peek();
                if (this.stream.peek_type() is TokenType.Plus || this.stream.peek_type() is TokenType.Minus) {
                    let op_token: Token = this.stream.advance();
                    let op: ast.BinaryOperator = this.token_to_binary_operator(op_token);
                    operators.push(op);
                    let right = this.parse_multiplicativeExpression();
                    operands.push(right);
                } else {
                    break;
                }
            }

            if (operators.size() == 0) {
                return first;
            }
            let bin_expr: ast.BinaryExpression = new ast.BinaryExpression();
            bin_expr.operators = operators;
            bin_expr.operands = operands;
            return new ast.Expression.binary(bin_expr);
        }


        // relationalExpression: additiveExpression (relationalOperator additiveExpression)*;
        // Classification: Binary
        fun parse_relationalExpression(this) -> ast.Expression {
            let first: ast.Expression = this.parse_additiveExpression();
            let operators = new List<ast.BinaryOperator>();
            let operands = new List<ast.Expression>();
            operands.push(first);
            while (true) {
                let token: Token = this.stream.peek();
                if (this.stream.peek_type() is TokenType.Less || this.stream.peek_type() is TokenType.Greater || this.stream.peek_type() is TokenType.LessEqual || this.stream.peek_type() is TokenType.GreaterEqual) {
                    let op_token: Token = this.stream.advance();
                    let op: ast.BinaryOperator = this.token_to_binary_operator(op_token);
                    operators.push(op);
                    let right = this.parse_additiveExpression();
                    operands.push(right);
                } else {
                    break;
                }
            }

            if (operators.size() == 0) {
                return first;
            }
            let bin_expr: ast.BinaryExpression = new ast.BinaryExpression();
            bin_expr.operators = operators;
            bin_expr.operands = operands;
            return new ast.Expression.binary(bin_expr);
        }


        // equalityExpression: relationalExpression (equalityOperator relationalExpression)?;
        // Classification: Binary
        fun parse_equalityExpression(this) -> ast.Expression {
            let first: ast.Expression = this.parse_relationalExpression();
            let operators = new List<ast.BinaryOperator>();
            let operands = new List<ast.Expression>();
            operands.push(first);
            while (true) {
                let token: Token = this.stream.peek();
                if (this.stream.peek_type() is TokenType.EqualEqual || this.stream.peek_type() is TokenType.BangEqual || this.stream.peek_type() is TokenType.Is) {
                    let op_token: Token = this.stream.advance();
                    let op: ast.BinaryOperator = this.token_to_binary_operator(op_token);
                    operators.push(op);
                    let right = this.parse_relationalExpression();
                    operands.push(right);
                } else {
                    break;
                }
            }

            if (operators.size() == 0) {
                return first;
            }
            let bin_expr: ast.BinaryExpression = new ast.BinaryExpression();
            bin_expr.operators = operators;
            bin_expr.operands = operands;
            return new ast.Expression.binary(bin_expr);
        }


        // bitwiseAndExpression: equalityExpression ('&' equalityExpression)*;
        // Classification: Binary
        fun parse_bitwiseAndExpression(this) -> ast.Expression {
            let first: ast.Expression = this.parse_equalityExpression();
            let operators = new List<ast.BinaryOperator>();
            let operands = new List<ast.Expression>();
            operands.push(first);
            while (true) {
                let token: Token = this.stream.peek();
                if (this.stream.peek_type() is TokenType.Ampersand) {
                    let op_token: Token = this.stream.advance();
                    let op: ast.BinaryOperator = this.token_to_binary_operator(op_token);
                    operators.push(op);
                    let right = this.parse_equalityExpression();
                    operands.push(right);
                } else {
                    break;
                }
            }

            if (operators.size() == 0) {
                return first;
            }
            let bin_expr: ast.BinaryExpression = new ast.BinaryExpression();
            bin_expr.operators = operators;
            bin_expr.operands = operands;
            return new ast.Expression.binary(bin_expr);
        }

        // bitwiseXorExpression: bitwiseAndExpression ('^' bitwiseAndExpression)*;
        // Classification: Binary
        fun parse_bitwiseXorExpression(this) -> ast.Expression {
            let first: ast.Expression = this.parse_bitwiseAndExpression();
            let operators = new List<ast.BinaryOperator>();
            let operands = new List<ast.Expression>();
            operands.push(first);
            while (true) {
                let token: Token = this.stream.peek();
                if (this.stream.peek_type() is TokenType.Caret) {
                    let op_token: Token = this.stream.advance();
                    let op: ast.BinaryOperator = this.token_to_binary_operator(op_token);
                    operators.push(op);
                    let right = this.parse_bitwiseAndExpression();
                    operands.push(right);
                } else {
                    break;
                }
            }

            if (operators.size() == 0) {
                return first;
            }
            let bin_expr: ast.BinaryExpression = new ast.BinaryExpression();
            bin_expr.operators = operators;
            bin_expr.operands = operands;
            return new ast.Expression.binary(bin_expr);
        }

        // bitwiseOrExpression: bitwiseXorExpression ('|' bitwiseXorExpression)*;
        // Classification: Binary
        fun parse_bitwiseOrExpression(this) -> ast.Expression {
            let first: ast.Expression = this.parse_bitwiseXorExpression();
            let operators = new List<ast.BinaryOperator>();
            let operands = new List<ast.Expression>();
            operands.push(first);
            while (true) {
                let token: Token = this.stream.peek();
                if (this.stream.peek_type() is TokenType.Pipe) {
                    let op_token: Token = this.stream.advance();
                    let op: ast.BinaryOperator = this.token_to_binary_operator(op_token);
                    operators.push(op);
                    let right = this.parse_bitwiseXorExpression();
                    operands.push(right);
                } else {
                    break;
                }
            }

            if (operators.size() == 0) {
                return first;
            }
            let bin_expr: ast.BinaryExpression = new ast.BinaryExpression();
            bin_expr.operators = operators;
            bin_expr.operands = operands;
            return new ast.Expression.binary(bin_expr);
        }

        // logicalAndExpression: bitwiseOrExpression ('&&' bitwiseOrExpression)*;
        // Classification: Binary
        fun parse_logicalAndExpression(this) -> ast.Expression {
            let first: ast.Expression = this.parse_bitwiseOrExpression();
            let operators = new List<ast.BinaryOperator>();
            let operands = new List<ast.Expression>();
            operands.push(first);
            while (true) {
                let token: Token = this.stream.peek();
                if (this.stream.peek_type() is TokenType.AmpersandAmpersand) {
                    let op_token: Token = this.stream.advance();
                    let op: ast.BinaryOperator = this.token_to_binary_operator(op_token);
                    operators.push(op);
                    let right = this.parse_bitwiseOrExpression();
                    operands.push(right);
                } else {
                    break;
                }
            }

            if (operators.size() == 0) {
                return first;
            }
            let bin_expr: ast.BinaryExpression = new ast.BinaryExpression();
            bin_expr.operators = operators;
            bin_expr.operands = operands;
            return new ast.Expression.binary(bin_expr);
        }

        // logicalOrExpression: logicalAndExpression ('||' logicalAndExpression)*;
        // Classification: Binary
        fun parse_logicalOrExpression(this) -> ast.Expression {
            let first: ast.Expression = this.parse_logicalAndExpression();
            let operators = new List<ast.BinaryOperator>();
            let operands = new List<ast.Expression>();
            operands.push(first);
            while (true) {
                let token: Token = this.stream.peek();
                if (this.stream.peek_type() is TokenType.PipePipe) {
                    let op_token: Token = this.stream.advance();
                    let op: ast.BinaryOperator = this.token_to_binary_operator(op_token);
                    operators.push(op);
                    let right = this.parse_logicalAndExpression();
                    operands.push(right);
                } else {
                    break;
                }
            }

            if (operators.size() == 0) {
                return first;
            }
            let bin_expr: ast.BinaryExpression = new ast.BinaryExpression();
            bin_expr.operators = operators;
            bin_expr.operands = operands;
            return new ast.Expression.binary(bin_expr);
        }

        // expression: logicalOrExpression;
        // Classification: Wrapper
        fun parse_expression(this) -> ast.Expression {
            return this.parse_logicalOrExpression();
        }


        // typeReferenceDeclaration: 'type' identifier '=' typeSpecifier;
        // Classification: Sequence
        fun parse_typeReferenceDeclaration(this) -> ast.Definition {
            this.stream.expect(new TokenType.TypeKw());
            let name_token: Token = this.stream.advance();
            this.stream.expect(new TokenType.Assign());
            let ts = this.parse_typeSpecifier();
            this.stream.expect(new TokenType.Semicolon());
            let node: ast.TypeReferenceDefinition = new ast.TypeReferenceDefinition();
            node.name = name_token.text;
            node.type_spec = new Option<ast.TypeSpecifier>.some(ts);
            return new ast.Definition.type_ref_def(node);
        }

        // declarationWithoutInitializer: identifier ':' typeSpecifier;
        // Classification: Sequence
        fun parse_declarationWithoutInitializer(this) -> ast.Definition {
            let name_token: Token = this.stream.advance();
            this.stream.expect(new TokenType.Colon());
            this.parse_typeSpecifier();
            let fd: ast.FunctionDefinition = new ast.FunctionDefinition();
            fd.name = name_token.text;
            return new ast.Definition.function_def(fd);
        }

        // declaration: identifier (':' typeSpecifier)? ('=' expression)?;
        // Classification: Sequence
        fun parse_declaration(this) -> ast.Definition {
            let name_token: Token = this.stream.advance();
            let fd: ast.FunctionDefinition = new ast.FunctionDefinition();
            fd.name = name_token.text;
            if (this.stream.match(new TokenType.Colon())) {
                let ts = this.parse_typeSpecifier();
                fd.return_type = new Option<ast.TypeSpecifier>.some(ts);
            }
            if (this.stream.match(new TokenType.Assign())) {
                let expr = this.parse_expression();
                fd.body = new Option<ast.Expression>.some(expr);
            }
            return new ast.Definition.function_def(fd);
        }

        // classDeclaration: identifier (':' typeMutabilitySpecifier? typeSpecifier)? ('=' expression)?;
        // Classification: Sequence
        fun parse_classDeclaration(this) -> ast.Definition {
            let name_token: Token = this.stream.advance();
            let node: ast.ClassFieldDefinition = new ast.ClassFieldDefinition();
            node.name = name_token.text;
            if (this.stream.match(new TokenType.Colon())) {
                let ts = this.parse_typeSpecifier();
                node.type_spec = new Option<ast.TypeSpecifier>.some(ts);
            }
            if (this.stream.match(new TokenType.Assign())) {
                let init_val: ast.Expression = this.parse_expression();
                node.initializer = new Option<ast.Expression>.some(init_val);
            }
            return new ast.Definition.class_field(node);
        }




        // typeSpecifier: typeMutabilitySpecifier? typeSpecifierWithoutIterable iterableType?;
        // Classification: Sequence
        fun parse_typeSpecifier(this) -> ast.TypeSpecifier {
            let node: ast.TypeSpecifier = new ast.TypeSpecifier();
            let next: Token = this.stream.peek();
            if (next.token_type is TokenType.Mut) {
                this.stream.advance();
                node.is_mutable = true;
            } else if (next.text == "!mut") {
                this.stream.advance();
                node.is_not_mutable = true;
            } else if (next.token_type is TokenType.AutoKw) {
                this.stream.advance();
                node.is_auto_mutability = true;
            }
            let type_next: Token = this.stream.peek();
            if (type_next.token_type is TokenType.Fun) {
                this.stream.advance();
                if (this.stream.peek_type() is TokenType.Less) {
                    node.is_function_type = true;
                    this.parse_genericTypeArgs(node.function_params);
                } else {
                    node.name = type_next.text;
                }
            } else {
                let type_token: Token = this.stream.advance();
                node.name = type_token.text;
                while (this.stream.peek_type() is TokenType.Dot) {
                    node.qualified_parts.push(node.name);
                    this.stream.expect(new TokenType.Dot());
                    let part: Token = this.stream.advance();
                    node.name = part.text;
                }
                if (this.stream.peek_type() is TokenType.Less) {
                    this.parse_genericTypeArgs(node.generic_args);
                }
            }
            if (this.stream.peek_type() is TokenType.ArrayBracket) {
                this.stream.advance();
                node.is_iterable = true;
            }
            return node;
        }
        fun parse_genericTypeArgs(this, list: mut List<ast.TypeSpecifier>) {
            this.stream.expect(new TokenType.Less());
            if (!(this.stream.peek_type() is TokenType.Greater)) {
                let first: ast.TypeSpecifier = new ast.TypeSpecifier();
                let t1: Token = this.stream.advance();
                first.name = t1.text;
                if (this.stream.peek_type() is TokenType.Less) {
                    this.parse_genericTypeArgs(first.generic_args);
                }
                list.push(first);
                while (this.stream.peek_type() is TokenType.Comma) {
                    this.stream.advance();
                    let next_type: ast.TypeSpecifier = new ast.TypeSpecifier();
                    if (this.stream.peek_type() is TokenType.Ellipsis) {
                        this.stream.advance();
                        break;
                    }
                    let tn: Token = this.stream.advance();
                    next_type.name = tn.text;
                    if (this.stream.peek_type() is TokenType.Less) {
                        this.parse_genericTypeArgs(next_type.generic_args);
                    }
                    list.push(next_type);
                }
            }
            this.stream.expect(new TokenType.Greater());
        }



        // identifierWithDots: identifier ('.' identifier)*;
        // Classification: Binary
        fun parse_identifierWithDots(this) -> ast.Expression {
            let first: ast.Expression = this.parse_identifier();
            let operators = new List<ast.BinaryOperator>();
            let operands = new List<ast.Expression>();
            operands.push(first);
            while (true) {
                let token: Token = this.stream.peek();
                if (this.stream.peek_type() is TokenType.Dot) {
                    let op_token: Token = this.stream.advance();
                    let op: ast.BinaryOperator = this.token_to_binary_operator(op_token);
                    operators.push(op);
                    let right = this.parse_identifier();
                    operands.push(right);
                } else {
                    break;
                }
            }

            if (operators.size() == 0) {
                return first;
            }
            let bin_expr: ast.BinaryExpression = new ast.BinaryExpression();
            bin_expr.operators = operators;
            bin_expr.operands = operands;
            return new ast.Expression.binary(bin_expr);
        }

        // identifierWithDotsAndGenericArguments: identifierWithDots genericArguments?;
        // Classification: Sequence
        fun parse_identifierWithDotsAndGenericArguments(this) -> ast.Expression {
            this.parse_identifierWithDots();
            if (this.stream.peek_type() is TokenType.Less) {
                this.parse_genericArguments();
            }
            let node = new ast.ConstantExpression();
            return new ast.Expression.constant(node);
        }

        // genericArguments: '<' typeSpecifier (',' typeSpecifier)* (',' variadicGenericArguments)? '>';
        // Classification: Sequence
        fun parse_genericArguments(this) -> ast.Expression {
            this.stream.expect(new TokenType.Less());
            this.parse_typeSpecifier();
            while (this.stream.peek_type() is TokenType.Comma) {
                this.stream.advance();
                if (this.stream.peek_type() is TokenType.Greater) { break; }
                this.parse_typeSpecifier();
            }
            this.stream.expect(new TokenType.Greater());
            let node = new ast.ConstantExpression();
            return new ast.Expression.constant(node);
        }


        // templateParameter: identifier ':' ('type' | typeSpecifier);
        // Classification: Sequence
        fun parse_templateParameter(this) -> ast.TemplateParameter {
            let name_token: Token = this.stream.advance();
            this.stream.expect(new TokenType.Colon());
            let node: ast.TemplateParameter = new ast.TemplateParameter();
            node.name = name_token.text;
            let constraint_token: Token = this.stream.peek();
            if (constraint_token.text == "type") {
                this.stream.advance();
                node.type_constraint = "type";
            } else {
                let ts = this.parse_typeSpecifier();
                node.type_constraint = "";
            }
            return node;
        }

        // templateDeclaration: '#' 'template' '(' templateParameter (',' templateParameter)* ')';
        // Classification: Sequence
        fun parse_templateDeclaration(this) -> ast.TemplateDeclaration {
            this.stream.expect(new TokenType.Hash());
            this.stream.expect(new TokenType.TemplateKw());
            this.stream.expect(new TokenType.LParen());
            let node: ast.TemplateDeclaration = new ast.TemplateDeclaration();
            let tp = this.parse_templateParameter();
            node.parameters.push(tp);
            while (this.stream.peek_type() is TokenType.Comma) {
                this.stream.advance();
                let tp2 = this.parse_templateParameter();
                node.parameters.push(tp2);
            }
            this.stream.expect(new TokenType.RParen());
            return node;
        }

        // whereClause: identifier ':' typeSpecifier;
        // Classification: Sequence
        fun parse_whereClause(this) -> ast.WhereClause {
            let name_token: Token = this.stream.advance();
            this.stream.expect(new TokenType.Colon());
            let node: ast.WhereClause = new ast.WhereClause();
            node.name = name_token.text;
            let ts = this.parse_typeSpecifier();
            return node;
        }

        // whereDefinition: 'where' (whereClause (',' whereClause)*);
        // Classification: Sequence
        fun parse_whereDefinition(this) -> ast.WhereDefinition {
            this.stream.expect(new TokenType.Where());
            this.stream.expect(new TokenType.LParen());
            let node: ast.WhereDefinition = new ast.WhereDefinition();
            let wc = this.parse_whereClause();
            node.clauses.push(wc);
            while (this.stream.peek_type() is TokenType.Comma) {
                this.stream.advance();
                let wc2 = this.parse_whereClause();
                node.clauses.push(wc2);
            }
            this.stream.expect(new TokenType.RParen());
            return node;
        }

        // interfaceDefinition: (templateDeclaration)? 'interface' identifier '{' ((declaration ';') | functionDefinition | interfaceImplementation | eventDefinition)* '}';
        // Classification: Sequence
        fun parse_interfaceDefinition(this) -> ast.Definition {
            let node: ast.InterfaceDefinition = new ast.InterfaceDefinition();
            if (this.stream.peek_type() is TokenType.Hash) {
                let tpl = this.parse_templateDeclaration();
                node.template_decl = new Option<ast.TemplateDeclaration>.some(tpl);
            }
            this.stream.expect(new TokenType.Interface());
            let name_token: Token = this.stream.advance();
            node.name = name_token.text;
            this.stream.expect(new TokenType.LBrace());
            let _loop_guard_pos: mut i64 = -1;
            while (!(this.stream.peek_type() is TokenType.RBrace)) {
                if (this.stream.peek_type() is TokenType.Semicolon) {
                    this.stream.advance();
                    continue;
                }
                if (this.stream.pos == _loop_guard_pos) {
                    print("ERROR: parser stuck at pos " + cast<string>(this.stream.pos) + " token: " + this.stream.peek().to_string());
                    break;
                }
                _loop_guard_pos = this.stream.pos;
                let next: Token = this.stream.peek();
                if (next.token_type is TokenType.Fun || next.token_type is TokenType.Pure || next.token_type is TokenType.NotPure || next.token_type is TokenType.Extern || next.token_type is TokenType.Async || next.token_type is TokenType.NotAsync || next.token_type is TokenType.Hash) {
                    node.members.push(this.parse_functionDefinition());
                } else if (next.token_type is TokenType.EventKw) {
                    node.members.push(this.parse_eventDefinition());
                } else if (next.token_type is TokenType.Impl) {
                    node.members.push(this.parse_interfaceImplementation());
                } else {
                    // declaration ';'
                    this.parse_declaration();
                    this.stream.expect(new TokenType.Semicolon());
                    let fd = new ast.FunctionDefinition();
                    node.members.push(new ast.Definition.function_def(fd));
                }
            }
            this.stream.expect(new TokenType.RBrace());
            return new ast.Definition.interface_def(node);
        }

        // interfaceImplementation: 'impl' typeSpecifier (whereDefinition)? (';' | ('{' (functionDefinition)* '}'));
        // Classification: Sequence
        fun parse_interfaceImplementation(this) -> ast.Definition {
            this.stream.expect(new TokenType.Impl());
            let type_token: Token = this.stream.advance();
            if (this.stream.peek_type() is TokenType.For) {
                // interfaceForImplementation: impl Type for Type { ... }
                this.stream.expect(new TokenType.For());
                let for_type_token: Token = this.stream.advance();
                let node: ast.InterfaceForImplementation = new ast.InterfaceForImplementation();
                node.type_name = type_token.text;
                node.for_type_name = for_type_token.text;
                if (this.stream.peek_type() is TokenType.Where) {
                    let wd = this.parse_whereDefinition();
                    node.where_def = new Option<ast.WhereDefinition>.some(wd);
                }
                if (this.stream.peek_type() is TokenType.LBrace) {
                    this.stream.expect(new TokenType.LBrace());
                    while (!(this.stream.peek_type() is TokenType.RBrace)) {
                        let func_def: ast.Definition = this.parse_functionDefinition();
                        node.functions.push(func_def);
                    }
                    this.stream.expect(new TokenType.RBrace());
                } else {
                    this.stream.expect(new TokenType.Semicolon());
                }
                return new ast.Definition.impl_for_def(node);
            }
            // interfaceImplementation: impl Type { ... } or impl Type ;
            let node2: ast.InterfaceImplementation = new ast.InterfaceImplementation();
            node2.type_name = type_token.text;
            if (this.stream.peek_type() is TokenType.Where) {
                let wd2 = this.parse_whereDefinition();
                node2.where_def = new Option<ast.WhereDefinition>.some(wd2);
            }
            if (this.stream.peek_type() is TokenType.LBrace) {
                this.stream.expect(new TokenType.LBrace());
                while (!(this.stream.peek_type() is TokenType.RBrace)) {
                    let func_def2: ast.Definition = this.parse_functionDefinition();
                    node2.functions.push(func_def2);
                }
                this.stream.expect(new TokenType.RBrace());
            } else {
                this.stream.expect(new TokenType.Semicolon());
            }
            return new ast.Definition.impl_def(node2);
        }

        // interfaceForImplementation: 'impl' typeSpecifier 'for' typeSpecifier (whereDefinition)? (';' | ('{' (functionDefinition)* '}'));
        // Classification: Sequence
        fun parse_interfaceForImplementation(this) -> ast.Definition {
            this.stream.expect(new TokenType.Impl());
            let type_token: Token = this.stream.advance();
            if (this.stream.peek_type() is TokenType.For) {
                // interfaceForImplementation: impl Type for Type { ... }
                this.stream.expect(new TokenType.For());
                let for_type_token: Token = this.stream.advance();
                let node: ast.InterfaceForImplementation = new ast.InterfaceForImplementation();
                node.type_name = type_token.text;
                node.for_type_name = for_type_token.text;
                if (this.stream.peek_type() is TokenType.Where) {
                    let wd = this.parse_whereDefinition();
                    node.where_def = new Option<ast.WhereDefinition>.some(wd);
                }
                if (this.stream.peek_type() is TokenType.LBrace) {
                    this.stream.expect(new TokenType.LBrace());
                    while (!(this.stream.peek_type() is TokenType.RBrace)) {
                        let func_def: ast.Definition = this.parse_functionDefinition();
                        node.functions.push(func_def);
                    }
                    this.stream.expect(new TokenType.RBrace());
                } else {
                    this.stream.expect(new TokenType.Semicolon());
                }
                return new ast.Definition.impl_for_def(node);
            }
            // interfaceImplementation: impl Type { ... } or impl Type ;
            let node2: ast.InterfaceImplementation = new ast.InterfaceImplementation();
            node2.type_name = type_token.text;
            if (this.stream.peek_type() is TokenType.Where) {
                let wd2 = this.parse_whereDefinition();
                node2.where_def = new Option<ast.WhereDefinition>.some(wd2);
            }
            if (this.stream.peek_type() is TokenType.LBrace) {
                this.stream.expect(new TokenType.LBrace());
                while (!(this.stream.peek_type() is TokenType.RBrace)) {
                    let func_def2: ast.Definition = this.parse_functionDefinition();
                    node2.functions.push(func_def2);
                }
                this.stream.expect(new TokenType.RBrace());
            } else {
                this.stream.expect(new TokenType.Semicolon());
            }
            return new ast.Definition.impl_def(node2);
        }

        // classDefinition: (templateDeclaration)? 'class' identifier '{' ((classDeclaration ';') | functionDefinition | interfaceImplementation | eventDefinition | onRoutine)* '}';
        // Classification: Sequence
        fun parse_classDefinition(this) -> ast.Definition {
            let node = new ast.ClassDefinition();
            if (this.stream.peek_type() is TokenType.Hash) {
                let tpl = this.parse_templateDeclaration();
                node.template_decl = new Option<ast.TemplateDeclaration>.some(tpl);
            }
            this.stream.expect(new TokenType.Class());
            let name_token: Token = this.stream.advance();
            node.name = name_token.text;
            this.stream.expect(new TokenType.LBrace());
            let _loop_guard_pos: mut i64 = -1;
            while (!(this.stream.peek_type() is TokenType.RBrace)) {
                if (this.stream.peek_type() is TokenType.Semicolon) {
                    this.stream.advance();
                    continue;
                }
                if (this.stream.pos == _loop_guard_pos) {
                    print("ERROR: parser stuck at pos " + cast<string>(this.stream.pos) + " token: " + this.stream.peek().to_string());
                    break;
                }
                _loop_guard_pos = this.stream.pos;
                let next: Token = this.stream.peek();
                if (next.token_type is TokenType.Fun || next.token_type is TokenType.Pure || next.token_type is TokenType.NotPure || next.token_type is TokenType.Extern || next.token_type is TokenType.Async || next.token_type is TokenType.NotAsync || next.token_type is TokenType.Hash) {
                    node.members.push(this.parse_functionDefinition());
                } else if (next.token_type is TokenType.On) {
                    node.members.push(this.parse_onRoutine());
                } else if (next.token_type is TokenType.EventKw) {
                    node.members.push(this.parse_eventDefinition());
                } else if (next.token_type is TokenType.Impl) {
                    node.members.push(this.parse_interfaceImplementation());
                } else {
                    node.members.push(this.parse_classDeclaration());
                }
            }
            this.stream.expect(new TokenType.RBrace());
            return new ast.Definition.class_def(node);
        }

        // enumDefinition: (templateDeclaration)? 'enum' identifier '{' (enumDeclaration | functionDefinition | interfaceImplementation | eventDefinition | onRoutine)* '}';
        // Classification: Sequence
        fun parse_enumDefinition(this) -> ast.Definition {
            let node = new ast.EnumDefinition();
            if (this.stream.peek_type() is TokenType.Hash) {
                let tpl = this.parse_templateDeclaration();
                node.template_decl = new Option<ast.TemplateDeclaration>.some(tpl);
            }
            this.stream.expect(new TokenType.Enum());
            let name_token: Token = this.stream.advance();
            node.name = name_token.text;
            this.stream.expect(new TokenType.LBrace());
            let _loop_guard_pos: mut i64 = -1;
            while (!(this.stream.peek_type() is TokenType.RBrace)) {
                if (this.stream.peek_type() is TokenType.Semicolon) {
                    this.stream.advance();
                    continue;
                }
                if (this.stream.pos == _loop_guard_pos) {
                    print("ERROR: parser stuck at pos " + cast<string>(this.stream.pos) + " token: " + this.stream.peek().to_string());
                    break;
                }
                _loop_guard_pos = this.stream.pos;
                let next: Token = this.stream.peek();
                if (next.token_type is TokenType.Fun || next.token_type is TokenType.Pure || next.token_type is TokenType.NotPure || next.token_type is TokenType.Extern || next.token_type is TokenType.Async || next.token_type is TokenType.NotAsync || next.token_type is TokenType.Hash) {
                    node.members.push(this.parse_functionDefinition());
                } else if (next.token_type is TokenType.On) {
                    node.members.push(this.parse_onRoutine());
                } else if (next.token_type is TokenType.EventKw) {
                    node.members.push(this.parse_eventDefinition());
                } else if (next.token_type is TokenType.Impl) {
                    node.members.push(this.parse_interfaceImplementation());
                } else {
                    node.members.push(this.parse_enumDeclaration());
                }
            }
            this.stream.expect(new TokenType.RBrace());
            return new ast.Definition.enum_def(node);
        }

        // enumDeclaration: identifier (':' typeSpecifier)? ';';
        // Classification: Sequence
        fun parse_enumDeclaration(this) -> ast.Definition {
            let name_token: Token = this.stream.advance();
            let node: ast.EnumMemberDefinition = new ast.EnumMemberDefinition();
            node.name = name_token.text;
            if (this.stream.match(new TokenType.Colon())) {
                let ts = this.parse_typeSpecifier();
                node.type_spec = new Option<ast.TypeSpecifier>.some(ts);
            }
            this.stream.expect(new TokenType.Semicolon());
            return new ast.Definition.enum_member(node);
        }


        // codeBlockItem: statement | (letKeyword declaration ';') | (typeReferenceDeclaration ';');
        // Classification: Alternative
        fun parse_codeBlockItem(this) -> ast.Statement {
            let next: Token = this.stream.peek();
            if (next.token_type is TokenType.TypeKw) {
                this.parse_typeReferenceDeclaration();
                let empty_stmt: ast.ExpressionStatement = new ast.ExpressionStatement();
                return new ast.Statement.expression(empty_stmt);
            }
            if (next.token_type is TokenType.Let) {
                // letKeyword declaration ';'
                this.stream.advance();
                if (this.stream.match(new TokenType.Mut())) { }
                this.parse_declaration();
                this.stream.expect(new TokenType.Semicolon());
                let empty_let: ast.ExpressionStatement = new ast.ExpressionStatement();
                return new ast.Statement.expression(empty_let);
            }
            // Otherwise: statement
            return this.parse_statement();
        }

        // statement: codeBlockExpression | expressionStatement | ifStatement | whileStatement | forStatement | assignmentStatement | jumpStatement | returnStatement | yieldStatement | signalStatement | emitEventStatement | ';';
        // Classification: Alternative
        fun parse_statement(this) -> ast.Statement {
            let next: Token = this.stream.peek();
            if (next.token_type is TokenType.Let) {
                this.stream.advance();
                let is_mut: mut bool = false;
                if (this.stream.match(new TokenType.Mut())) { is_mut = true; }
                let var_name: Token = this.stream.advance();
                let var_type: mut string = "";
                if (this.stream.match(new TokenType.Colon())) {
                    let ts = this.parse_typeSpecifier();
                    var_type = ts.build_text();
                }
                let init_val: mut Option<ast.Expression> = new Option<ast.Expression>.none();
                if (this.stream.match(new TokenType.Assign())) {
                    init_val = new Option<ast.Expression>.some(this.parse_expression());
                }
                this.stream.expect(new TokenType.Semicolon());
                let let_stmt: ast.LetDeclarationStatement = new ast.LetDeclarationStatement();
                let_stmt.is_mutable = is_mut;
                let_stmt.variable_name = var_name.text;
                let_stmt.variable_type = var_type;
                let_stmt.initializer = init_val;
                return new ast.Statement.let_decl(let_stmt);
            }
            if (next.token_type is TokenType.If) {
                return this.parse_ifStatement();
            }
            if (next.token_type is TokenType.While) {
                return this.parse_whileStatement();
            }
            if (next.token_type is TokenType.For) {
                return this.parse_forStatement();
            }
            if (next.token_type is TokenType.Return) {
                return this.parse_returnStatement();
            }
            if (next.token_type is TokenType.Break || next.token_type is TokenType.Continue) {
                return this.parse_jumpStatement();
            }
            if (next.token_type is TokenType.LBrace) {
                let block = this.parse_codeBlockExpression();
                let es: ast.ExpressionStatement = new ast.ExpressionStatement();
                es.expression = new Option<ast.Expression>.some(block);
                return new ast.Statement.expression(es);
            }
            if (next.token_type is TokenType.Emit) {
                return this.parse_emitEventStatement();
            }
            if (next.token_type is TokenType.Yield) {
                return this.parse_yieldStatement();
            }
            if (next.token_type is TokenType.InternalSignal) {
                return this.parse_signalStatement();
            }
            if (next.token_type is TokenType.Semicolon) {
                this.stream.advance();
                let empty: ast.ExpressionStatement = new ast.ExpressionStatement();
                let void_node: ast.VoidLiteralExpression = new ast.VoidLiteralExpression();
                empty.expression = new Option<ast.Expression>.some(new ast.Expression.void_literal(void_node));
                return new ast.Statement.expression(empty);
            }
            // expression or assignment — parse expression, then check for assignment operator
            let expr = this.parse_expression();
            if (this.stream.peek_type() is TokenType.Semicolon) {
                this.stream.advance();
                let es: ast.ExpressionStatement = new ast.ExpressionStatement();
                es.expression = new Option<ast.Expression>.some(expr);
                return new ast.Statement.expression(es);
            }
            // Must be an assignment: check for assignment operator
            let op_token: Token = this.stream.advance();
            let value = this.parse_expression();
            this.stream.expect(new TokenType.Semicolon());
            let assign = new ast.AssignmentStatement();
            assign.target = new Option<ast.Expression>.some(expr);
            let op: mut ast.AssignmentOperator = this.token_to_assignment_operator(op_token);
            assign.operator_value = op;
            assign.value = new Option<ast.Expression>.some(value);
            return new ast.Statement.assignment(assign);
        }

        // assignmentStatement: postfixExpression assignmentOperator expression ';';
        // Classification: Sequence
        fun parse_assignmentStatement(this) -> ast.Statement {
            let target = this.parse_postfixExpression();
            let op_token: Token = this.stream.advance();
            let value = this.parse_expression();
            this.stream.expect(new TokenType.Semicolon());
            let node = new ast.AssignmentStatement();
            node.target = new Option<ast.Expression>.some(target);
            let op2: mut ast.AssignmentOperator = this.token_to_assignment_operator(op_token);
            node.operator_value = op2;
            node.value = new Option<ast.Expression>.some(value);
            return new ast.Statement.assignment(node);
        }

        // expressionStatement: expression ';';
        // Classification: Sequence
        fun parse_expressionStatement(this) -> ast.Statement {
            let expr = this.parse_expression();
            this.stream.expect(new TokenType.Semicolon());
            let node = new ast.ExpressionStatement();
            node.expression = new Option<ast.Expression>.some(expr);
            return new ast.Statement.expression(node);
        }

        // ifStatement: 'if' '(' expression ')' statement ('else' statement)?;
        // Classification: Sequence
        fun parse_ifStatement(this) -> ast.Statement {
            this.stream.expect(new TokenType.If());
            this.stream.expect(new TokenType.LParen());
            let condition = this.parse_expression();
            this.stream.expect(new TokenType.RParen());
            let then_stmt = this.parse_statement();
            let else_stmt: mut Option<ast.Statement> = new Option<ast.Statement>.none();
            if (this.stream.match(new TokenType.Else())) {
                else_stmt = new Option<ast.Statement>.some(this.parse_statement());
            }
            let node = new ast.IfStatement();
            node.condition = new Option<ast.Expression>.some(condition);
            node.then_statement = new Option<ast.Statement>.some(then_stmt);
            node.else_statement = else_stmt;
            return new ast.Statement.if_stmt(node);
        }

        // whileStatement: 'while' '(' expression ')' statement;
        // Classification: Sequence
        fun parse_whileStatement(this) -> ast.Statement {
            this.stream.expect(new TokenType.While());
            this.stream.expect(new TokenType.LParen());
            let condition = this.parse_expression();
            this.stream.expect(new TokenType.RParen());
            let body = this.parse_statement();
            let node = new ast.WhileStatement();
            node.condition = new Option<ast.Expression>.some(condition);
            node.body = new Option<ast.Statement>.some(body);
            return new ast.Statement.while_stmt(node);
        }

        // forStatement: 'for' '(' letKeyword declaration 'in' expression ')' statement;
        // Classification: Sequence
        fun parse_forStatement(this) -> ast.Statement {
            this.stream.expect(new TokenType.For());
            this.stream.expect(new TokenType.LParen());
            this.stream.expect(new TokenType.Let());
            let is_mut: mut bool = false;
            if (this.stream.match(new TokenType.Mut())) { is_mut = true; }
            let name_token: Token = this.stream.advance();
            let var_type: mut string = "";
            if (this.stream.match(new TokenType.Colon())) {
                let type_token: Token = this.stream.advance();
                var_type = type_token.text;
            }
            this.stream.expect(new TokenType.In());
            let iterable = this.parse_expression();
            this.stream.expect(new TokenType.RParen());
            let body = this.parse_statement();
            let node = new ast.ForStatement();
            node.is_mutable = is_mut;
            node.variable_name = name_token.text;
            node.variable_type = var_type;
            node.iterable = new Option<ast.Expression>.some(iterable);
            node.body = new Option<ast.Statement>.some(body);
            return new ast.Statement.for_stmt(node);
        }

        // jumpStatement: 'continue' ';' | 'break' expression? ';';
        // Classification: Alternative
        fun parse_jumpStatement(this) -> ast.Statement {
            let next: Token = this.stream.peek();
            if (next.token_type is TokenType.Continue) {
                this.stream.advance();
                this.stream.expect(new TokenType.Semicolon());
                let node: ast.ContinueStatement = new ast.ContinueStatement();
                return new ast.Statement.continue_stmt(node);
            }
            // break expression? ';'
            this.stream.expect(new TokenType.Break());
            let node: ast.BreakStatement = new ast.BreakStatement();
            if (!(this.stream.peek_type() is TokenType.Semicolon)) {
                let val: ast.Expression = this.parse_expression();
                node.value = new Option<ast.Expression>.some(val);
            }
            this.stream.expect(new TokenType.Semicolon());
            return new ast.Statement.break_stmt(node);
        }

        // returnStatement: returnKeyword expression? ';';
        // Classification: Sequence
        fun parse_returnStatement(this) -> ast.Statement {
            this.stream.expect(new TokenType.Return());
            let val: mut Option<ast.Expression> = new Option<ast.Expression>.none();
            if (!(this.stream.peek_type() is TokenType.Semicolon)) {
                val = new Option<ast.Expression>.some(this.parse_expression());
            }
            this.stream.expect(new TokenType.Semicolon());
            let node = new ast.ReturnStatement();
            node.value = val;
            return new ast.Statement.return_stmt(node);
        }


        // yieldStatement: 'yield' expression? ';';
        // Classification: Sequence
        fun parse_yieldStatement(this) -> ast.Statement {
            this.stream.expect(new TokenType.Yield());
            let node: ast.YieldStatement = new ast.YieldStatement();
            if (!(this.stream.peek_type() is TokenType.Semicolon)) {
                let val: ast.Expression = this.parse_expression();
                node.value = new Option<ast.Expression>.some(val);
            }
            this.stream.expect(new TokenType.Semicolon());
            return new ast.Statement.yield_stmt(node);
        }

        // signalStatement: '__signal' expression;
        // Classification: Sequence
        fun parse_signalStatement(this) -> ast.Statement {
            this.stream.expect(new TokenType.InternalSignal());
            let node: ast.SignalStatement = new ast.SignalStatement();
            let expr: ast.Expression = this.parse_expression();
            node.expression = new Option<ast.Expression>.some(expr);
            return new ast.Statement.signal_stmt(node);
        }

        // emitEventStatement: 'emit' expression '(' expression? ')' ';';
        // Classification: Sequence
        fun parse_emitEventStatement(this) -> ast.Statement {
            this.stream.expect(new TokenType.Emit());
            let event_expr: ast.Expression = this.parse_expression();
            this.stream.expect(new TokenType.LParen());
            let node: ast.EmitEventStatement = new ast.EmitEventStatement();
            node.event_expr = new Option<ast.Expression>.some(event_expr);
            if (!(this.stream.peek_type() is TokenType.RParen)) {
                let arg: ast.Expression = this.parse_expression();
                node.argument = new Option<ast.Expression>.some(arg);
            }
            this.stream.expect(new TokenType.RParen());
            this.stream.expect(new TokenType.Semicolon());
            return new ast.Statement.emit_event(node);
        }

        // compilationUnit: namespaceDeclaration* EOF;
        // Classification: Sequence
        fun parse_compilationUnit(this) -> ast.CompilationUnit {
            let unit: ast.CompilationUnit = new ast.CompilationUnit();
            let prev_pos: mut i64 = -1;
            while (!(this.stream.is_at_end())) {
                if (this.stream.peek_type() is TokenType.Semicolon) {
                    this.stream.advance();
                    continue;
                }
                if (this.stream.pos == prev_pos) {
                    this.report_error("parser stuck at token: " + this.stream.peek().to_string());
                    break;
                }
                prev_pos = this.stream.pos;
                let def = this.parse_namespaceDeclaration();
                unit.definitions.push(def);
            }
            if (this.has_errors()) {
                print("Parse completed with " + cast<string>(this.errors.size()) + " error(s)");
            }
            return unit;
        }

        // namespaceDeclaration: (letKeyword declaration ';') | typeReferenceDeclaration | namespaceDefinition | initialRoutine | functionDefinition | classDefinition | enumDefinition | interfaceDefinition | interfaceForImplementation | eventDefinition | onRoutine | ';';
        // Classification: Alternative
        fun parse_namespaceDeclaration(this) -> ast.Definition {
            let next: Token = this.stream.peek();
            if (next.token_type is TokenType.Namespace) {
                return this.parse_namespaceDefinition();
            }
            if (next.token_type is TokenType.Fun || next.token_type is TokenType.Pure || next.token_type is TokenType.NotPure || next.token_type is TokenType.Extern || next.token_type is TokenType.Async || next.token_type is TokenType.NotAsync) {
                return this.parse_functionDefinition();
            }
            if (next.token_type is TokenType.Hash) {
                let saved_pos: i64 = this.stream.pos;
                this.stream.advance(); // skip #
                if (this.stream.peek_type() is TokenType.TemplateKw) {
                    this.stream.advance(); // skip template
                    this.stream.expect(new TokenType.LParen());
                    let depth: mut i64 = 1;
                    while (depth > 0 && !(this.stream.is_at_end())) {
                        let t: Token = this.stream.advance();
                        if (t.token_type is TokenType.LParen) { depth = depth + 1; }
                        if (t.token_type is TokenType.RParen) { depth = depth - 1; }
                    }
                    let after_tpl: Token = this.stream.peek();
                    this.stream.pos = saved_pos;
                    if (after_tpl.token_type is TokenType.Class) { return this.parse_classDefinition(); }
                    if (after_tpl.token_type is TokenType.Enum) { return this.parse_enumDefinition(); }
                    if (after_tpl.token_type is TokenType.Interface) { return this.parse_interfaceDefinition(); }
                } else {
                    this.stream.pos = saved_pos;
                }
            }
            if (next.token_type is TokenType.Class) {
                return this.parse_classDefinition();
            }
            if (next.token_type is TokenType.Enum) {
                return this.parse_enumDefinition();
            }
            if (next.token_type is TokenType.Initial) {
                return this.parse_initialRoutine();
            }
            if (next.token_type is TokenType.Let) {
                this.stream.advance();
                if (this.stream.match(new TokenType.Mut())) { }
                let decl = this.parse_declaration();
                this.stream.expect(new TokenType.Semicolon());
                return decl;
            }
            if (next.token_type is TokenType.TypeKw) {
                return this.parse_typeReferenceDeclaration();
            }
            if (next.token_type is TokenType.Interface) {
                return this.parse_interfaceDefinition();
            }
            if (next.token_type is TokenType.Impl) {
                return this.parse_interfaceImplementation();
            }
            if (next.token_type is TokenType.EventKw) {
                return this.parse_eventDefinition();
            }
            if (next.token_type is TokenType.On) {
                return this.parse_onRoutine();
            }
            if (next.token_type is TokenType.Semicolon) {
                this.stream.advance();
                let fallback2 = new ast.FunctionDefinition();
                return new ast.Definition.function_def(fallback2);
            }
            // fallback
            let fallback3 = new ast.FunctionDefinition();
            return new ast.Definition.function_def(fallback3);
        }

        // thisParameter: 'mut'? 'this';
        // Classification: Sequence
        fun parse_thisParameter(this) -> ast.Parameter {
            let is_mut: mut bool = false;
            if (this.stream.match(new TokenType.Mut())) { is_mut = true; }
            this.stream.expect(new TokenType.ThisKw());
            let node: ast.Parameter = new ast.Parameter();
            node.is_this = true;
            node.is_mutable = is_mut;
            return node;
        }

        // singleParameter: identifier (':' typeSpecifier)? ('=' expression)?;
        fun parse_singleParameter(this) -> ast.Parameter {
            let name_token: Token = this.stream.advance();
            let node: ast.Parameter = new ast.Parameter();
            node.name = name_token.text;
            if (this.stream.match(new TokenType.Colon())) {
                let ts = this.parse_typeSpecifier();
                node.type_spec = new Option<ast.TypeSpecifier>.some(ts);
            }
            if (this.stream.match(new TokenType.Assign())) {
                let default_val: ast.Expression = this.parse_expression();
                node.default_value = new Option<ast.Expression>.some(default_val);
            }
            return node;
        }

        // parameterList: (thisParameter | singleParameter)? (',' singleParameter)* ','?;
        // Classification: Sequence
        fun parse_parameterList(this, params: mut List<ast.Parameter>) {
            if (!(this.stream.peek_type() is TokenType.RParen)) {
                let first = this.stream.peek();
                if (first.token_type is TokenType.ThisKw || first.token_type is TokenType.Mut) {
                    params.push(this.parse_thisParameter());
                } else {
                    params.push(this.parse_singleParameter());
                }
            }
            while (this.stream.match(new TokenType.Comma())) {
                if (this.stream.peek_type() is TokenType.RParen) { break; }
                params.push(this.parse_singleParameter());
            }
        }


        // lambdaFunctionExpression: ('fun' | 'async_fun') ('(' parameterList ')')? ('->' typeSpecifier)? codeBlockExpression;
        // Classification: Sequence
        fun parse_lambdaFunctionExpression(this) -> ast.Expression {
            let node: ast.LambdaFunctionExpression = new ast.LambdaFunctionExpression();
            this.stream.expect(new TokenType.Fun());
            if (this.stream.peek_type() is TokenType.LParen) {
                this.stream.expect(new TokenType.LParen());
                this.parse_parameterList(node.parameters);
                this.stream.expect(new TokenType.RParen());
            }
            if (this.stream.match(new TokenType.Arrow())) {
                let ret_type = this.parse_typeSpecifier();
                node.return_type = new Option<ast.TypeSpecifier>.some(ret_type);
            }
            let body: ast.Expression = this.parse_codeBlockExpression();
            node.body = new Option<ast.Expression>.some(body);
            return new ast.Expression.lambda_expr(node);
        }

        // functionDefinition: functionSpecifier* 'fun' (identifier | 'new') ('(' parameterList ')')? ('->' typeSpecifier)? (codeBlockExpression | ';');
        // Classification: Sequence
        fun parse_functionDefinition(this) -> ast.Definition {
            let node = new ast.FunctionDefinition();
            if (this.stream.peek_type() is TokenType.Hash) {
                let tpl = this.parse_templateDeclaration();
                node.template_decl = new Option<ast.TemplateDeclaration>.some(tpl);
            }
            while (true) {
                let spec: Token = this.stream.peek();
                if (spec.token_type is TokenType.Pure) {
                    this.stream.advance();
                    node.is_pure = true;
                } else if (spec.token_type is TokenType.NotPure) {
                    this.stream.advance();
                    node.is_not_pure = true;
                } else if (spec.token_type is TokenType.Extern) {
                    this.stream.advance();
                    node.is_extern = true;
                } else if (spec.token_type is TokenType.Async) {
                    this.stream.advance();
                    node.is_async = true;
                } else if (spec.token_type is TokenType.NotAsync) {
                    this.stream.advance();
                    node.is_not_async = true;
                } else {
                    break;
                }
            }
            this.stream.expect(new TokenType.Fun());
            let name_token: Token = this.stream.advance();
            node.name = name_token.text;
            if (name_token.text == "new") { node.is_new = true; }
            if (this.stream.match(new TokenType.LParen())) {
                this.parse_parameterList(node.parameters);
                this.stream.expect(new TokenType.RParen());
            }
            if (this.stream.match(new TokenType.Arrow())) {
                let ret_type = this.parse_typeSpecifier();
                node.return_type = new Option<ast.TypeSpecifier>.some(ret_type);
            }
            if (this.stream.peek_type() is TokenType.LBrace) {
                let body_expr = this.parse_codeBlockExpression();
                node.body = new Option<ast.Expression>.some(body_expr);
            } else {
                this.stream.expect(new TokenType.Semicolon());
            }
            return new ast.Definition.function_def(node);
        }

        // eventDefinition: 'event' identifier (':' typeSpecifier)? ';';
        // Classification: Sequence
        fun parse_eventDefinition(this) -> ast.Definition {
            this.stream.expect(new TokenType.EventKw());
            let name_token: Token = this.stream.advance();
            let node: ast.EventDefinition = new ast.EventDefinition();
            node.name = name_token.text;
            if (this.stream.match(new TokenType.Colon())) {
                let type_token: Token = this.stream.advance();
                let ts: ast.TypeSpecifier = new ast.TypeSpecifier();
                ts.name = type_token.text;
                node.event_type = new Option<ast.TypeSpecifier>.some(ts);
            }
            this.stream.expect(new TokenType.Semicolon());
            return new ast.Definition.event_def(node);
        }

        // initialRoutine: 'initial' identifier? codeBlockExpression;
        // Classification: Sequence
        fun parse_initialRoutine(this) -> ast.Definition {
            this.stream.expect(new TokenType.Initial());
            // Optional identifier before codeBlockExpression
            if (!(this.stream.peek_type() is TokenType.LBrace)) {
                this.stream.advance(); // consume optional identifier
            }
            let body = this.parse_codeBlockExpression();
            let node = new ast.InitialRoutineDefinition();
            node.body = new Option<ast.Expression>.some(body);
            return new ast.Definition.initial_routine(node);
        }

        // onRoutine: 'on' expression ('(' declarationWithoutInitializer? ')')? codeBlockExpression;
        // Classification: Sequence
        fun parse_onRoutine(this) -> ast.Definition {
            this.stream.expect(new TokenType.On());
            let node: ast.OnRoutineDefinition = new ast.OnRoutineDefinition();
            let event_token: Token = this.stream.advance();
            let event_id: ast.IdentifierExpression = new ast.IdentifierExpression();
            event_id.name = event_token.text;
            if (this.stream.peek_type() is TokenType.Dot) {
                let base_id: ast.IdentifierExpression = new ast.IdentifierExpression();
                base_id.name = event_token.text;
                this.stream.expect(new TokenType.Dot());
                let member_token: Token = this.stream.advance();
                let ma: ast.MemberAccessExpression = new ast.MemberAccessExpression();
                ma.base_expr = new Option<ast.Expression>.some(new ast.Expression.identifier(base_id));
                ma.member_name = member_token.text;
                node.event_expr = new Option<ast.Expression>.some(new ast.Expression.member_access(ma));
            } else {
                node.event_name = event_token.text;
                node.event_expr = new Option<ast.Expression>.some(new ast.Expression.identifier(event_id));
            }
            if (this.stream.peek_type() is TokenType.LParen) {
                this.stream.expect(new TokenType.LParen());
                if (!(this.stream.peek_type() is TokenType.RParen)) {
                    this.parse_declarationWithoutInitializer();
                }
                this.stream.expect(new TokenType.RParen());
            }
            let body: ast.Expression = this.parse_codeBlockExpression();
            node.body = new Option<ast.Expression>.some(body);
            return new ast.Definition.on_routine_def(node);
        }

        // namespaceDefinition: 'namespace' identifier '{' namespaceDeclaration* '}';
        // Classification: Sequence
        fun parse_namespaceDefinition(this) -> ast.Definition {
            this.stream.expect(new TokenType.Namespace());
            let name_token: Token = this.stream.advance();
            this.stream.expect(new TokenType.LBrace());
            let node = new ast.NamespaceDefinition();
            node.name = name_token.text;
            let _loop_guard_pos: mut i64 = -1;
            while (!(this.stream.peek_type() is TokenType.RBrace)) {
                if (this.stream.peek_type() is TokenType.Semicolon) {
                    this.stream.advance();
                    continue;
                }
                if (this.stream.pos == _loop_guard_pos) {
                    print("ERROR: parser stuck at pos " + cast<string>(this.stream.pos) + " token: " + this.stream.peek().to_string());
                    break;
                }
                _loop_guard_pos = this.stream.pos;
                let child = this.parse_namespaceDeclaration();
                node.children.push(child);
            }
            this.stream.expect(new TokenType.RBrace());
            return new ast.Definition.namespace_def(node);
        }

        // identifier: Identifier | 'this';
        // Classification: Alternative
        fun parse_identifier(this) -> ast.Expression {
            let token: Token = this.stream.peek();
            if (token.token_type is TokenType.Identifier) {
                let token: Token = this.stream.advance();
                let const_expr: ast.ConstantExpression = new ast.ConstantExpression();
                const_expr.value = token.text;
                return new ast.Expression.constant(const_expr);
            } else if (token.token_type is TokenType.ThisKw) {
                let token: Token = this.stream.advance();
                let const_expr: ast.ConstantExpression = new ast.ConstantExpression();
                const_expr.value = token.text;
                return new ast.Expression.constant(const_expr);
            } else {
                let const_expr: ast.ConstantExpression = new ast.ConstantExpression();
                return new ast.Expression.constant(const_expr);
            }
        }

        // boolLiteral: 'true' | 'false';
        // Classification: Alternative
        fun parse_boolLiteral(this) -> ast.Expression {
            let token: Token = this.stream.peek();
            if (token.token_type is TokenType.True) {
                let token: Token = this.stream.advance();
                let const_expr: ast.ConstantExpression = new ast.ConstantExpression();
                const_expr.value = token.text;
                return new ast.Expression.constant(const_expr);
            } else if (token.token_type is TokenType.False) {
                let token: Token = this.stream.advance();
                let const_expr: ast.ConstantExpression = new ast.ConstantExpression();
                const_expr.value = token.text;
                return new ast.Expression.constant(const_expr);
            } else {
                let const_expr: ast.ConstantExpression = new ast.ConstantExpression();
                return new ast.Expression.constant(const_expr);
            }
        }

        // voidLiteral: 'void';
        // Classification: Sequence
        fun parse_voidLiteral(this) -> ast.Expression {
            this.stream.expect(new TokenType.Void());
            let node = new ast.ConstantExpression();
            node.value = "<voidLiteral>";
            return new ast.Expression.constant(node);
        }

        fun token_to_binary_operator(this, token: Token) -> ast.BinaryOperator {
            if (token.text == "+") { return new ast.BinaryOperator.Add(); }
            if (token.text == "-") { return new ast.BinaryOperator.Subtract(); }
            if (token.text == "*") { return new ast.BinaryOperator.Multiply(); }
            if (token.text == "/") { return new ast.BinaryOperator.Divide(); }
            if (token.text == "%") { return new ast.BinaryOperator.Modulo(); }
            if (token.text == "<") { return new ast.BinaryOperator.LessThan(); }
            if (token.text == ">") { return new ast.BinaryOperator.GreaterThan(); }
            if (token.text == "<=") { return new ast.BinaryOperator.LessThanOrEqual(); }
            if (token.text == ">=") { return new ast.BinaryOperator.GreaterThanOrEqual(); }
            if (token.text == "==") { return new ast.BinaryOperator.Equal(); }
            if (token.text == "!=") { return new ast.BinaryOperator.NotEqual(); }
            if (token.text == "&&") { return new ast.BinaryOperator.LogicalAnd(); }
            if (token.text == "||") { return new ast.BinaryOperator.LogicalOr(); }
            if (token.text == "&") { return new ast.BinaryOperator.BitwiseAnd(); }
            if (token.text == "|") { return new ast.BinaryOperator.BitwiseOr(); }
            if (token.text == "^") { return new ast.BinaryOperator.BitwiseXor(); }
            if (token.text == "is") { return new ast.BinaryOperator.Is(); }
            return new ast.BinaryOperator.Add();
        }
        fun token_to_assignment_operator(this, token: Token) -> ast.AssignmentOperator {
            if (token.text == "=") { return new ast.AssignmentOperator.Assign(); }
            if (token.text == "+=") { return new ast.AssignmentOperator.PlusAssign(); }
            if (token.text == "-=") { return new ast.AssignmentOperator.MinusAssign(); }
            if (token.text == "*=") { return new ast.AssignmentOperator.StarAssign(); }
            if (token.text == "/=") { return new ast.AssignmentOperator.SlashAssign(); }
            if (token.text == "%=") { return new ast.AssignmentOperator.PercentAssign(); }
            if (token.text == "&=") { return new ast.AssignmentOperator.AmpersandAssign(); }
            if (token.text == "^=") { return new ast.AssignmentOperator.CaretAssign(); }
            if (token.text == "|=") { return new ast.AssignmentOperator.PipeAssign(); }
            return new ast.AssignmentOperator.Assign();
        }
        fun token_to_unary_operator(this, token: Token) -> ast.UnaryOperator {
            if (token.text == "-") { return new ast.UnaryOperator.Negate(); }
            if (token.text == "!") { return new ast.UnaryOperator.Not(); }
            if (token.text == "~") { return new ast.UnaryOperator.BitwiseNot(); }
            if (token.text == "+") { return new ast.UnaryOperator.UnaryPlus(); }
            if (token.text == "*") { return new ast.UnaryOperator.Deref(); }
            if (token.text == "&") { return new ast.UnaryOperator.Ref(); }
            return new ast.UnaryOperator.Negate();
        }
    }
}
